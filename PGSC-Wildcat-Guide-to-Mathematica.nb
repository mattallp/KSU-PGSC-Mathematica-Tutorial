Cell[TextData[StyleBox["Here, you can practice writing your own code. \
Possible solutions to exercises will also be included. Hopefully, you will \
find this guide helpful! If you have any issues or questions, please reach \
out to me at mattallp@ksu.edu or over Discord\n\n-Matthew Allphin, PGSC \
Academic Chair 2026-2027", "Subsubtitle"]], "Text",
 CellChangeTimes->{{3.976274435054739*^9, 3.9762744542237396`*^9}, {
   3.9762745321428413`*^9, 3.9762745331717167`*^9}, 3.9762745662759724`*^9, {
