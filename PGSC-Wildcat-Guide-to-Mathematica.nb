Cell["\<\
This happens because when I use =, Mathematica evaluates the function \
definition only when I execute the cell containing the definition. However, I \
can use a delayed function definition so that Mathematica will evaluate the \
definition each time the function is called. Using the same example as \
before, I can now change the values of a, b, and c at any time:\
\>", "Text",
 CellChangeTimes->{{3.9769703275681095`*^9, 3.9769705158493385`*^9}, {
   3.976970645160671*^9, 3.976970742818342*^9}, {3.9769709209860477`*^9, 
   3.9769710108886166`*^9}, {3.976971416332304*^9, 3.976971419872059*^9}, 
   3.976971487787777*^9, {3.9772463042085876`*^9, 3.9772463056383553`*^9}, {
   3.977247239015276*^9, 3.977247343866049*^9}, {3.9772474233519287`*^9, 
   3.977247461797262*^9}, {3.9772477847178707`*^9, 3.9772477994530964`*^9}, {
   3.9772478963172474`*^9, 3.9772478997908688`*^9}, {3.9772485880586033`*^9, 
   3.977248659757139*^9}, {3.9772488305432224`*^9, 
   3.9772488783086967`*^9}},ExpressionUUID->"e9978367-24b3-3348-9a03-\
e6d6f4bab4c8"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"a", ",", "b", ",", "c", ",", "h"}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Clear", " ", "variable", " ", "names"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"h", "[", "x_", "]"}], ":=", " ", 
   RowBox[{
    RowBox[{"a", " ", 
     SuperscriptBox["x", "2"]}], " ", "+", " ", 
    RowBox[{"b", " ", "x"}], " ", "+", " ", "c"}]}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"define", " ", "a", " ", "function", " ", "h", 
     RowBox[{"(", "x", ")"}], " ", "using"}], " ", "="}], "*)"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]"}], "Input",
