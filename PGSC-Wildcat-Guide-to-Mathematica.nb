     RowBox[{
      RowBox[{"-", "0.27825451262035505`"}], "+", 
      RowBox[{"2.6630812473958977`*^-17", " ", "\[ImaginaryI]"}]}], ",", 
     RowBox[{
      RowBox[{"-", "0.3533967124345227`"}], "-", 
