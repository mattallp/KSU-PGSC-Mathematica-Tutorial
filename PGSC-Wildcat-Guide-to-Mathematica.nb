Cell[CellGroupData[{

Cell["Exercise", "Subsubsection",
 CellChangeTimes->{{3.9929468041781654`*^9, 
  3.9929468061879444`*^9}},ExpressionUUID->"b8aba663-e172-2744-893c-\
74f067092191"],

Cell[TextData[{
 "In section V, we will be dealing with how to plot and fit data. It will be \
useful to know how to convert two related lists of data into a set of ordered \
pairs. For this exercise, you will hopefully be able to find a way to do so \
(or at least look at the solution for a way to do so).  Here you have two \
sets of data X = {",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], "1"], ",", 
         SubscriptBox[
          StyleBox["x", "TI"], "2"], ",", "\[Ellipsis]", ",", 
         SubscriptBox[
          StyleBox["x", "TI"], 
          StyleBox["n", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "x_1,x_2,\\ldots,x_n", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "61784a34-de98-7e47-8977-62f7be68677c"],
 "}",
 StyleBox[" ", "Subsubsection"],
 "and Y = {",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["y", "TI"], "1"], ",", 
         SubscriptBox[
          StyleBox["y", "TI"], "2"], ",", "\[Ellipsis]", ",", 
         SubscriptBox[
          StyleBox["y", "TI"], 
          StyleBox["n", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "y_1,y_2,\\ldots,y_n", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8866ef83-7aa3-be40-b48c-061040a610c0"],
 "}, convert the data into a list of ordered pairs, pairList = {(",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], "1"], ",", 
         SubscriptBox[
          StyleBox["y", "TI"], "1"], ")", ",", 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox[
              StyleBox["x", "TI"], "2"], ",", 
             SubscriptBox[
              StyleBox["y", "TI"], "2"]}], ")"}], ",", "\[Ellipsis]", ",", 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox[
              StyleBox["x", "TI"], 
              StyleBox["n", "TI"]], ",", 
             SubscriptBox[
              StyleBox["y", "TI"], 
              StyleBox["n", "TI"]]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> "x_1,y_1),(x_2,y_2),\\ldots,(x_n,y_n)", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1b9be4b3-1365-8747-847c-691dae931d86"],
 "}"
}], "Text",
 CellChangeTimes->{{3.9929468041781654`*^9, 3.9929468195769577`*^9}, {
  3.9929469533937283`*^9, 3.992947131525524*^9}, {3.992947163762535*^9, 
  3.9929471710319595`*^9}, {3.992947222849251*^9, 
  3.992947492417183*^9}},ExpressionUUID->"05aea140-a31e-7c4e-9f60-\
c3cd5860b91b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"X", " ", "=", " ", 
    RowBox[{"Table", "[", 
     RowBox[{"j", ",", 
      RowBox[{"{", 
       RowBox[{"j", ",", "1", ",", "20"}], "}"}]}], "]"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Data", " ", "set", " ", "X"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Y", " ", "=", " ", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"RandomReal", "[", "]"}], ",", "20"}], "]"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Data", " ", "set", " ", "Y"}], "*)"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"your", " ", "code", " ", "here"}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.9929468041781654`*^9, 3.9929468195769577`*^9}, {
  3.9929469533937283`*^9, 3.9929471570775566`*^9}, {3.992947242422264*^9, 
  3.9929472596191864`*^9}, {3.9929475147914314`*^9, 3.992947601998068*^9}, {
  3.992947784717535*^9, 
  3.9929477987435417`*^9}},ExpressionUUID->"faa2188f-6d15-8541-8958-\
0d3fdf7ef63b"]
}, Closed]],

Cell[CellGroupData[{

Cell["Solution", "Subsubsection",
 CellChangeTimes->{{3.9929477594186115`*^9, 
  3.9929477621242676`*^9}},ExpressionUUID->"8f71b1b3-37c2-2140-b1d5-\
476cce3411ca"],

Cell["\<\
Again, there are a lot of ways to do this, but I find that the simplest way \
is to simply place the two data sets in a list and then transpose them. \
\>", "Text",
 CellChangeTimes->{{3.992947772931267*^9, 
  3.9929478257023544`*^9}},ExpressionUUID->"21e6aef6-bfd9-144d-8658-\
c51fc98d03fe"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"{", 
   RowBox[{"X", ",", "Y"}], "}"}], "//", " ", "Transpose"}]], "Input",
