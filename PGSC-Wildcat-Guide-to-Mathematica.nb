 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"a", ",", "b", ",", "c", ",", "h"}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Clear", " ", "variable", " ", "names"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"h", "[", "x_", "]"}], ":=", " ", 
   RowBox[{
    RowBox[{"a", " ", 
     SuperscriptBox["x", "2"]}], " ", "+", " ", 
    RowBox[{"b", " ", "x"}], " ", "+", " ", "c"}]}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"define", " ", "a", " ", "function", " ", "h", 
     RowBox[{"(", "x", ")"}], " ", "using"}], " ", "="}], "*)"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]"}], "Input",
