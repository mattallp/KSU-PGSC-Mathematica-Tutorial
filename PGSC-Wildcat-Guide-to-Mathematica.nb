Cell[CellGroupData[{

Cell["Numerics", "Subsection",
 CellChangeTimes->{{3.9929479349014854`*^9, 3.9929479392459583`*^9}, {
  3.992947992167433*^9, 3.992947999457571*^9}, {3.993042107468937*^9, 
  3.9930421086727657`*^9}},ExpressionUUID->"b8f17eb4-924b-274f-b7c3-\
77c8562bd874"],

Cell["\<\
As with all mathematical computing, we also need to be mindful of the quirks \
and nuances of numerical accuracy and precision. I will not go into the \
specifics of the different types of numerical errors that occur, for that you \
will have to take a course that deals with numerical methods. However, in \
Mathematica there are a few built-in tools that help us to manage numerics. \
We have already seen the use of the numerical evaluation command, N (see \
Section 1, Variables and Basic Functions):\
\>", "Text",
 CellChangeTimes->{{3.9929479349014854`*^9, 3.9929481910779495`*^9}, {
  3.9929482492609158`*^9, 3.9929482964550915`*^9}, {3.9929484152468357`*^9, 
  3.992948416227564*^9}, {3.99294851088715*^9, 
  3.9929485427209797`*^9}},ExpressionUUID->"f848cd05-e957-f04f-aef9-\
6de1e98c5e90"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Pi", "  ", 
  RowBox[{"(*", 
   RowBox[{
   "outputs", " ", "the", " ", "exact", " ", "expression", " ", "for", " ", 
    "\[Pi]"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"N", "[", "Pi", "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "gives", " ", "a", " ", "numerical", " ", "approximation", " ", "for", " ",
     "\[Pi]"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"N", "[", 
   RowBox[{"Pi", ",", "3"}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Specifically", " ", "gives", " ", "a", " ", "numerical", " ", 
    "approximation", " ", "for", " ", "\[Pi]", " ", "to", " ", "3", " ", 
    "digits"}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.9929479349014854`*^9, 3.9929481910779495`*^9}, {
  3.9929482492609158`*^9, 3.9929482964550915`*^9}, {3.9929484152468357`*^9, 
  3.9929484904269085`*^9}},
 CellLabel->"In[53]:=",ExpressionUUID->"4dd51f9b-7ca5-bb4a-b6c4-3def3ebe2db9"],

Cell[BoxData["\[Pi]"], "Output",
 CellChangeTimes->{3.992948492337517*^9},
 CellLabel->"Out[53]=",ExpressionUUID->"4c91efeb-5107-3a4a-b5b1-e381e75c3a4f"],

Cell[BoxData["3.141592653589793`"], "Output",
 CellChangeTimes->{3.992948492337517*^9},
 CellLabel->"Out[54]=",ExpressionUUID->"17ba5485-cb9f-ec42-8d7f-14bf0643f352"],

Cell[BoxData["3.1415926535897932385`3."], "Output",
 CellChangeTimes->{3.992948492353714*^9},
 CellLabel->"Out[55]=",ExpressionUUID->"2edf9914-53d0-c54a-b591-562b533adb95"]
}, Open  ]],

Cell[TextData[{
 "While this can be helpful to manage the final output of any calculation, it \
won\[CloseCurlyQuote]t affect how Mathematica manages numerical values during \
calculation. Fortunately, Mathematica does have built-in commands for common \
types of numerical calculation. We will begin with Integration. Mathematica\
\[CloseCurlyQuote]s ",
 StyleBox["Integral",
  FontWeight->"Bold"],
 " command",
 " will first attempt to evaluate an integral exactly:"
}], "Text",
 CellChangeTimes->{{3.992948546508007*^9, 3.9929485523373737`*^9}, {
  3.992948594973736*^9, 3.992948618538702*^9}, {3.9929487244035225`*^9, 
  3.9929487897723064`*^9}, {3.992948868525984*^9, 3.9929488911562195`*^9}, {
  3.992948925218214*^9, 3.9929489663234043`*^9}, {3.9929490060540657`*^9, 
  3.992949008473812*^9}, {3.9929491004075546`*^9, 3.992949110860607*^9}, {
  3.992949250178299*^9, 3.9929492769078884`*^9}, {3.992949328509081*^9, 
  3.9929493378705482`*^9}, {3.992949424501524*^9, 
  3.9929494648589554`*^9}},ExpressionUUID->"e6b42ef4-f00a-8748-bde3-\
091fb962395d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{"Exp", "[", 
     RowBox[{"-", 
      SuperscriptBox["x", "2"]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}]}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Evaluated", " ", "the", " ", "Gaussian", " ", "integral", " ", 
    "exactly"}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.992948546508007*^9, 3.9929485523373737`*^9}, {
  3.992948594973736*^9, 3.992948618538702*^9}, {3.9929487244035225`*^9, 
  3.9929487897723064`*^9}, {3.992948868525984*^9, 3.9929488911562195`*^9}, {
  3.992948925218214*^9, 3.9929489663234043`*^9}, {3.9929490060540657`*^9, 
  3.992949008473812*^9}, {3.9929491004075546`*^9, 3.992949110860607*^9}, {
  3.992949250178299*^9, 
  3.9929493176410236`*^9}},ExpressionUUID->"9550bea8-3192-aa47-b0c3-\
8390ae21f30a"],

Cell[BoxData[
 SqrtBox["\[Pi]"]], "Output",
 CellChangeTimes->{3.992949304599888*^9},
 CellLabel->"Out[56]=",ExpressionUUID->"940f5a90-394e-904c-afba-4faddf8a4824"]
}, Open  ]],

Cell["\<\
If exact integration is not possible, it will attempt to evaluate the \
integral numerically:\
\>", "Text",
 CellChangeTimes->{{3.992949438497555*^9, 3.992949446203745*^9}, {
  3.992949503310198*^9, 3.99294951697653*^9}, {3.992949620756092*^9, 
  3.9929496335188675`*^9}},ExpressionUUID->"f9bbfb53-5a67-f645-9aef-\
7efe6ea91500"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Exp", "[", 
      RowBox[{"-", 
       SuperscriptBox["x", "2"]}], "]"}], 
     RowBox[{"Sin", "[", "x", "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0.2", ",", "0.3"}], "}"}]}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Mathematica", " ", "was", " ", "unable", " ", "to", " ", "evaluate", " ", 
    "the", " ", "integral", " ", "exactly", " ", "and", " ", "therefore", " ",
     "use", " ", "numerical", " ", "techniques", " ", "to", " ", "calculate", 
    " ", "the", " ", "integral"}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.992949438497555*^9, 3.992949446203745*^9}, {
  3.992949503310198*^9, 3.99294951697653*^9}, {3.992949620756092*^9, 
  3.9929497533600674`*^9}, {3.992949804412134*^9, 3.9929498466248455`*^9}, {
  3.992949918717882*^9, 
  3.9929499451587486`*^9}},ExpressionUUID->"ce57d975-ecab-da44-900f-\
017a60a60ecc"],

Cell[BoxData[
 RowBox[{"0.023176983716635076`", "\[VeryThinSpace]", "+", 
  RowBox[{"0.`", " ", "\[ImaginaryI]"}]}]], "Output",
 CellChangeTimes->{{3.992949669368305*^9, 3.9929497008709164`*^9}, {
  3.992949733153429*^9, 3.9929497661399803`*^9}, {3.9929498068175583`*^9, 
  3.9929498471828346`*^9}},
 CellLabel->"Out[69]=",ExpressionUUID->"9b8c2fa8-fb2e-014e-8403-dcb329fd70a6"]
}, Open  ]],

Cell[TextData[{
 "This is the case for a number of Mathematica\[CloseCurlyQuote]s commands. \
However, if we know that an integral (or calculation) cannot be done exactly, \
we can skip the exact integral calculation attempt by utilizing the ",
 StyleBox["NIntegrate ",
  FontWeight->"Bold"],
 "command. This command also has a lot of options that can change the method \
with which integration is done and change the precision and accuracy of the \
numbers used in calculation. Let\[CloseCurlyQuote]s look at an integral with \
some notable singularities: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox["\[Integral]", "30", "\[Infinity]"], 
         FractionBox[
          SuperscriptBox[
           StyleBox["e", "TI"], 
           RowBox[{"-", 
             StyleBox["x", "TI"]}]], 
          RowBox[{"sin", "(", 
            RowBox[{"\[Pi]", 
              StyleBox["x", "TI"]}], ")"}]], 
         StyleBox["d", "TI"], 
         StyleBox["x", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\int_{30}^{\\infty} \\frac{e^{-x}}{\\sin(\\pi x)}dx", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "294be1d0-2dcd-e74d-88d1-780faf899ebb"],
 "\nIf we try to use the normal ",
 StyleBox["Integrate ",
  FontWeight->"Bold"],
 "we see that it throws an error:"
}], "Text",
 CellChangeTimes->{{3.9929479349014854`*^9, 3.9929481910779495`*^9}, {
  3.9929482492609158`*^9, 3.9929482934192924`*^9}, {3.9929497772048798`*^9, 
  3.9929498130963593`*^9}, {3.9929498665070915`*^9, 3.992949905292427*^9}, {
  3.9929499488048496`*^9, 3.992949969056402*^9}, {3.993029692947195*^9, 
  3.993029735858597*^9}, {3.99302978756312*^9, 3.9930298836913567`*^9}, {
  3.993029943289179*^9, 3.9930299677665195`*^9}, {3.993030028757126*^9, 
  3.993030030858675*^9}, {3.993030209050455*^9, 3.993030211050951*^9}, {
  3.993030278182234*^9, 3.993030315127407*^9}, {3.993030377435587*^9, 
  3.9930303939814873`*^9}, {3.993030440513525*^9, 3.9930304820463467`*^9}, {
  3.993030840182335*^9, 3.9930308569612293`*^9}, {3.993032292401287*^9, 
  3.993032300256838*^9}, {3.993041984128645*^9, 
  3.993041984578415*^9}},ExpressionUUID->"dc4738ad-7ed1-984f-949f-\
c4c233d4396f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Integrate", "[", 
   RowBox[{
    FractionBox[
     RowBox[{"Exp", "[", 
      RowBox[{"-", "x"}], "]"}], 
     RowBox[{"Sin", "[", 
      RowBox[{"\[Pi]", " ", "x"}], "]"}]], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "30", ",", "Infinity"}], "}"}]}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "integration", " ", "of", " ", "a", " ", "singular", " ", "function", " ", 
    "will", " ", "give", " ", "a", " ", "error"}], "*)"}]}]], "Input",
 CellChangeTimes->CompressedData["
1:eJxTTMoPSmViYGAQB2IQ/ePGndkf9791nFD3aDeIzonUOAyib2StPQGiE/rU
