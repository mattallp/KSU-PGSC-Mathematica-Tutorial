Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"V", "[", 
     RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], "=", " ", 
    RowBox[{
     SuperscriptBox["x", "2"], "+", 
     SuperscriptBox["y", "2"], "+", 
     SuperscriptBox["z", "2"]}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"A", " ", "simple", " ", "3", "D", " ", "potential"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"GradV", "[", 
     RowBox[{"x_", ",", "y_"}], "]"}], "=", " ", 
    RowBox[{"Grad", "[", 
     RowBox[{
      RowBox[{"V", "[", 
       RowBox[{"x", ",", "y", ",", "z"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "y", ",", "z"}], "}"}]}], "]"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"get", " ", "the", " ", "gradient", " ", "of", " ", "V"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"StreamPlot3D", "[", 
   RowBox[{
    RowBox[{"-", 
     RowBox[{"GradV", "[", 
      RowBox[{"x", ",", "y"}], "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"y", ",", 
      RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"z", ",", 
      RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}], "  ", 
  RowBox[{"(*", 
   RowBox[{"Plot", " ", "of", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{"-", "\[Del]", 
          StyleBox["V", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
      "-\\nabla V", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"]}], "*)"}]}]}], "Input",
