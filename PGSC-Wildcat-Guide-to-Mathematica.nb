 TemplateBox[{"322.`", 
   RowBox[{
    "\"kg\"", "\[ThinSpace]", "\"ft\"", "\[InvisibleSpace]", "\"/\"", 
     "\[InvisibleSpace]", 
     SuperscriptBox["\"s\"", "2"]}], "kilogram feet per second squared", 
   FractionBox[
    RowBox[{"\"Feet\"", " ", "\"Kilograms\""}], 
    SuperscriptBox["\"Seconds\"", "2"]]},
  "Quantity"]], "Output",
 CellChangeTimes->{{3.9935512523774347`*^9, 3.993551260290386*^9}, 
   3.993551314866229*^9},
 CellLabel->"Out[12]=",ExpressionUUID->"307a59d3-36a1-454b-a7f0-907dd2f2c010"],

Cell[BoxData[
 TemplateBox[{"98.1456`", "\"N\"", "newtons", "\"Newtons\""},
  "Quantity"]], "Output",
