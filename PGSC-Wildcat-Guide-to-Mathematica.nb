  "During evaluation of \
In[64]:=",ExpressionUUID->"d47237ce-344b-cd45-a86b-cf67f0a70691"],

Cell[BoxData[
 RowBox[{
  SubsuperscriptBox["\[Integral]", "30", "\[Infinity]"], 
  RowBox[{
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"-", "x"}]], " ", 
    RowBox[{"Csc", "[", 
     RowBox[{"\[Pi]", " ", "x"}], "]"}]}], 
   RowBox[{"\[DifferentialD]", "x"}]}]}]], "Output",
 CellChangeTimes->{
  3.9930305075514755`*^9, 3.993030544644039*^9, 3.993030706780134*^9, 
   3.993030826165716*^9, {3.993032020672739*^9, 3.993032073094351*^9}, 
   3.9930322737741337`*^9, 3.9930323888653545`*^9, 3.993032424103344*^9, {
   3.9930325117099075`*^9, 3.9930325171794453`*^9}, 3.993041352488243*^9},
 CellLabel->"Out[64]=",ExpressionUUID->"6e043094-02d7-9b4b-be4b-ee35d21236a6"]
}, Open  ]],

Cell[TextData[{
 "If we use the NIntegrate command without any options, we still get errors \
and Mathematica again suggests that the integrand is probably zero. \
Mathematica will even output a number which is on the order of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["10", 
    RowBox[{"-", "12"}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4351c66d-e857-9347-9869-6bcfbaf05fa0"],
 " (which is basically zero)"
}], "Text",
 CellChangeTimes->{{3.993030862884062*^9, 3.993030879332161*^9}, {
  3.9930312405704937`*^9, 3.9930313224695873`*^9}, {3.9930414117537537`*^9, 
  3.9930414551459713`*^9}},ExpressionUUID->"954a431c-d757-264b-91cd-\
87ea5b4c686c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"NIntegrate", "[", 
  RowBox[{
   FractionBox[
    RowBox[{"Exp", "[", 
     RowBox[{"-", "x"}], "]"}], 
    RowBox[{"Sin", "[", 
     RowBox[{"\[Pi]", " ", "x"}], "]"}]], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "30", ",", "Infinity"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.993030862884062*^9, 3.993030879332161*^9}, {
   3.9930312405704937`*^9, 3.9930312553123207`*^9}, {3.9930318407721043`*^9, 
   3.9930318605884438`*^9}, {3.9930322500760174`*^9, 3.9930322507102222`*^9}, 
   3.9930324103712883`*^9, {3.993032521054323*^9, 3.9930325232560673`*^9}, {
   3.993037563725752*^9, 3.993037564448908*^9}, {3.9930412369130135`*^9, 
   3.9930412397492104`*^9}, {3.993041348858055*^9, 3.9930413493027306`*^9}},
 CellLabel->"In[65]:=",ExpressionUUID->"4943520f-5da9-dd41-bf15-046447336fd9"],

Cell[BoxData[
 TemplateBox[{
  "NIntegrate", "slwcon", 
   "\"Numerical integration converging too slowly; suspect one of the \
following: singularity, value of the integration is 0, highly oscillatory \
integrand or WorkingPrecision too small.\"", 2, 65, 98, 34900017014425649369, 
   "Local"},
  "MessageTemplate",
