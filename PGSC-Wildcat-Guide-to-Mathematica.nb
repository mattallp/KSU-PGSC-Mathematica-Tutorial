   "try", " ", "to", " ", "find", " ", "the", " ", "first", " ", "order", " ",
     "zero", " ", "of", " ", "the", " ", "function", " ", 
    FormBox[
     TemplateBox[<|"boxes" -> FormBox[
         RowBox[{
           StyleBox["f", "TI"], 
           RowBox[{"(", 
             StyleBox["x", "TI"], ")"}], "\[LongEqual]", 
