Cell[CellGroupData[{

Cell["Parametric Plots", "Subsubsection",
 CellChangeTimes->{{3.993731446433675*^9, 
  3.9937314550979433`*^9}},ExpressionUUID->"8c0e2a0e-6e50-418c-a185-\
429ff38a79eb"],

Cell[TextData[{
 StyleBox["ParametricPlot ",
  FontWeight->"Bold"],
 "allows you to plot parametric curves like that of a projectile:"
}], "Text",
 CellChangeTimes->{{3.993729265437292*^9, 3.993729292292077*^9}, {
  3.9937299828495893`*^9, 3.9937300068497963`*^9}, {3.993730250955475*^9, 
  3.9937302620598993`*^9}},ExpressionUUID->"dc492419-a772-4f3b-8bf1-\
af2ce6d2b305"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Projectile", " ", "motion"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Clear", "[", 
     RowBox[{"x", ",", "y"}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"v", " ", "=", "20"}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"launch", " ", "speed"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"g", " ", "=", " ", "9.8"}], ";"}], 
   RowBox[{"(*", 
    RowBox[{"acceleration", " ", "due", " ", "to", " ", "gravity"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Theta]", " ", "=", " ", 
     RowBox[{"30", " ", "Degree"}]}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"launch", " ", "angle"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"kinematic", " ", "equations"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"x", "[", "t_", "]"}], "=", " ", 
     RowBox[{"v", " ", 
      RowBox[{"Cos", "[", "\[Theta]", "]"}], "t"}]}], ";"}], " ", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"y", "[", "t_", "]"}], " ", "=", " ", 
     RowBox[{
      RowBox[{"v", " ", 
       RowBox[{"Sin", "[", "\[Theta]", "]"}], "t"}], " ", "-", " ", 
      RowBox[{
       FractionBox["1", "2"], "g", " ", 
       SuperscriptBox["t", "2"]}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Parametric", " ", "Plot", " ", "of", " ", "the", " ", "trajectory"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{"ParametricPlot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"x", "[", "t", "]"}], ",", 
       RowBox[{"y", "[", "t", "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "4"}], "}"}], ",", 
     RowBox[{"PlotRange", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", "40"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "6"}], "}"}]}], "}"}]}]}], "]"}], 
   "\[IndentingNewLine]"}]}]], "Input",
 CellChangeTimes->{{3.993729265437292*^9, 3.993729292292077*^9}, {
  3.9937299828495893`*^9, 3.993729999899332*^9}, {3.993730237767642*^9, 
  3.99373035119692*^9}, {3.993730405697648*^9, 3.993730464274032*^9}, {
  3.993730521622387*^9, 
  3.9937307540245323`*^9}},ExpressionUUID->"4ed15741-e2a4-417f-955a-\
ea6ded07d100"],

Cell["Again, there is a 3D equivalent to this:", "Text",
 CellChangeTimes->{{3.993732059470624*^9, 3.99373207000252*^9}, {
  3.993732170543562*^9, 
  3.9937321743329763`*^9}},ExpressionUUID->"e4c13b1e-cb9b-44f2-b566-\
18d2fe0e222e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Motion", " ", "of", " ", "a", " ", "charged", " ", "particle", " ", 
    "through", " ", "a", " ", "uniform", " ", "magnetic", " ", "field"}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Clear", "[", 
     RowBox[{"x", ",", "y", ",", "z"}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"v", " ", "=", "0.5"}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"initial", " ", "speed"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"R", "=", "1"}], ";"}], 
   RowBox[{"(*", 
    RowBox[{"Radius", " ", "of", " ", "orbit"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Omega]", " ", "=", "5"}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"angular", " ", "frequency"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"kinematic", " ", "equations"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"x", "[", "t_", "]"}], "=", " ", 
     RowBox[{"R", " ", 
      RowBox[{"Cos", "[", 
       RowBox[{"\[Omega]", " ", "t"}], "]"}]}]}], ";"}], " ", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"y", "[", "t_", "]"}], " ", "=", " ", 
     RowBox[{"R", " ", 
      RowBox[{"Sin", "[", 
       RowBox[{"\[Omega]", " ", "t"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"z", "[", "t_", "]"}], "=", 
     RowBox[{"v", " ", "t"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Parametric", " ", "Plot", " ", "of", " ", "the", " ", "trajectory"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{"ParametricPlot3D", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"x", "[", "t", "]"}], ",", 
       RowBox[{"y", "[", "t", "]"}], ",", 
       RowBox[{"z", "[", "t", "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "4"}], "}"}]}], "]"}], 
   "\[IndentingNewLine]"}]}]], "Input",
 CellChangeTimes->{{3.993732059470624*^9, 3.99373207000252*^9}, {
  3.993732170543562*^9, 3.993732447109767*^9}},
 CellLabel->
  "In[308]:=",ExpressionUUID->"7b402cdd-3519-4a3a-be2f-3a6848045315"]
}, Closed]],

Cell[CellGroupData[{

Cell["Complex Functions", "Subsubsection",
 CellChangeTimes->{{3.9937324680912037`*^9, 
  3.993732478255817*^9}},ExpressionUUID->"abc7029f-d59f-43cc-bbde-\
9f804731c0f5"],

Cell[TextData[{
 "For complex functions, you can use ",
 StyleBox["Re ",
  FontWeight->"Bold"],
 "and ",
 StyleBox["Im ",
  FontWeight->"Bold"],
 "to extract the imaginry and real components of complex numbers to plot \
separately:"
}], "Text",
 CellChangeTimes->{{3.9937324680912037`*^9, 3.9937324885863657`*^9}, {
  3.993732553155079*^9, 
  3.9937326339476357`*^9}},ExpressionUUID->"4d82f9d2-10a8-4baf-ad86-\
a9a87ebf8ed1"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Re", "[", 
       RowBox[{"E", "^", 
        RowBox[{"(", 
         RowBox[{"I", " ", "\[Theta]"}], ")"}]}], "]"}], ",", 
      RowBox[{"Im", "[", 
       RowBox[{"E", "^", 
        RowBox[{"(", 
         RowBox[{"I", " ", "\[Theta]"}], ")"}]}], "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"\[Theta]", ",", 
      RowBox[{"-", "\[Pi]"}], ",", "\[Pi]"}], "}"}], ",", 
    RowBox[{"PlotLegends", "->", "\"\<Expressions\>\""}]}], "]"}], "  ", 
  RowBox[{"(*", 
   RowBox[{"ends", " ", "up", " ", "plotting", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{"cos", "\[Theta]"}], TraditionalForm], "errors" -> {}, 
      "input" -> "\\cos \\theta", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " ", "and", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{"sin", "\[Theta]"}], TraditionalForm], "errors" -> {}, 
      "input" -> "\\sin \\theta", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"]}], 
   "*)"}]}], "\[IndentingNewLine]", "Compl"}], "Input",
 CellChangeTimes->{{3.9937324680912037`*^9, 3.9937324885863657`*^9}, {
  3.993732553155079*^9, 3.993732589287026*^9}, {3.9937326364278316`*^9, 
  3.9937329331979647`*^9}, {3.993733039383457*^9, 
  3.993733051763197*^9}},ExpressionUUID->"f263dca9-874a-47bd-8130-\
cb9a6b7bbfeb"],

Cell[TextData[{
 "However, this still doesn\[CloseCurlyQuote]t really help us visualize \
mapping a complex number to another complex number. ",
 StyleBox["ComplexPlot ",
  FontWeight->"Bold"],
 "and ",
 StyleBox["ComplexPlot3D",
  FontWeight->"Bold"],
 " utilize color to represent the Argument of a complex number. This can help \
better visualize complex numbers."
}], "Text",
 CellChangeTimes->{{3.993732942491824*^9, 3.993732975926415*^9}, {
   3.993733012986622*^9, 3.993733036814638*^9}, {3.9937331377232943`*^9, 
   3.9937331952616463`*^9}, {3.9937333913800983`*^9, 3.993733441769846*^9}, 
   3.993733505638434*^9},ExpressionUUID->"5148cc0a-6cc2-4a00-a5b0-\
a19c7b521783"],

Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{"w", ",", "z"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"w", "[", "z_", "]"}], ":=", " ", 
   FractionBox[
    RowBox[{"Exp", "[", 
     RowBox[{"1", "/", "z"}], "]"}], 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"z", "+", "2"}], ")"}], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"z", "+", "1"}], ")"}], "2"]}]]}], " ", 
  RowBox[{"(*", 
   RowBox[{"a", " ", "complex", " ", "function"}], "*)"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"ComplexPlot", "[", 
  RowBox[{
   RowBox[{"w", "[", "z", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"z", ",", 
     RowBox[{
      RowBox[{"-", "3"}], "-", 
      RowBox[{"3", "I"}]}], ",", 
     RowBox[{"3", "+", 
      RowBox[{"3", "I"}]}]}], "}"}], ",", 
   RowBox[{"PlotLegends", "->", "Automatic"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"ComplexPlot3D", "[", 
  RowBox[{
   RowBox[{"w", "[", "z", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"z", ",", 
     RowBox[{
      RowBox[{"-", "3"}], "-", 
      RowBox[{"3", "I"}]}], ",", 
     RowBox[{"3", "+", 
      RowBox[{"3", "I"}]}]}], "}"}], ",", 
   RowBox[{"PlotLegends", "->", "Automatic"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.993732942491824*^9, 3.993732975926415*^9}, {
  3.993733012986622*^9, 3.993733036814638*^9}, {3.9937331377232943`*^9, 
  3.993733385151246*^9}, {3.9937334504910383`*^9, 3.993733485587448*^9}},
 CellLabel->
  "In[367]:=",ExpressionUUID->"5a3f451f-0678-4c9e-8578-afe6e7621bf5"]
}, Closed]]
}, Closed]],

Cell[CellGroupData[{

Cell["Graphic Primitives and Combining Graphics", "Subsection",
 CellChangeTimes->{{3.99373357370685*^9, 3.993733574775091*^9}, {
   3.993733617975566*^9, 3.993733622501048*^9}, 3.993733945303678*^9, {
   3.9938164513397465`*^9, 3.9938164586554756`*^9}, {3.9938165811405125`*^9, 
   3.9938165830509377`*^9}},ExpressionUUID->"6f8fa4f0-ff5d-42a9-bf15-\
e0c506db26d0"],

Cell[TextData[{
 "Mathematica has a wide variety of graphics objects available for use.  \
Strictly speaking, the plots we have already done are graphics objects. In \
this section, however, we are going to go over graphics primitives. The \
implementation of these graphics can get pretty cumbersome and complicated, \
so we will only go through a basic example using 2D graphics, just know that \
3D versions also exist. Don\[CloseCurlyQuote]t hesitate to check the \
documentation if you are unsure how something works. \n\nGraphics primitives \
are commands that you can call to create different graphics objects. You can \
store these objects in variables, but in order to tell Mathematica how to \
actually display them you need to use the ",
 StyleBox["Graphics ",
  FontWeight->"Bold"],
 "(or ",
 StyleBox["Graphics3D) ",
  FontWeight->"Bold"],
 "command. "
}], "Text",
 CellChangeTimes->{{3.99373357370685*^9, 3.993733574775091*^9}, {
   3.993733617975566*^9, 3.993733622501048*^9}, {3.9937339459034348`*^9, 
   3.993734058307164*^9}, {3.993734141203682*^9, 3.993734173912402*^9}, {
   3.9937342148843517`*^9, 3.993734218520664*^9}, {3.993734325145562*^9, 
   3.993734401389907*^9}, 3.993734646761469*^9, {3.993814133494442*^9, 
   3.993814224088421*^9}, {3.993814263833933*^9, 3.993814271543442*^9}, {
   3.9938143113956394`*^9, 3.993814329248966*^9}, {3.9938144532956486`*^9, 
   3.993814493355715*^9}, {3.9938163437913837`*^9, 3.993816360664755*^9}, {
   3.993820546447605*^9, 
   3.993820557194771*^9}},ExpressionUUID->"d17fd0a3-9530-4a96-aa10-\
dd001859a728"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"disk1", " ", "=", " ", 
    RowBox[{"Disk", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", "0"}], "}"}], ",", "0.25"}], "]"}]}], " ", ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "this", " ", "will", " ", "create", " ", "a", " ", "disk", " ", "of", " ", 
    "radius", " ", "0.25", " ", "at", " ", "the", " ", "the", " ", 
    "coordinate", " ", 
    RowBox[{"(", 
     RowBox[{"1", ",", "0"}], ")"}]}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Graphics", "[", "disk1", "]"}], "  "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"this", " ", "will", " ", "display", " ", "the", " ", "disk"}], 
   "*)"}]}]}], "Input",
 CellChangeTimes->{{3.99373357370685*^9, 3.993733574775091*^9}, {
   3.993733617975566*^9, 3.993733622501048*^9}, {3.9937339459034348`*^9, 
   3.993734058307164*^9}, {3.993734141203682*^9, 3.993734173912402*^9}, {
   3.9937342148843517`*^9, 3.993734218520664*^9}, {3.993734325145562*^9, 
   3.993734401389907*^9}, 3.993734646761469*^9, {3.993814133494442*^9, 
   3.9938142573350544`*^9}, {3.99381449700461*^9, 3.9938146156109924`*^9}, {
   3.993814652275528*^9, 3.9938146713202724`*^9}, {3.9938205601877975`*^9, 
   3.993820563948084*^9}},ExpressionUUID->"7fb6cf06-999a-c34f-8dac-\
46c34fa6df46"],

Cell["\<\
Since this disk is on it\[CloseCurlyQuote]s own, you can\[CloseCurlyQuote]t \
really tell that it is a disk of radius 0.25 at (1,0). Fortunately, we can \
include multiple objects in the Graphics command:\
\>", "Text",
 CellChangeTimes->{{3.9938146834313145`*^9, 3.993814701695423*^9}, {
  3.9938147381449337`*^9, 
  3.9938148216502876`*^9}},ExpressionUUID->"4e2668e1-4348-164d-8a2a-\
4178ba214105"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"disk2", " ", "=", "  ", 
    RowBox[{"Disk", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "1"}], ",", "0"}], "}"}], ",", "0.5"}], "]"}]}], ";"}], 
  " ", 
  RowBox[{"(*", 
   RowBox[{"create", " ", "a", " ", "different", " ", "disk", " ", "at", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], ",", "0"}], ")"}], " ", "with", " ", "radius", " ", 
    "0.5"}], "*)"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Graphics", "[", 
   RowBox[{"{", 
    RowBox[{"disk1", ",", "disk2"}], "}"}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{"display", " ", "the", " ", "two", " ", "disks"}], 
   "*)"}]}]}], "Input",
 CellChangeTimes->{{3.9938146834313145`*^9, 3.993814701695423*^9}, {
  3.9938147381449337`*^9, 3.9938148735465965`*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"9f218417-9a4c-6d4b-9e62-8ffb4a85a1f1"],

Cell[TextData[{
 "In order to change the formatting and style of the graphics object, we \
actually need to create a list and include all of our options we want to \
apply before listing our graphics object. The ",
 StyleBox["Directive",
  FontWeight->"Bold"],
 " command one way to include all of the format changed we want into a single \
command:"
}], "Text",
 CellChangeTimes->{{3.9938148905925045`*^9, 3.9938149477286777`*^9}, {
  3.993815057593485*^9, 3.993815073540289*^9}, {3.9938158383085823`*^9, 
  3.9938158778160877`*^9}},ExpressionUUID->"ffd0cb59-a1d7-fe41-9727-\
0bc5c8f7c5b8"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"arrow1", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Directive", "[", 
       RowBox[{"Red", ",", "Thick"}], "]"}], ",", 
      RowBox[{"Arrow", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "1"}], ",", "0"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "0.5"}], ",", "0"}], "}"}]}], "}"}], "]"}]}], " ", 
     "}"}]}], ";"}], "  ", 
  RowBox[{"(*", 
   RowBox[{
   "Create", " ", "a", " ", "red", " ", "centripetal", " ", "force", " ", 
    "vector"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"text1", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Directive", "[", 
       RowBox[{"Red", ",", "Thick"}], "]"}], ",", " ", 
      RowBox[{"Text", "[", 
       RowBox[{"\"\<\!\(\*TemplateBox[<|\"boxes\" -> FormBox[
SubscriptBox[
StyleBox[\"F\", \"TI\"], 
StyleBox[\"c\", \"TI\"]], TraditionalForm], \"errors\" -> {}, \"input\" -> \
\"F_c\", \"state\" -> \"Boxes\"|>,\"TeXAssistantTemplate\"]\)\>\"", ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "0.75"}], ",", "0.1"}], "}"}]}], "]"}]}], "}"}]}], 
   ";"}], "  ", 
  RowBox[{"(*", 
   RowBox[{
   "create", " ", "text", " ", "to", " ", "label", " ", "the", " ", "force", " ",
     "vector"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"circle", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Directive", "[", 
       RowBox[{"Blue", ",", "Dashed"}], "]"}], ",", 
      RowBox[{"Circle", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "0.25"}], ",", "0"}], "}"}], ",", "0.75"}], "]"}]}], 
     "}"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "create", " ", "a", " ", "blue", " ", "dashed", " ", "circle", " ", "to", " ",
     "trace", " ", "out", " ", "the", " ", "orbit"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"object", "=", " ", 
    RowBox[{"{", 
     RowBox[{"Black", ",", 
      RowBox[{"Disk", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "1"}], ",", "0"}], "}"}], ",", "0.1"}], "]"}]}], 
     "}"}]}], " ", ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "create", " ", "a", " ", "disk", " ", "representing", " ", "an", " ", 
    "object", " ", "in", " ", "uniform", " ", "circular", " ", "motion"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"arrow2", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{"Green", ",", 
      RowBox[{"Arrow", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "1"}], ",", "0"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "1"}], ",", 
           RowBox[{"-", "0.3"}]}], "}"}]}], "}"}], "]"}]}], "}"}]}], ";"}], 
  " ", 
  RowBox[{"(*", 
   RowBox[{
   "vector", " ", "representing", " ", "the", " ", "tangential", " ", 
    "velocity"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"text2", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Directive", "[", 
       RowBox[{"Green", ",", "Thick"}], "]"}], ",", " ", 
      RowBox[{"Text", "[", 
       RowBox[{"\"\<\!\(\*TemplateBox[<|\"boxes\" -> FormBox[
SubscriptBox[
StyleBox[\"v\", \"TI\"], 
StyleBox[\"t\", \"TI\"]], TraditionalForm], \"errors\" -> {}, \"input\" -> \
\"v_t\", \"state\" -> \"Boxes\"|>,\"TeXAssistantTemplate\"]\)\>\"", ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "1.2"}], ",", "0"}], "}"}]}], "]"}]}], "}"}]}], ";"}], 
  " ", 
  RowBox[{"(*", 
   RowBox[{
   "label", " ", "for", " ", "the", " ", "tangential", " ", "velocity"}], 
   "*)"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Graphics", "[", 
   RowBox[{"{", 
    RowBox[{
    "circle", ",", "arrow1", ",", "text1", ",", "arrow2", ",", "text2", ",", 
     "object"}], "}"}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "The", " ", "last", " ", "object", " ", "in", " ", "a", " ", "list", " ", 
    "will", " ", "be", " ", "drawn", " ", "on", " ", "top", " ", "of", " ", 
    "the", " ", "existing", " ", "objects"}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.9938148905925045`*^9, 3.9938149477286777`*^9}, {
   3.993815057593485*^9, 3.9938151132158813`*^9}, {3.99381518285244*^9, 
   3.9938154043818626`*^9}, {3.993815454810564*^9, 3.9938155468023205`*^9}, {
   3.993815593911314*^9, 3.9938156354854813`*^9}, {3.9938156679058056`*^9, 
   3.993815699936079*^9}, {3.9938157383225574`*^9, 3.99381583419174*^9}, {
   3.9938158902318325`*^9, 3.993815994969122*^9}, {3.993816064190094*^9, 
   3.9938161540902596`*^9}, {3.9938162019733753`*^9, 3.993816228288265*^9}, 
   3.9938163076091022`*^9, {3.993816373651125*^9, 3.993816392778143*^9}, {
   3.9938165439773216`*^9, 3.993816561995905*^9}},
 CellLabel->"In[71]:=",ExpressionUUID->"834459f2-fb9f-d44b-9ec4-38dafb60bb63"],

Cell["\<\
As another note, a lot of graphics primitives can also represent Mathematical \
objects such as a curve, region, or contour of integration:\
\>", "Text",
 CellChangeTimes->{{3.9938205895159054`*^9, 3.9938206067801304`*^9}, {
  3.9938206390108376`*^9, 3.993820663681959*^9}, {3.9938207891900826`*^9, 
  3.9938208181555595`*^9}},ExpressionUUID->"a0d6132b-e834-7147-9a9d-\
1144c00840e7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"unitCircle", "=", " ", 
    RowBox[{"Circle", "[", "]"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ContourIntegrate", "[", 
   RowBox[{
    RowBox[{"1", "/", "z"}], ",", 
    RowBox[{"z", " ", "\[Element]", " ", "unitCircle"}]}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "preform", " ", "a", " ", "complex", " ", "contour", " ", "integral", " ", 
    "over", " ", "the", " ", "unit", " ", "circle", " ", "in", " ", "the", " ",
     "complex", " ", "plane", " ", "of", " ", "the", " ", "function", " ", 
    RowBox[{"1", "/", "z"}]}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.9938205895159054`*^9, 3.9938206067801304`*^9}, {
  3.9938206390108376`*^9, 3.993820663681959*^9}, {3.9938207891900826`*^9, 
  3.9938208722698193`*^9}, {3.993820957164295*^9, 
  3.993820994778204*^9}},ExpressionUUID->"fb8f123f-5759-ae4b-8a03-\
932332d9566a"],

Cell[TextData[{
 "Combining graphics primitives together can make for some good visuals, but \
what if you want to combine a graphics primitive to something like a plot? \
Fortunately, you can use the ",
 StyleBox["Show",
  FontWeight->"Bold"],
 " command to do just that. The S",
 StyleBox["how",
  FontWeight->"Bold"],
 " command will simply put all of our graphics objects on a single canvas. \
Note, however, if you choose to use multiple plots in ",
 StyleBox["Show, ",
  FontWeight->"Bold"],
 "only the formatting options in the first graphics object will take \
priority, though you can change some of these in the ",
 StyleBox["Show",
  FontWeight->"Bold"],
 " command. "
}], "Text",
 CellChangeTimes->{{3.993816610191387*^9, 3.9938166748692913`*^9}, {
  3.9938167473837376`*^9, 3.9938167818434505`*^9}, {3.9938168182489395`*^9, 
  3.993816826397869*^9}, {3.9938202694097786`*^9, 3.9938204410289097`*^9}, {
  3.9938212802711678`*^9, 
  3.993821292513319*^9}},ExpressionUUID->"c11ea4ba-820b-c846-b7d1-\
d33d71c13176"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"parabolaPlot", " ", "=", " ", 
    RowBox[{"Plot", "[", 
     RowBox[{
      SuperscriptBox["x", "2"], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", 
        RowBox[{"-", ".8"}], ",", ".8"}], "}"}], ",", " ", 
      RowBox[{"Background", "->", "White"}], ",", " ", 
      RowBox[{
      "PlotLabel", 
       "->", "\"\<Mean Value Theorem Example, \!\(\*TemplateBox[<|\"boxes\" \
-> FormBox[
RowBox[{
StyleBox[\"f\", \"TI\"], 
RowBox[{\"(\", 
StyleBox[\"x\", \"TI\"], \")\"}], \"\[LongEqual]\", 
SuperscriptBox[
StyleBox[\"x\", \"TI\"], \"2\"]}], TraditionalForm], \"errors\" -> {}, \
\"input\" -> \"f(x) =x^2\", \"state\" -> \
\"Boxes\"|>,\"TeXAssistantTemplate\"]\)\>\""}], ",", " ", 
      RowBox[{"LabelStyle", "->", 
       RowBox[{"Directive", "[", 
        RowBox[{"Bold", ",", " ", "Black"}], "]"}]}], ",", 
      RowBox[{"FrameStyle", "->", 
       RowBox[{"Directive", "[", 
        RowBox[{"Black", ",", " ", "Bold"}], "]"}]}], ",", " ", 
      RowBox[{"Frame", "->", "True"}], ",", 
      RowBox[{"AxesStyle", "->", 
       RowBox[{"Directive", "[", 
        RowBox[{"Black", ",", " ", "Bold"}], "]"}]}]}], "]"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"plot", " ", "of", " ", "a", " ", "prabola"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"points", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{"Red", ",", 
      RowBox[{"Point", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0.6", ",", 
           SuperscriptBox["0.6", "2"]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "0.6"}], ",", 
           SuperscriptBox["0.6", "2"]}], "}"}]}], "}"}], "]"}]}], "}"}]}], 
   ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Red", " ", "endpoints", " ", "A", " ", "and", " ", "B"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"greenPoint", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{"Green", ",", 
      RowBox[{"Point", "[", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0"}], "}"}], "]"}]}], "}"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"green", " ", "zero", " ", "point", " ", "C"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"text1", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{"Red", ",", " ", 
      RowBox[{"Text", "[", 
       RowBox[{"\"\<A\>\"", ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "0.55"}], ",", 
          RowBox[{
           SuperscriptBox["0.6", "2"], "+", ".05"}]}], "}"}]}], "]"}]}], 
     "}"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"text", " ", "for", " ", "point", " ", "A"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"text2", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{"Red", ",", " ", 
      RowBox[{"Text", "[", 
       RowBox[{"\"\<B\>\"", ",", 
        RowBox[{"{", 
         RowBox[{"0.55", ",", 
          RowBox[{
           SuperscriptBox["0.6", "2"], "+", ".05"}]}], "}"}]}], "]"}]}], 
     "}"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"text", " ", "for", " ", "point", " ", "B"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ABslope", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{"Red", ",", " ", 
      RowBox[{"Line", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0.6", ",", 
           SuperscriptBox["0.6", "2"]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "0.6"}], ",", 
           SuperscriptBox["0.6", "2"]}], "}"}]}], "}"}], "]"}]}], "}"}]}], 
   ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "line", " ", "representing", " ", "slope", " ", "from", " ", "A", " ", 
    "to", " ", "B"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"zeroSlope", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{"Green", ",", " ", "Thick", ",", 
      RowBox[{"Line", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "0.2"}], ",", "0"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"0.2", ",", "0"}], "}"}]}], "}"}], "]"}]}], "}"}]}], ";"}], 
  " ", 
  RowBox[{"(*", 
   RowBox[{
   "Line", " ", "representing", " ", "derivative", " ", "at", " ", "point", " ",
     "C"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"text3", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{"Green", ",", 
      RowBox[{"Text", "[", 
       RowBox[{"\"\<C\>\"", ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0.05"}], "}"}]}], "]"}]}], "}"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"text", " ", "for", " ", "point", " ", "C"}], "*)"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"primitives", " ", "=", " ", 
    RowBox[{"Graphics", "[", 
     RowBox[{"{", 
      RowBox[{
      "points", ",", " ", "greenPoint", ",", "text1", ",", "text2", ",", 
       "ABslope", ",", "zeroSlope", ",", "text3"}], "}"}], "]"}]}], ";"}], 
  " ", 
  RowBox[{"(*", 
   RowBox[{
   "store", " ", "the", " ", "graphics", " ", "primitives", " ", "on", " ", 
    "a", " ", "single", " ", "canvas"}], "*)"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Show", "[", 
   RowBox[{"parabolaPlot", ",", "primitives"}], "]"}], 
  RowBox[{"(*", 
   RowBox[{
   "Use", " ", "Show", " ", "command", " ", "to", " ", "combine", " ", 
    "graphics"}], "*)"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.993816610191387*^9, 3.9938166748692913`*^9}, {
  3.9938167473837376`*^9, 3.9938167818434505`*^9}, {3.9938168182489395`*^9, 
  3.993816826397869*^9}, {3.9938202694097786`*^9, 3.9938204111240253`*^9}, {
  3.9938204421495876`*^9, 3.9938204839699154`*^9}, {3.993820514524351*^9, 
  3.993820515453146*^9}, {3.993821007988117*^9, 3.993821039634964*^9}, {
  3.993821138409107*^9, 3.9938212586453915`*^9}, {3.9938213067458973`*^9, 
  3.993821398670187*^9}, {3.993821444428383*^9, 3.9938214444931927`*^9}, {
  3.9938215410871944`*^9, 3.9938216840430927`*^9}, {3.9938217402583847`*^9, 
  3.9938221840521545`*^9}, {3.993822215874283*^9, 3.9938222773108616`*^9}},
 CellLabel->
  "In[313]:=",ExpressionUUID->"e878417a-f467-0143-8e83-d8e552b872b8"],

Cell[CellGroupData[{

Cell["Exercise", "Subsubsection",
 CellChangeTimes->{{3.993822313900215*^9, 
  3.9938223222690544`*^9}},ExpressionUUID->"974c9ef8-9c4c-cf4e-80a2-\
00230818daca"],

Cell["\<\
In the input cell below, I have defined the function V, which represents a 2D \
electric potential for two point charges. Create a plot which shows both the \
electric field lines and the equipotential contour lines. Make sure your plot \
is appropriately labeled. \
\>", "Text",
 CellChangeTimes->{{3.993822313900215*^9, 3.9938223256398544`*^9}, {
  3.9938223656938744`*^9, 3.9938224907827816`*^9}, {3.993822926715027*^9, 
  3.9938229354739113`*^9}, {3.993823010357506*^9, 
  3.993823025036495*^9}},ExpressionUUID->"ff50b4f7-a75d-f647-a02d-\
6a4435fe8f45"],

Cell[BoxData[{
 RowBox[{"Clear", "[", "\"\<`*\>\"", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"V", "[", 
    RowBox[{"x_", ",", "y_"}], "]"}], ":=", " ", 
   RowBox[{
    FractionBox["1", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"x", "-", "1"}], ")"}], "^", "2"}], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"y", "-", "1"}], ")"}], "^", "2"}]}], ")"}], 
      RowBox[{"3", "/", "2"}]]], "-", " ", 
    FractionBox["1", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"x", "+", "1"}], ")"}], "^", "2"}], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"y", "+", "1"}], ")"}], "^", "2"}]}], ")"}], 
      RowBox[{"3", "/", "2"}]]]}]}], 
  RowBox[{"(*", 
   RowBox[{"2", "D", " ", "potential"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Your", " ", "code", " ", "here"}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.993822313900215*^9, 3.993822317739376*^9}, {
  3.993822494119087*^9, 3.993822614521206*^9}, {3.993822834566801*^9, 
  3.993822837888489*^9}, {3.9938231089460583`*^9, 3.993823179220278*^9}},
 CellLabel->
  "In[338]:=",ExpressionUUID->"d3ccb64f-5b74-3b42-a563-b66a33e36eb7"]
}, Closed]],

Cell[CellGroupData[{

Cell["Solution", "Subsubsection",
 CellChangeTimes->{{3.9938228060992966`*^9, 
  3.99382280730023*^9}},ExpressionUUID->"d49767e4-430a-6041-b75a-\
fae8393cc636"],

Cell["\<\
We can use the ContourPlot command to get the equipotential lines, since we \
only want the equipotential lines, we are going to turn the shading off.  \
Since I want the field lines to go over the equipotential lines, I am going \
to add all my formatting options to this plot\
\>", "Text",
 CellChangeTimes->{{3.9938228468312187`*^9, 3.993822856306082*^9}, {
  3.9938232144026775`*^9, 3.9938232306713047`*^9}, {3.993823330254677*^9, 
  3.9938233859366646`*^9}},ExpressionUUID->"752dbeb5-86af-3f4f-96ae-\
17b28957fdcd"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"V", "[", 
    RowBox[{"x_", ",", "y_"}], "]"}], ":=", " ", 
   RowBox[{
    FractionBox["1", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"x", "-", "1"}], ")"}], "^", "2"}], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"y", "-", "1"}], ")"}], "^", "2"}]}], ")"}], 
      RowBox[{"3", "/", "2"}]]], "-", " ", 
    FractionBox["1", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"x", "+", "1"}], ")"}], "^", "2"}], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"y", "+", "1"}], ")"}], "^", "2"}]}], ")"}], 
      RowBox[{"3", "/", "2"}]]]}]}], 
  RowBox[{"(*", 
   RowBox[{"2", "D", " ", "potential"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"equipotentialcontours", " ", "=", " ", 
  RowBox[{"ContourPlot", "[", 
   RowBox[{
    RowBox[{"V", "[", 
     RowBox[{"x", ",", "y"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "3"}], ",", "3"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"y", ",", 
      RowBox[{"-", "3"}], ",", "3"}], "}"}], ",", 
    RowBox[{"ContourStyle", "->", "Black"}], ",", " ", 
    RowBox[{"ContourShading", "->", "None"}], ",", " ", 
    RowBox[{"Background", "->", "White"}], ",", " ", 
    RowBox[{"AxesStyle", "->", 
     RowBox[{"Directive", "[", 
      RowBox[{"Black", ",", "Bold"}], "]"}]}], ",", 
    RowBox[{"LabelStyle", "->", 
     RowBox[{"Directive", "[", 
      RowBox[{"Black", ",", "Bold"}], "]"}]}], ",", 
    RowBox[{
    "PlotLabel", 
     "->", "\"\<Electric Field Generated by \!\(\*TemplateBox[<|\"boxes\" -> \
FormBox[
RowBox[{
StyleBox[\"V\", \"TI\"], \"(\", 
RowBox[{
StyleBox[\"x\", \"TI\"], \",\", 
StyleBox[\"y\", \"TI\"]}], \")\"}], TraditionalForm], \"errors\" -> {}, \
\"input\" -> \"V(x,y)\", \"state\" -> \"Boxes\"|>,\"TeXAssistantTemplate\"]\)\
\>\""}], ",", " ", 
    RowBox[{"FrameStyle", "->", 
     RowBox[{"Directive", "[", 
      RowBox[{"Black", ",", "Bold"}], "]"}]}], ",", " ", 
    RowBox[{"FrameLabel", "->", 
     RowBox[{"{", 
      RowBox[{"\"\<x\>\"", ",", "\"\<y\>\""}], "}"}]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{" ", 
  RowBox[{"(*", 
   RowBox[{
   "Contour", " ", "plot", " ", "for", " ", "equipotential", " ", "lines"}], 
   "*)"}]}]}], "Input",
 CellChangeTimes->{{3.9938228060992966`*^9, 3.993822894128937*^9}, {
  3.993822992424652*^9, 3.993823036439598*^9}, {3.9938230909556103`*^9, 
  3.9938230987507477`*^9}, {3.993823163094675*^9, 3.9938232860412846`*^9}, {
  3.993823357887556*^9, 3.993823527598009*^9}},
 CellLabel->
  "In[355]:=",ExpressionUUID->"98449b5c-dd67-ea49-b985-b41798fd6d7f"],

Cell["\<\
For the electric field lines, I am going to use StreamPlot, though VectorPlot \
would also work. I will omit any formatting options as I have already took \
care of them in my contour plot:\
\>", "Text",
 CellChangeTimes->{{3.993823290418627*^9, 3.993823321157936*^9}, {
   3.993823550195719*^9, 3.993823582044388*^9}, 
   3.993823720254835*^9},ExpressionUUID->"06bc6499-6915-d242-9e6b-\
9834f8f03252"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Efield", "[", 
     RowBox[{"x_", ",", "y_"}], "]"}], "=", " ", 
    RowBox[{"-", 
     RowBox[{"Grad", "[", 
      RowBox[{
       RowBox[{"V", "[", 
        RowBox[{"x", ",", "y"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "y"}], "}"}]}], "]"}]}]}], ";"}], 
  RowBox[{"(*", " ", 
   RowBox[{"calculate", " ", "the", " ", "Efield", " ", "by", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{"-", "\[Del]", 
          StyleBox["V", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
      "-\\nabla V", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"linesPlot", " ", "=", " ", 
  RowBox[{"StreamPlot", "[", 
   RowBox[{
    RowBox[{"Efield", "[", 
     RowBox[{"x", ",", "y"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "3"}], ",", "3"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"y", ",", 
      RowBox[{"-", "3"}], ",", "3"}], "}"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.993823290418627*^9, 3.993823321157936*^9}, {
  3.993823550195719*^9, 
  3.993823717644108*^9}},ExpressionUUID->"ccbff425-9a3f-6941-964b-\
5aae34aba11f"],

Cell["I can then use the Show command to display the two plots:", "Text",
 CellChangeTimes->{{3.9938237239062023`*^9, 
  3.9938237350954914`*^9}},ExpressionUUID->"534484b3-55a2-c04a-8b4e-\
a267be745433"],

Cell[BoxData[
 RowBox[{"Show", "[", 
  RowBox[{"equipotentialcontours", ",", "linesPlot"}], "]"}]], "Input",
 CellChangeTimes->{{3.9938237239062023`*^9, 3.993823745474472*^9}},
 CellLabel->
  "In[367]:=",ExpressionUUID->"6cef4687-ee7f-ac4e-aefc-238112f12303"]
}, Closed]]
}, Closed]],

