   RowBox[{"{", 
    RowBox[{"1.`", ",", "1.`", ",", "2.`"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "1.`"}], ",", "5.`", ",", "2.`"}], "}"}], ",", 
   RowBox[{"{", 
