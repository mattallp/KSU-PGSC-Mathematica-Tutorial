  3.99372515483041*^9, 3.993725183078149*^9}},
 CellLabel->"In[3]:=",ExpressionUUID->"aced0550-3e5d-4d29-ab6b-90d0b674dd31"]
}, Closed]],

Cell[CellGroupData[{

Cell["Nuances of Plot Commands", "Subsubsection",
 CellChangeTimes->{{3.993559567912127*^9, 3.993559577068104*^9}, 
   3.993559632306389*^9, {3.993559792838234*^9, 
   3.993559810102415*^9}},ExpressionUUID->"fab1342d-2192-45e4-a4d9-\
e60bf0c9c465"],

Cell[TextData[{
 "The ",
 StyleBox["Plot ",
  FontWeight->"Bold"],
 "and other plotting commands use numerical calculations to make plots. \
Therefore, just like with other numerical commands, there are some options \
you can use to improve the accuracy and quality of your plots. The way that \
Mathematica plots is by sampling values in the domain specified and then uses \
recursive subdivisions to fill in the gaps between the sampling points. \
Typically, Mathematica does a good job of choosing the number of sampling \
points and recursive subdivisions automatically, but occasionally you may \
need to adjust these values for more complicated functions.  \n\nAs an \
example we are going to take a look at the truncated Fourier series for a \
Dirac delta function, here is code to initialize such a function:"
}], "Text",
 CellChangeTimes->{{3.9935596373408623`*^9, 3.9935597058095427`*^9}, {
   3.993559781982213*^9, 3.993559901187421*^9}, {3.993560704771345*^9, 
   3.993560715023013*^9}, {3.9935608562324963`*^9, 3.9935608567525387`*^9}, {
   3.9935609029649363`*^9, 3.9935609994140453`*^9}, {3.993561252224483*^9, 
   3.993561299981089*^9}, {3.993561392997718*^9, 3.993561426268659*^9}, 
   3.993561701812908*^9, {3.993562217342662*^9, 
   3.993562227413632*^9}},ExpressionUUID->"e0cf3238-782d-458d-9b43-\
f822e8fb6a90"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "\"\<`*\>\"", "]"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"f", "[", "x_", "]"}], "=", 
    RowBox[{"FourierSeries", "[", 
     RowBox[{
      RowBox[{"DiracDelta", "[", "x", "]"}], ",", "x", ",", "50"}], "]"}]}], 
   ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "generated", " ", "the", " ", "first", " ", "50", " ", "terms", " ", "of", 
    " ", "a", " ", "Fourier", " ", "series", " ", "for", " ", "a", " ", 
    "dirac", " ", "delta", " ", "function", " ", 
    RowBox[{"(", 
     RowBox[{
     "this", " ", "may", " ", "take", " ", "a", " ", "while", " ", "to", " ", 
      "execute"}], ")"}]}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.993559567912127*^9, 3.993559577068104*^9}, {
   3.993559632965892*^9, 3.9935596329664297`*^9}, {3.993559904099448*^9, 
   3.993559911723508*^9}, {3.993560151850478*^9, 3.993560163762302*^9}, {
   3.9935602057029552`*^9, 3.993560488050445*^9}, {3.993560525250621*^9, 
   3.9935605518976927`*^9}, {3.993560668491057*^9, 3.993560883357102*^9}, {
   3.993561005494339*^9, 3.993561070499343*^9}, {3.9935611115276127`*^9, 
   3.9935611959082193`*^9}, {3.9935612412406893`*^9, 3.9935612849412746`*^9}, 
   3.993561403263315*^9},ExpressionUUID->"bafca29a-7a70-4204-86c4-\
369951ef7224"],

Cell[TextData[{
 "This function is highly oscillatory, so if I tell Mathematica not to use \
any recursive subdivisions using ",
 StyleBox["MaxRecursion -> 0",
  FontWeight->"Bold"],
 ", we get a rather jagged plot:"
}], "Text",
 CellChangeTimes->{{3.9935614373183193`*^9, 3.9935614780906143`*^9}, {
   3.993561714728661*^9, 3.9935617247086906`*^9}, 
   3.9935622106940393`*^9},ExpressionUUID->"353f87dd-526a-421b-b292-\
b8575da878a3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"f", "[", "x", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
    RowBox[{"PlotRange", "->", "All"}], ",", " ", 
    RowBox[{"MaxRecursion", "->", "0"}]}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "a", " ", "plot", " ", "which", " ", "uses", " ", "zero", " ", "recursive",
     " ", "bisections"}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.993559567912127*^9, 3.993559577068104*^9}, {
   3.993559632965892*^9, 3.9935596329664297`*^9}, {3.993559904099448*^9, 
   3.993559911723508*^9}, {3.993560151850478*^9, 3.993560163762302*^9}, {
   3.9935602057029552`*^9, 3.993560488050445*^9}, {3.993560525250621*^9, 
   3.9935605518976927`*^9}, {3.993560668491057*^9, 3.993560883357102*^9}, {
   3.993561005494339*^9, 3.993561070499343*^9}, {3.9935611115276127`*^9, 
   3.9935611959082193`*^9}, {3.9935612412406893`*^9, 3.9935612849412746`*^9}, 
   3.993561403263315*^9, {3.993561434106709*^9, 3.993561434286314*^9}},
 CellLabel->
  "In[257]:=",ExpressionUUID->"20774aaa-fc66-4244-b966-4ffe7e631321"],

Cell[TextData[{
 "However, I can remedy this by increasing the number of plotting points \
using ",
 StyleBox["PlotPoints",
  FontWeight->"Bold"],
 ":"
}], "Text",
 CellChangeTimes->{{3.993561484668564*^9, 3.993561510644498*^9}, {
  3.993561729541007*^9, 
  3.993561734777136*^9}},ExpressionUUID->"8d185b7e-922e-49f2-a374-\
1522abb8ed6e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"f", "[", "x", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
    RowBox[{"PlotRange", "->", "All"}], ",", 
    RowBox[{"PlotPoints", "->", "1000"}], ",", "  ", 
    RowBox[{"MaxRecursion", "->", "0"}]}], "]"}], " "}]], "Input",
 CellChangeTimes->{{3.993561484668564*^9, 3.9935615266916037`*^9}},
 CellLabel->
  "In[259]:=",ExpressionUUID->"3862ad49-d0c6-4d17-b815-3ab09018bf41"],

Cell["\<\
I can also alternatively have small amount of plotting points and increase \
the number of recursive subdivisions,\
\>", "Text",
 CellChangeTimes->{{3.993561557608705*^9, 3.993561570811241*^9}, {
  3.993561664852351*^9, 3.9935616861322107`*^9}, {3.993561746369462*^9, 
  3.99356176305886*^9}, {3.993562197421432*^9, 
  3.993562201533474*^9}},ExpressionUUID->"eea7be70-26b9-4acb-a816-\
e95f00902701"],

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"f", "[", "x", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
   RowBox[{"PlotRange", "->", "All"}], ",", 
   RowBox[{"PlotPoints", "->", "10"}], ",", " ", 
   RowBox[{"MaxRecursion", "->", "10"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.993561557608705*^9, 3.993561570811241*^9}, {
  3.993561664852351*^9, 3.9935616861322107`*^9}, {3.993561746369462*^9, 
  3.9935617745615463`*^9}, {3.993561866970715*^9, 3.993561915118944*^9}},
 CellLabel->
  "In[264]:=",ExpressionUUID->"9608dacf-af6b-4d5c-a254-6f333c384c8b"],

Cell["\<\
Feel free to mess around with the numbers to see how the plot changes. \
\>", "Text",
 CellChangeTimes->{{3.993562059685382*^9, 
  3.993562072883967*^9}},ExpressionUUID->"0e9da22d-6ffc-4c65-8a74-\
b28c83248c48"],

Cell[TextData[{
 "However, as stated before, Mathematica\[CloseCurlyQuote]s default is to \
automatically determine an appropriate amount for both ",
 StyleBox["PlotPoints ",
  FontWeight->"Bold"],
 "and ",
 StyleBox["MaxRecursions",
  FontWeight->"Bold"],
 ". So, you can usually omit having to mess with these options:"
}], "Text",
 CellChangeTimes->{{3.9935619188708467`*^9, 3.993562051503941*^9}, {
  3.993562084720646*^9, 
  3.99356208507231*^9}},ExpressionUUID->"6b75d403-a2ef-4743-a443-\
26bf327da2b1"],

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"f", "[", "x", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
   RowBox[{"PlotRange", "->", "All"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9935619188708467`*^9, 3.993562014771572*^9}},
 CellLabel->
  "In[265]:=",ExpressionUUID->"e2f56924-156c-4903-ad40-d2e9ccc9a969"],

Cell[TextData[{
 "In cases of complex numerical models, however, you may find that your plots \
are not turning out the way you would like. In these cases, consider changing \
some of these values. There are also options like ",
 StyleBox["Exclusions",
  FontWeight->"Bold"],
 " which works similar to the ",
 StyleBox["NIntegrate",
  FontWeight->"Bold"],
 " equivalent. You will likely have to look into the different options as you \
run into issues and learn with experience. \n",
 "\nAnother thing to note with plots is that they can handle quantities (i.e \
things with units), however, they will only plot the magnitudes without any \
units involved so be wary of what units your variables have. "
}], "Text",
 CellChangeTimes->{{3.9935620884655533`*^9, 3.9935621572367573`*^9}, {
  3.9935622367817717`*^9, 3.9935622500795717`*^9}, {3.9935622895782003`*^9, 
  3.993562304098381*^9}, {3.993562359766581*^9, 3.993562367666596*^9}, {
  3.993562525824066*^9, 3.993562549088335*^9}, {3.9935627603385963`*^9, 
  3.9935628276271887`*^9}},ExpressionUUID->"5f7cfd33-4c26-4151-a393-\
a99463237f4b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"a", " ", "=", " ", 
    TemplateBox[<|"query" -> "2 m/s^2", "boxes" -> TemplateBox[{"2", 
         RowBox[{"\"m\"", "\[InvisibleSpace]", "\"/\"", "\[InvisibleSpace]", 
           SuperscriptBox["\"s\"", "2"]}], "meters per second squared", 
         FractionBox["\"Meters\"", 
          SuperscriptBox["\"Seconds\"", "2"]]}, "Quantity", SyntaxForm -> 
        Mod], "allassumptions" -> {{
        "word" -> "", "template" -> 
         "Assuming \"m/s^2\" is a unit${separator}Use \"m\" as ${desc} \
instead", "count" -> "2", "pulldown" -> "false", "type" -> "MultiClash", 
         "default" -> "{\"MC\", \"m/s^2\"} -> {\"Unit\", \"dflt\"}", 
         "Values" -> {{
           "name" -> "Unit", "desc" -> "a unit", "input" -> 
            "{\"MC\", \"m/s^2\"} -> {\"Unit\"}", "word" -> "m/s^2"}, {
           "name" -> "Variable", "desc" -> "a variable", "input" -> 
            "{\"MC\", \"m/s^2\"} -> {\"Variable\"}", "word" -> "m"}}}}, 
      "assumptions" -> {}, "open" -> {1, 2}, 
      "querystate" -> {
       "Online" -> True, "Allowed" -> True, "mparse.jsp" -> 
        0.552398`6.1937970910084035, "Messages" -> {}}, "contextinfo" -> 
      Automatic, "version" -> 5|>,
     "LinguisticAssistantTemplate"]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"acceleration", " ", "of", " ", "2", " ", 
    RowBox[{"m", "/", 
     RowBox[{"s", "^", "2"}]}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"F", "[", "x_", "]"}], ":=", " ", 
    RowBox[{
     RowBox[{"Quantity", "[", 
      RowBox[{"x", ",", "\"\<Kilograms\>\""}], "]"}], " ", "a"}]}], ";"}], 
  " ", 
  RowBox[{"(*", 
   RowBox[{
   "force", " ", "for", " ", "an", " ", "object", " ", "of", " ", "mass", " ",
     "x"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"F", "[", "x", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0", ",", "10"}], "}"}]}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "A", " ", "plot", " ", "which", " ", "is", " ", "gives", " ", "the", " ", 
     "force", " ", "in", " ", "Newtons", " ", "as", " ", "a", " ", "function",
      " ", "of", " ", "the", " ", "mass", " ", "in", " ", "kg"}], ",", " ", 
    RowBox[{
    "but", " ", "there", " ", "is", " ", "no", " ", "indication", " ", "as", " ",
      "to", " ", "what", " ", "the", " ", "units", " ", "are"}]}], 
   "*)"}]}]}], "Input",
 CellChangeTimes->{{3.9935620884655533`*^9, 3.9935621572367573`*^9}, {
  3.9935622367817717`*^9, 3.993562340150737*^9}, {3.9935624291599693`*^9, 
  3.993562517052175*^9}},
 CellLabel->
  "In[293]:=",ExpressionUUID->"8d49791d-a9b5-446f-b82f-65def61659c1"]
}, Closed]]
}, Closed]],

Cell[CellGroupData[{

Cell["Plots in Higher Dimensions", "Subsection",
 CellChangeTimes->{{3.993562888231983*^9, 
  3.993562956946138*^9}},ExpressionUUID->"8b83c4cd-3fa5-4cad-b083-\
cd08f8a696c3"],

Cell["\<\
Mathematica also has a variety of options for displaying plots in higher \
dimensions. A lot of the plot options from before also apply to these plots, \
though you may have to look in the documentation to see how they work for \
each kind of plot. The rest of this section just highlights some useful plot \
commands with some examples. Keep in mind that it usually takes more \
computing power to render 3D graphics and you may be better off using a \
different representation.\
\>", "Text",
 CellChangeTimes->{{3.9937241419223633`*^9, 3.993724206578434*^9}, {
  3.993724244618885*^9, 3.9937243796358232`*^9}, {3.993724471900797*^9, 
  3.993724530377091*^9}, {3.993725313723442*^9, 3.993725326951376*^9}, {
  3.9937254938171453`*^9, 3.993725509268784*^9}, {3.993725650029883*^9, 
  3.99372565137537*^9}, {3.9937257526991377`*^9, 3.993725752778751*^9}, {
  3.993726110401692*^9, 3.9937261381262417`*^9}, {3.993726540753149*^9, 
  3.993726562777688*^9}, {3.993726682910562*^9, 3.993726701526477*^9}, {
  3.9937268138716288`*^9, 3.993726814351712*^9}, {3.9937310883147583`*^9, 
  3.993731118123075*^9}, {3.993732076722802*^9, 
  3.993732128515082*^9}},ExpressionUUID->"e79522e2-70e8-4a66-a027-\
e50aaddc11bd"],

Cell[CellGroupData[{

Cell["Plot3D", "Subsubsection",
 CellChangeTimes->{{3.993731166079125*^9, 
  3.99373117442467*^9}},ExpressionUUID->"2648272a-904c-407e-b3a8-\
f60c8ec4667f"],

Cell[TextData[{
 StyleBox["Plot3D",
  FontWeight->"Bold"],
 " allows you to visualize surfaces, note that with 3 D plots, you can use \
your mouse to click and drag to change the view of the plot . Commands like \
ViewPoint can also change at which view the plot is oriented to begin with . "
}], "Text",
 CellChangeTimes->{{3.99373119129797*^9, 
  3.993731193217367*^9}},ExpressionUUID->"ab9c67eb-7ea9-428b-9703-\
7ee94830b75b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"f", "[", 
   RowBox[{"x_", ",", "y_"}], "]"}], ":=", " ", 
  RowBox[{
   RowBox[{"x", "^", "2"}], " ", 
   RowBox[{"Sin", "[", "y", "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Plot3D", "[", 
   RowBox[{
    RowBox[{"f", "[", 
     RowBox[{"x", ",", "y"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "5"}], ",", "5"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"y", ",", 
      RowBox[{"-", "5"}], ",", "5"}], "}"}], ",", 
    RowBox[{"ViewPoint", "->", " ", "Top"}]}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{"A", " ", "plot", " ", "of", " ", 
    RowBox[{"x", "^", "2"}], " ", 
    RowBox[{"Sin", "[", "y", "]"}]}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.993731166079125*^9, 3.993731198891015*^9}, 
   3.9937312464209347`*^9},
 CellLabel->
  "In[256]:=",ExpressionUUID->"6956c78e-3dd0-4a50-9f9c-c123e41a0dd2"]
}, Closed]],

Cell[CellGroupData[{

Cell["Contour Plots", "Subsubsection",
 CellChangeTimes->{{3.993731127555088*^9, 
  3.9937311345347757`*^9}},ExpressionUUID->"631db1ae-d4d2-4a38-a567-\
70643096c58c"],

Cell[TextData[{
 StyleBox["ContourPlot",
  FontWeight->"Bold"],
 " is a great way to visualize a surface without using 3D graphics, adding a \
color function and a legend can help make it more readable. You can also use \
it to plot solution curves."
}], "Text",
 CellChangeTimes->{{3.9937265308103027`*^9, 3.993726549037188*^9}, {
  3.993726588197424*^9, 3.9937266799706*^9}, {3.993726828675848*^9, 
  3.993726832320002*^9}, {3.993726870344555*^9, 3.993726888904368*^9}, {
  3.993726927252527*^9, 3.9937269299002857`*^9}, {3.993727063161631*^9, 
  3.993727066041691*^9}, {3.993727376488308*^9, 
  3.993727413552362*^9}},ExpressionUUID->"e5253610-c9de-4e82-bcbc-\
74d45dddfaf0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ContourPlot", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Cos", "[", "x", "]"}], 
     RowBox[{"Sin", "[", "y", "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{
       RowBox[{"-", "2"}], "\[Pi]"}], ",", 
      RowBox[{"2", "\[Pi]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"y", ",", 
      RowBox[{
       RowBox[{"-", "2"}], "\[Pi]"}], ",", 
      RowBox[{"2", "\[Pi]"}]}], "}"}], ",", 
    RowBox[{"ColorFunction", "->", "\"\<DeepSeaColors\>\""}], ",", 
    RowBox[{"PlotLegends", "->", "Automatic"}]}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"A", " ", "plot", " ", "of", " ", "the", " ", "surface", " ", "f", 
     RowBox[{"(", 
      RowBox[{"x", ",", "y"}], ")"}]}], " ", "=", " ", 
    RowBox[{
     RowBox[{"Cos", "[", "x", "]"}], 
     RowBox[{"Sin", "[", "y", "]"}]}]}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.9937265308103027`*^9, 3.993726549037188*^9}, {
  3.993726588197424*^9, 3.993726640787622*^9}, {3.993727117346572*^9, 
  3.993727234175383*^9}, {3.9937274174450607`*^9, 3.993727424217887*^9}, {
  3.993727498369679*^9, 
  3.9937275149177856`*^9}},ExpressionUUID->"82662580-7a3a-4872-a268-\
ab37cdf3a74f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ContourPlot", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"x", "^", "2"}], " ", "+", " ", 
      RowBox[{"y", "^", "2"}]}], " ", "==", " ", "4"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "3"}], ",", "3"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"y", ",", 
      RowBox[{"-", "3"}], ",", "3"}], "}"}]}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"Plot", " ", "of", " ", "solutions", " ", "to", " ", 
      SuperscriptBox["x", "2"]}], " ", "+", " ", 
     SuperscriptBox["y", "2"]}], " ", "=", " ", "4"}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.993727243483075*^9, 3.993727251155538*^9}, {
  3.9937273213960123`*^9, 
  3.9937273568603163`*^9}},ExpressionUUID->"96f98aa2-c67a-4573-bb8a-\
8dd9629e9228"],

Cell["There is also a 3D version:", "Text",
 CellChangeTimes->{{3.993731725717046*^9, 
  3.993731739161436*^9}},ExpressionUUID->"1c47e7ba-4cfe-4b59-a2bb-\
bc2fdba56deb"],

Cell[BoxData[
 RowBox[{"ContourPlot3D", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"x", "^", "2"}], "+", 
     RowBox[{"y", "^", "2"}], "+", 
     RowBox[{"z", "^", "2"}]}], "==", "4"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"y", ",", 
     RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"z", ",", 
     RowBox[{"-", "2"}], ",", "2"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.993731725717046*^9, 3.993731790268388*^9}},
 CellLabel->
