Cell[BoxData[{
 RowBox[{"Clear", "[", "\"\<`*\>\"", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Efield", "[", 
     RowBox[{"x_", ",", "y_"}], "]"}], "=", " ", 
    RowBox[{
     FractionBox["1", 
      SuperscriptBox[
       RowBox[{"Sqrt", "[", 
        RowBox[{
         SuperscriptBox["x", "2"], "+", 
         SuperscriptBox["y", "2"]}], "]"}], "3"]], 
     RowBox[{"{", 
      RowBox[{"x", ",", "y"}], "}"}]}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "a", " ", "simple", " ", "2", "D", " ", "Electric", " ", "field", " ", 
    "for", " ", "a", " ", "positive", " ", "charge", " ", "at", " ", "the", " ",
     "origin"}], "*)"}], " "}], "\[IndentingNewLine]", 
 RowBox[{"VectorPlot", "[", 
  RowBox[{
   RowBox[{"Efield", "[", 
    RowBox[{"x", ",", "y"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"y", ",", 
     RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}]}], "Input",
