       "TeXAssistantTemplate"]}],
     TraditionalForm], " ", "are", " ", "the", " ", "zeroth", " ", "order", " ",
     "Bessel", " ", "functions", " ", "of", " ", "the", " ", "first", " ", 
    "and", " ", "second", " ", "kind"}], ",", " ", 
