   3.9774990612660713`*^9}, {3.977499157212118*^9, 3.9774992336241016`*^9}, {
   3.977499282336191*^9, 3.9774993933641186`*^9}, {3.977499579120455*^9, 
   3.977499669025341*^9}, {3.977499733389925*^9, 3.977499762194748*^9}, {
   3.9774998636875153`*^9, 3.9774998780355167`*^9}, 3.9774999284575176`*^9, {
   3.977499978770628*^9, 3.977500198657345*^9}, {3.977500241249569*^9, 
   3.9775003362474537`*^9}, {3.9775007740549164`*^9, 
   3.9775007961279144`*^9}, {3.9775009580495815`*^9, 3.977500962457617*^9}},
 CellLabel->"In[11]:=",ExpressionUUID->"df10244b-e109-7f4c-befc-1a9d43b8b610"],

Cell["\<\
Mathematica outputs the number 2 since I told Mathematica to replace a with \
2.  You can also do this with expressions and multiple parameters:\
\>", "Text",
 CellChangeTimes->{{3.976971517887455*^9, 3.9769715485208187`*^9}, {
   3.977246450772932*^9, 3.9772464720028763`*^9}, {3.977246506341463*^9, 
   3.9772465256877575`*^9}, {3.9772465826819305`*^9, 
   3.9772465923542633`*^9}, {3.9772467009793205`*^9, 
   3.9772467306122875`*^9}, {3.9772469127315025`*^9, 3.977246913995699*^9}, {
   3.977248711276884*^9, 3.977248712647888*^9}, {3.977499002884161*^9, 
   3.9774990612660713`*^9}, {3.977499157212118*^9, 3.9774992336241016`*^9}, {
   3.977499282336191*^9, 3.9774993933641186`*^9}, {3.977499579120455*^9, 
   3.977499669025341*^9}, {3.977499733389925*^9, 3.977499762194748*^9}, {
   3.9774998636875153`*^9, 3.9774998780355167`*^9}, 3.9774999284575176`*^9, {
   3.977499978770628*^9, 3.977500198657345*^9}, {3.977500241249569*^9, 
   3.9775003362474537`*^9}, {3.9775007740549164`*^9, 
   3.9775007933427944`*^9}, {3.9775009255265503`*^9, 3.977501006838625*^9}, {
   3.9775010977603283`*^9, 3.977501102930155*^9}, {3.9775011543979645`*^9, 
   3.9775011655115128`*^9}},ExpressionUUID->"7f6af919-3c94-4b4d-a017-\
86dd31cce78d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"a", " ", "+", " ", "b"}], " ", "/.", " ", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"a", "->", " ", "1"}], ",", " ", 
    RowBox[{"b", "->", " ", "2"}], ",", 
    RowBox[{"c", " ", "->", " ", "10"}]}], "}"}]}]], "Input",
 CellChangeTimes->{{3.976971517887455*^9, 3.9769715485208187`*^9}, {
   3.977246450772932*^9, 3.9772464720028763`*^9}, {3.977246506341463*^9, 
   3.9772465256877575`*^9}, {3.9772465826819305`*^9, 
   3.9772465923542633`*^9}, {3.9772467009793205`*^9, 
   3.9772467306122875`*^9}, {3.9772469127315025`*^9, 3.977246913995699*^9}, {
   3.977248711276884*^9, 3.977248712647888*^9}, {3.977499002884161*^9, 
   3.9774990612660713`*^9}, {3.977499157212118*^9, 3.9774992336241016`*^9}, {
   3.977499282336191*^9, 3.9774993933641186`*^9}, {3.977499579120455*^9, 
   3.977499669025341*^9}, {3.977499733389925*^9, 3.977499762194748*^9}, {
   3.9774998636875153`*^9, 3.9774998780355167`*^9}, 3.9774999284575176`*^9, {
   3.977499978770628*^9, 3.977500198657345*^9}, {3.977500241249569*^9, 
   3.9775003362474537`*^9}, {3.9775007740549164`*^9, 
   3.9775007933427944`*^9}, {3.9775009255265503`*^9, 3.977501006838625*^9}, {
   3.9775010977603283`*^9, 3.977501102930155*^9}, {3.9775011543979645`*^9, 
   3.977501177013338*^9}, {3.9775012142556725`*^9, 3.9775012201510124`*^9}},
 CellLabel->"In[15]:=",ExpressionUUID->"35eb96e9-9785-3546-a649-9f1fcf5306fb"],

Cell["\<\
Note that Mathematica will still evaluate the expression even if your rule \
contains parameters which don\[CloseCurlyQuote]t appear in the expression. \
\>", "Text",
 CellChangeTimes->{{3.977501181897558*^9, 
  3.9775012120599365`*^9}},ExpressionUUID->"cba7e896-f8fd-974b-87df-\
5ac0dc5a0190"],

Cell[TextData[{
 "For a more applicable example, suppose I am working with the magnitude of \
some electric field . I can store the constants I might use in a rule and use \
",
 StyleBox["Replace",
  FontWeight->"Bold"],
 " to numerically evaluate the field :"
}], "Text",
 CellChangeTimes->{{3.976971517887455*^9, 3.9769715485208187`*^9}, {
   3.977246450772932*^9, 3.9772464720028763`*^9}, {3.977246506341463*^9, 
   3.9772465256877575`*^9}, {3.9772465826819305`*^9, 
   3.9772465923542633`*^9}, {3.9772467009793205`*^9, 
   3.9772467306122875`*^9}, {3.9772469127315025`*^9, 3.977246913995699*^9}, {
   3.977248711276884*^9, 3.977248712647888*^9}, {3.977499002884161*^9, 
   3.9774990612660713`*^9}, {3.977499157212118*^9, 3.9774992336241016`*^9}, {
   3.977499282336191*^9, 3.9774993933641186`*^9}, {3.977499579120455*^9, 
   3.977499669025341*^9}, {3.977499733389925*^9, 3.977499762194748*^9}, {
   3.9774998636875153`*^9, 3.9774998780355167`*^9}, 3.9774999284575176`*^9, {
   3.977499978770628*^9, 3.977500198657345*^9}, {3.977500241249569*^9, 
   3.9775003362474537`*^9}, {3.9775007740549164`*^9, 
   3.9775007933427944`*^9}, {3.9775009255265503`*^9, 
   3.9775009418910103`*^9}},ExpressionUUID->"61356ab5-f3c7-184c-afff-\
9b6eb20ae328"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"MagEField", "[", "r_", "]"}], " ", "=", "  ", 
   RowBox[{"k", " ", 
    FractionBox["q", 
     SuperscriptBox["r", "2"]]}]}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Define", " ", "the", " ", "magnitude", " ", "of", " ", "the", " ", 
    "electric", " ", "field"}], "*)"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"EMrule", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"k", " ", "->", " ", 
       RowBox[{"8.99", " ", "*", 
        SuperscriptBox["10", "9"]}]}], " ", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"Coulomb", "'"}], "s", " ", "constant", " ", "in", " ", "N", " ", 
        RowBox[{
         RowBox[{"m", "^", "2"}], "/", 
         RowBox[{"C", "^", "2"}]}]}], "*)"}], ",", " ", 
      RowBox[{"q", " ", "->", " ", 
       RowBox[{"1.60218", "*", " ", 
        SuperscriptBox["10", 
         RowBox[{"-", "19"}]]}]}]}], " ", 
     RowBox[{"(*", 
      RowBox[{"elementary", " ", "charge", " ", "in", " ", "Coulombs"}], 
      "*)"}], "}"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "create", " ", "a", " ", "list", " ", "of", " ", "replacement", " ", 
    "rules", " ", "for", " ", "the", " ", "constants"}], "*)"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"MagEField", "[", "0.1", "]"}], "/.", " ", "EMrule", " ", 
  RowBox[{"(*", 
   RowBox[{
   "calculate", " ", "the", " ", "magnitude", " ", "of", " ", "the", " ", 
    "magnetic", " ", "field", " ", "at", " ", "0.1", "m", " ", "with", " ", 
    "above", " ", "constants"}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.976971517887455*^9, 3.9769715485208187`*^9}, {
   3.977246450772932*^9, 3.9772464720028763`*^9}, {3.977246506341463*^9, 
   3.9772465256877575`*^9}, {3.9772465826819305`*^9, 
   3.9772465923542633`*^9}, {3.9772467009793205`*^9, 
   3.9772467306122875`*^9}, {3.9772469127315025`*^9, 3.977246913995699*^9}, {
   3.977248711276884*^9, 3.977248712647888*^9}, {3.977499002884161*^9, 
   3.9774990612660713`*^9}, {3.977499157212118*^9, 3.9774992336241016`*^9}, {
   3.977499282336191*^9, 3.9774993933641186`*^9}, {3.977499579120455*^9, 
   3.977499669025341*^9}, {3.977499733389925*^9, 3.977499762194748*^9}, {
   3.9774998636875153`*^9, 3.9774998780355167`*^9}, 3.9774999284575176`*^9, {
   3.977499978770628*^9, 3.9775001745150604`*^9}, {3.9775002361394005`*^9, 
   3.9775002364979343`*^9}, {3.977500289484129*^9, 3.9775003032953663`*^9}, {
   3.9775003402407913`*^9, 3.9775004124782066`*^9}, {3.977500444837631*^9, 
   3.977500497114916*^9}, {3.977500576656889*^9, 3.9775006452013626`*^9}, {
   3.9775006975095367`*^9, 3.9775007666322517`*^9}},
 CellLabel->"In[8]:=",ExpressionUUID->"60b2fac5-2ff4-9440-b62d-04b0f6c9d0de"],

Cell["\<\
The replace command is also useful because a lot of pre-built Mathematica \
functions return rules as output. A previous exercise asked you to find the \
zero of a function, below I have copied the solution \
\>", "Text",
 CellChangeTimes->{{3.97750144813628*^9, 
  3.9775015938621674`*^9}},ExpressionUUID->"9d140e11-123b-b54a-ab92-\
e33db59bb950"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "\"\<`*\>\"", "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Clear", " ", "variables"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"f", "[", "x_", "]"}], " ", "=", " ", 
    RowBox[{
     RowBox[{"BesselJ", "[", 
      RowBox[{"0", ",", "x"}], "]"}], "-", " ", 
     RowBox[{"BesselY", "[", 
      RowBox[{"0", ",", "x"}], "]"}]}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Define", " ", "function"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"FindRoot", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"f", "[", "x", "]"}], "==", "0"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0.01"}], "}"}]}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Find", " ", "the", " ", "first", " ", "order", " ", "zero"}], 
   "*)"}]}]}], "Input",
 CellChangeTimes->{{3.97750144813628*^9, 3.977501643576782*^9}},
 CellLabel->"In[19]:=",ExpressionUUID->"a970316b-d87f-054c-a29b-88d01ff82e9c"],

Cell["\<\
Notice Mathematica returned a rule as the output. We can use the replace \
command to access this value for a function. We can check to make sure this \
is actually a zero of the function, or evaluate the derivative:\
\>", "Text",
 CellChangeTimes->{{3.9775016530513077`*^9, 3.9775016658254547`*^9}, {
  3.977501705144327*^9, 3.977501724112566*^9}, {3.9775019195970936`*^9, 
  3.9775019806330376`*^9}},ExpressionUUID->"4c47e023-63c4-3e41-818e-\
02eaced00058"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", "x", "]"}], "/.", " ", 
   RowBox[{"FindRoot", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"f", "[", "x", "]"}], "==", "0"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0.01"}], "}"}]}], "]"}]}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Check", " ", "to", " ", "make", " ", "sure", " ", "this", " ", "is", " ", 
    "actually", " ", "a", " ", "zero"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"f", "'"}], "[", "x", "]"}], "/.", " ", 
  RowBox[{"FindRoot", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"f", "[", "x", "]"}], "==", "0"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0.01"}], "}"}]}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Calculate", " ", "the", " ", "derivative", " ", "at", " ", "the", " ", 
    "zero"}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.9775016530513077`*^9, 3.9775016658254547`*^9}, {
  3.977501705144327*^9, 3.977501724112566*^9}, {3.9775019195970936`*^9, 
  3.9775020134278374`*^9}, {3.977502115951721*^9, 3.977502122019497*^9}},
 CellLabel->"In[25]:=",ExpressionUUID->"64b096aa-23b2-0044-8e78-e05aaa86d7d9"]
}, Closed]],

Cell[CellGroupData[{

Cell["Prefix and Postfix", "Subsection",
 CellChangeTimes->{{3.977501463759281*^9, 
  3.977501467544937*^9}},ExpressionUUID->"ccee3404-fda7-8e4c-b34d-\
7ab758fd8048"],

Cell["We can also evaluate functions using prefix notation (@). ", "Text",
 CellChangeTimes->{{3.977501253556959*^9, 3.9775013849455357`*^9}, {
  3.977502191117384*^9, 3.9775022021061134`*^9}, {3.977502267057829*^9, 
  3.977502276237734*^9}, {3.9775024008281307`*^9, 
  3.9775024094834213`*^9}},ExpressionUUID->"8d67cf4e-4bbb-2b41-bbbd-\
ab2f48ebb479"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "f", "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Clear", " ", "the", " ", "function", " ", "f"}], "*)"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", "x_", "]"}], "=", " ", 
   RowBox[{"x", "^", "3"}]}], " ", 
  RowBox[{"(*", 
   RowBox[{"Define", " ", "the", " ", "function"}], " ", "*)"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"f", "@", "3", " ", 
  RowBox[{"(*", 
   RowBox[{"Evaluate", " ", "the", " ", "function", " ", "at", " ", "3"}], 
   "*)"}]}]}], "Input",
 CellChangeTimes->{{3.977501253556959*^9, 3.9775013849455357`*^9}, {
  3.977502191117384*^9, 
  3.977502282241827*^9}},ExpressionUUID->"76c2a718-5a38-924b-bc8a-\
e1dfef6be9e6"],

Cell["\<\
The line \[OpenCurlyDoubleQuote]f@3\[CloseCurlyDoubleQuote] can be read as \
\[OpenCurlyDoubleQuote]the function, f ,evaluated at \
3\[CloseCurlyDoubleQuote].  This, of course, isn\[CloseCurlyQuote]t much \
different than just doing f[3]. However, when used in conjunction with \
\[OpenCurlyDoubleQuote]nameless\[CloseCurlyDoubleQuote], or pure, functions \
they can become much more useful. A nameless function is exactly what it \
sounds like, it is a function which was not previously defined and therefore \
doesn\[CloseCurlyQuote]t have a name. These functions use # to denote \
variables and & to denote where they end:\
\>", "Text",
 CellChangeTimes->{{3.977502285008751*^9, 3.9775023174789276`*^9}, {
  3.9775023747886333`*^9, 3.9775023819248543`*^9}, {3.977502414614393*^9, 
  3.9775025370820084`*^9}, {3.9775027435809727`*^9, 3.9775027479375095`*^9}, {
  3.977502788881592*^9, 3.9775027944553585`*^9}, {3.977502842440834*^9, 
  3.9775028897712536`*^9}},ExpressionUUID->"f7fb092c-165f-9044-8450-\
cde9f3fee91e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"(", 
   RowBox[{
    SuperscriptBox["2", "#1"], "&"}], ")"}], "[", "x", "]"}], "\n", 
 RowBox[{
  RowBox[{"(", 
   RowBox[{
    RowBox[{
     RowBox[{
      SuperscriptBox["#1", "2"], " ", 
      SuperscriptBox["#2", "2"]}], "+", "#3"}], "&"}], ")"}], "[", 
  RowBox[{"x", ",", "y", ",", "z"}], "]"}]}], "Input",
 CellChangeTimes->{{3.977502285008751*^9, 3.9775023174789276`*^9}, {
   3.9775023747886333`*^9, 3.9775023819248543`*^9}, {3.977502414614393*^9, 
   3.9775025370820084`*^9}, {3.9775027435809727`*^9, 
   3.9775027479375095`*^9}, {3.977502788881592*^9, 3.9775028806021805`*^9}, 
   3.9929447857118587`*^9},
 CellLabel->"In[34]:=",ExpressionUUID->"09a03610-cd43-7343-b446-d76f098a0982"],

Cell["\<\
Again, this may not be particularly useful on its own, but using the two can \
be very useful when you want to apply the same operation to a set of numbers\
\>", "Text",
 CellChangeTimes->{{3.977502900026346*^9, 3.9775029145479374`*^9}, {
  3.977503067055929*^9, 3.9775030812879868`*^9}, {3.9775031302832584`*^9, 
  3.977503149244528*^9}},ExpressionUUID->"450d12e3-3773-fa4c-bede-\
08f73863ea29"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(", 
   RowBox[{
    RowBox[{
     FractionBox[
      SuperscriptBox["#1", "2"], "9"], "+", "6"}], "&"}], ")"}], "[", 
  RowBox[{"{", 
   RowBox[{"1", ",", "2", ",", "3", ",", "4", ",", "5"}], "}"}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.977502900026346*^9, 3.9775029145479374`*^9}, {
   3.977503067055929*^9, 3.9775030812879868`*^9}, {3.9775031302832584`*^9, 
   3.977503179529873*^9}, 3.9929447857706223`*^9},
 CellLabel->"In[36]:=",ExpressionUUID->"203cd4f1-3836-dc44-9c7e-1a7ba6760b82"],

Cell["\<\
Another useful notation is postfix notation (//). This notation tells \
Mathematica to apply a command after evaluating everything else first. There \
are a few common instances where I use post fixing myself:

For numerical outputs:\
\>", "Text",
 CellChangeTimes->{{3.977502248850111*^9, 3.9775022509693184`*^9}, {
   3.977503344121319*^9, 3.977503356291477*^9}, {3.977503496642023*^9, 
   3.9775035417303467`*^9}, {3.977503582789076*^9, 3.9775036300697517`*^9}, 
   3.992944231550417*^9, {3.9929450372925777`*^9, 
   3.9929450467591267`*^9}},ExpressionUUID->"b92561f7-d00e-8842-a802-\
5e37613fc284"],

Cell[BoxData[{
 SqrtBox["10"], "\n", 
 RowBox[{"N", "[", 
  SqrtBox["10"], "]"}]}], "Input",
 CellChangeTimes->{{3.977502248850111*^9, 3.9775022509693184`*^9}, {
   3.977503344121319*^9, 3.977503356291477*^9}, {3.977503496642023*^9, 
   3.9775035417303467`*^9}, {3.977503582789076*^9, 3.9775036300697517`*^9}, {
   3.992944233991396*^9, 3.992944271005434*^9}, 3.992944785774626*^9},
 CellLabel->"In[2]:=",ExpressionUUID->"96e9a6d1-c665-a443-b85a-b3c7a3d85c2b"],

Cell["Simplifying and expanding expressions:", "Text",
 CellChangeTimes->{{3.977502248850111*^9, 3.9775022509693184`*^9}, {
  3.977503344121319*^9, 3.977503356291477*^9}, {3.977503496642023*^9, 
  3.9775035417303467`*^9}, {3.977503582789076*^9, 3.9775036492704887`*^9}, {
  3.992944277346678*^9, 3.992944279356369*^9}, {3.992944515406687*^9, 
  3.992944516814991*^9}},ExpressionUUID->"8f502ae0-9906-d244-901c-\
16a7aecddf8f"],

Cell[BoxData[{
 RowBox[{"Simplify", "[", 
  RowBox[{
   SuperscriptBox["x", "2"], "+", 
   RowBox[{"2", " ", "x"}], "+", "1"}], "]"}], "\n", 
 RowBox[{"Expand", "[", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"x", "+", "1"}], ")"}], " ", 
   RowBox[{"(", 
    RowBox[{"x", "+", "2"}], ")"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.977502248850111*^9, 3.9775022509693184`*^9}, {
   3.977503344121319*^9, 3.977503356291477*^9}, {3.977503496642023*^9, 
   3.9775035417303467`*^9}, {3.977503582789076*^9, 3.9775036492704887`*^9}, {
   3.992944277346678*^9, 3.9929442798673096`*^9}, {3.9929445206603775`*^9, 
   3.9929445944099064`*^9}, 3.992944785797922*^9},
 CellLabel->"In[5]:=",ExpressionUUID->"d9981ed0-e264-3b4d-870b-40949ae4a5cb"],

Cell["Matrix operations, including matrix form:", "Text",
 CellChangeTimes->{{3.977502248850111*^9, 3.9775022509693184`*^9}, {
  3.977503344121319*^9, 3.977503356291477*^9}, {3.977503496642023*^9, 
  3.9775035417303467`*^9}, {3.977503582789076*^9, 3.9775036433929577`*^9}, {
  3.9929447653094807`*^9, 3.9929447661984177`*^9}, {3.9929450701742363`*^9, 
  3.9929450924756184`*^9}},ExpressionUUID->"62fb22ec-50b4-9d4f-83d5-\
f4951f662743"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"A", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"3", ",", "4"}], "}"}]}], "}"}]}], "  "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"A", " ", "//", " ", "MatrixForm"}], " ", 
  RowBox[{"(*", 
   RowBox[{"outputs", " ", "matrix", " ", "form"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"A", " ", "//", " ", "Transpose"}], " ", "//", " ", "MatrixForm"}],
   " ", 
  RowBox[{"(*", 
   RowBox[{
   "transposes", " ", "the", " ", "matrix", " ", "and", " ", "then", " ", 
    "outputs", " ", "matrix", " ", "form"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"A", " ", "//", " ", "Inverse"}], " ", "//", " ", "MatrixForm", " ", 
  RowBox[{"(*", 
   RowBox[{
   "inverts", " ", "the", " ", "matrix", " ", "and", " ", "outputs", " ", 
    "the", " ", "matrix", " ", "form"}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.977502248850111*^9, 3.9775022509693184`*^9}, {
  3.977503344121319*^9, 3.977503356291477*^9}, {3.977503496642023*^9, 
  3.9775035417303467`*^9}, {3.977503582789076*^9, 3.9775036433929577`*^9}, {
  3.9929447653094807`*^9, 3.9929447926643925`*^9}, {3.9929449790357113`*^9, 
  3.9929449831014023`*^9}, {3.992945064150322*^9, 
  3.9929451660176563`*^9}},ExpressionUUID->"5e707774-e869-0744-80b8-\
936d586db6c0"],

Cell["\<\
Notice how we can apply multiple postfix commands, the commands are applied \
from left to right. Be careful, when using postfixing with definitions as it \
will store whatever the result of the postfix command is. For example, you \
may end up storing the Matrix form of an object:\
\>", "Text",
 CellChangeTimes->{{3.992945050908993*^9, 3.992945062667816*^9}, {
   3.992945168567911*^9, 3.99294519878298*^9}, {3.992946027698576*^9, 
   3.9929461107473316`*^9}, {3.9929461418690453`*^9, 3.9929461745108356`*^9}, 
   3.9929466999093647`*^9, 
   3.9929467611338425`*^9},ExpressionUUID->"9f362f82-da36-1542-93ee-\
bab979b40a18"],

Cell[BoxData[
 RowBox[{" ", 
  RowBox[{
   RowBox[{"A", " ", "=", " ", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", "0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "1"}], "}"}]}], "}"}], " ", "//", " ", 
     "MatrixForm"}]}], " ", 
   RowBox[{"(*", 
    RowBox[{"stores", " ", "the", " ", "matrix", " ", "form"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"A", ".", 
    RowBox[{"{", 
     RowBox[{"1", ",", "0"}], "}"}], " ", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{"won", "'"}], "t", " ", "do", " ", "the", " ", "calculation", " ",
       "because", " ", "A", " ", "is", " ", "not", " ", "a", " ", "list", " ",
       "but", " ", "the", " ", "matrix", " ", "form", " ", "of", " ", "a", " ",
       "list"}], "*)"}]}]}]}]], "Input",
 CellChangeTimes->{
  3.9929458592705383`*^9, {3.992946113388504*^9, 3.9929461373927937`*^9}, {
   3.9929467206116085`*^9, 3.992946754701462*^9}},
 CellLabel->"In[45]:=",ExpressionUUID->"8033409a-aa2d-6d44-9f42-fb7e14a4c939"],

Cell[CellGroupData[{

Cell["Exercise", "Subsubsection",
 CellChangeTimes->{{3.9929468041781654`*^9, 
  3.9929468061879444`*^9}},ExpressionUUID->"b8aba663-e172-2744-893c-\
74f067092191"],

Cell[TextData[{
 "In section V, we will be dealing with how to plot and fit data. It will be \
useful to know how to convert two related lists of data into a set of ordered \
pairs. For this exercise, you will hopefully be able to find a way to do so \
(or at least look at the solution for a way to do so).  Here you have two \
sets of data X = {",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], "1"], ",", 
         SubscriptBox[
          StyleBox["x", "TI"], "2"], ",", "\[Ellipsis]", ",", 
         SubscriptBox[
          StyleBox["x", "TI"], 
          StyleBox["n", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "x_1,x_2,\\ldots,x_n", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "61784a34-de98-7e47-8977-62f7be68677c"],
 "}",
 StyleBox[" ", "Subsubsection"],
 "and Y = {",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["y", "TI"], "1"], ",", 
         SubscriptBox[
          StyleBox["y", "TI"], "2"], ",", "\[Ellipsis]", ",", 
         SubscriptBox[
          StyleBox["y", "TI"], 
          StyleBox["n", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "y_1,y_2,\\ldots,y_n", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8866ef83-7aa3-be40-b48c-061040a610c0"],
 "}, convert the data into a list of ordered pairs, pairList = {(",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], "1"], ",", 
         SubscriptBox[
          StyleBox["y", "TI"], "1"], ")", ",", 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox[
              StyleBox["x", "TI"], "2"], ",", 
             SubscriptBox[
              StyleBox["y", "TI"], "2"]}], ")"}], ",", "\[Ellipsis]", ",", 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox[
              StyleBox["x", "TI"], 
              StyleBox["n", "TI"]], ",", 
             SubscriptBox[
              StyleBox["y", "TI"], 
              StyleBox["n", "TI"]]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> "x_1,y_1),(x_2,y_2),\\ldots,(x_n,y_n)", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1b9be4b3-1365-8747-847c-691dae931d86"],
 "}"
}], "Text",
 CellChangeTimes->{{3.9929468041781654`*^9, 3.9929468195769577`*^9}, {
  3.9929469533937283`*^9, 3.992947131525524*^9}, {3.992947163762535*^9, 
  3.9929471710319595`*^9}, {3.992947222849251*^9, 
  3.992947492417183*^9}},ExpressionUUID->"05aea140-a31e-7c4e-9f60-\
c3cd5860b91b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"X", " ", "=", " ", 
    RowBox[{"Table", "[", 
     RowBox[{"j", ",", 
      RowBox[{"{", 
       RowBox[{"j", ",", "1", ",", "20"}], "}"}]}], "]"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Data", " ", "set", " ", "X"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Y", " ", "=", " ", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"RandomReal", "[", "]"}], ",", "20"}], "]"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Data", " ", "set", " ", "Y"}], "*)"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"your", " ", "code", " ", "here"}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.9929468041781654`*^9, 3.9929468195769577`*^9}, {
  3.9929469533937283`*^9, 3.9929471570775566`*^9}, {3.992947242422264*^9, 
  3.9929472596191864`*^9}, {3.9929475147914314`*^9, 3.992947601998068*^9}, {
  3.992947784717535*^9, 
  3.9929477987435417`*^9}},ExpressionUUID->"faa2188f-6d15-8541-8958-\
0d3fdf7ef63b"]
}, Closed]],

Cell[CellGroupData[{

Cell["Solution", "Subsubsection",
 CellChangeTimes->{{3.9929477594186115`*^9, 
  3.9929477621242676`*^9}},ExpressionUUID->"8f71b1b3-37c2-2140-b1d5-\
476cce3411ca"],

Cell["\<\
Again, there are a lot of ways to do this, but I find that the simplest way \
is to simply place the two data sets in a list and then transpose them. \
\>", "Text",
 CellChangeTimes->{{3.992947772931267*^9, 
  3.9929478257023544`*^9}},ExpressionUUID->"21e6aef6-bfd9-144d-8658-\
c51fc98d03fe"],

Cell[BoxData[
 RowBox[{
  RowBox[{"{", 
   RowBox[{"X", ",", "Y"}], "}"}], "//", " ", "Transpose"}]], "Input",
 CellChangeTimes->{{3.9929477594186115`*^9, 3.992947768196308*^9}, {
  3.992947829432804*^9, 3.99294784602219*^9}},
 CellLabel->"In[52]:=",ExpressionUUID->"99c69861-9cd3-a641-a40b-a8c5d86f99cc"]
}, Closed]]
}, Closed]],

Cell[CellGroupData[{

Cell["Numerics", "Subsection",
 CellChangeTimes->{{3.9929479349014854`*^9, 3.9929479392459583`*^9}, {
  3.992947992167433*^9, 3.992947999457571*^9}, {3.993042107468937*^9, 
  3.9930421086727657`*^9}},ExpressionUUID->"b8f17eb4-924b-274f-b7c3-\
77c8562bd874"],

Cell["\<\
As with all mathematical computing, we also need to be mindful of the quirks \
and nuances of numerical accuracy and precision. I will not go into the \
specifics of the different types of numerical errors that occur, for that you \
will have to take a course that deals with numerical methods. However, in \
Mathematica there are a few built-in tools that help us to manage numerics. \
We have already seen the use of the numerical evaluation command, N (see \
Section 1, Variables and Basic Functions):\
\>", "Text",
 CellChangeTimes->{{3.9929479349014854`*^9, 3.9929481910779495`*^9}, {
  3.9929482492609158`*^9, 3.9929482964550915`*^9}, {3.9929484152468357`*^9, 
  3.992948416227564*^9}, {3.99294851088715*^9, 
  3.9929485427209797`*^9}},ExpressionUUID->"f848cd05-e957-f04f-aef9-\
6de1e98c5e90"],

Cell[BoxData[{
 RowBox[{"Pi", "  ", 
  RowBox[{"(*", 
   RowBox[{
   "outputs", " ", "the", " ", "exact", " ", "expression", " ", "for", " ", 
    "\[Pi]"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"N", "[", "Pi", "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "gives", " ", "a", " ", "numerical", " ", "approximation", " ", "for", " ",
     "\[Pi]"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"N", "[", 
   RowBox[{"Pi", ",", "3"}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Specifically", " ", "gives", " ", "a", " ", "numerical", " ", 
    "approximation", " ", "for", " ", "\[Pi]", " ", "to", " ", "3", " ", 
    "digits"}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.9929479349014854`*^9, 3.9929481910779495`*^9}, {
  3.9929482492609158`*^9, 3.9929482964550915`*^9}, {3.9929484152468357`*^9, 
  3.9929484904269085`*^9}},
 CellLabel->"In[53]:=",ExpressionUUID->"4dd51f9b-7ca5-bb4a-b6c4-3def3ebe2db9"],

Cell[TextData[{
 "While this can be helpful to manage the final output of any calculation, it \
won\[CloseCurlyQuote]t affect how Mathematica manages numerical values during \
calculation. Fortunately, Mathematica does have built-in commands for common \
types of numerical calculation. We will begin with Integration. Mathematica\
\[CloseCurlyQuote]s ",
 StyleBox["Integral",
  FontWeight->"Bold"],
 " command",
 " will first attempt to evaluate an integral exactly:"
}], "Text",
 CellChangeTimes->{{3.992948546508007*^9, 3.9929485523373737`*^9}, {
  3.992948594973736*^9, 3.992948618538702*^9}, {3.9929487244035225`*^9, 
  3.9929487897723064`*^9}, {3.992948868525984*^9, 3.9929488911562195`*^9}, {
  3.992948925218214*^9, 3.9929489663234043`*^9}, {3.9929490060540657`*^9, 
  3.992949008473812*^9}, {3.9929491004075546`*^9, 3.992949110860607*^9}, {
  3.992949250178299*^9, 3.9929492769078884`*^9}, {3.992949328509081*^9, 
  3.9929493378705482`*^9}, {3.992949424501524*^9, 
  3.9929494648589554`*^9}},ExpressionUUID->"e6b42ef4-f00a-8748-bde3-\
091fb962395d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{"Exp", "[", 
     RowBox[{"-", 
      SuperscriptBox["x", "2"]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}]}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Evaluated", " ", "the", " ", "Gaussian", " ", "integral", " ", 
    "exactly"}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.992948546508007*^9, 3.9929485523373737`*^9}, {
  3.992948594973736*^9, 3.992948618538702*^9}, {3.9929487244035225`*^9, 
  3.9929487897723064`*^9}, {3.992948868525984*^9, 3.9929488911562195`*^9}, {
  3.992948925218214*^9, 3.9929489663234043`*^9}, {3.9929490060540657`*^9, 
  3.992949008473812*^9}, {3.9929491004075546`*^9, 3.992949110860607*^9}, {
  3.992949250178299*^9, 
  3.9929493176410236`*^9}},ExpressionUUID->"9550bea8-3192-aa47-b0c3-\
8390ae21f30a"],

Cell["\<\
If exact integration is not possible, it will attempt to evaluate the \
integral numerically:\
\>", "Text",
 CellChangeTimes->{{3.992949438497555*^9, 3.992949446203745*^9}, {
  3.992949503310198*^9, 3.99294951697653*^9}, {3.992949620756092*^9, 
  3.9929496335188675`*^9}},ExpressionUUID->"f9bbfb53-5a67-f645-9aef-\
7efe6ea91500"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Exp", "[", 
      RowBox[{"-", 
       SuperscriptBox["x", "2"]}], "]"}], 
     RowBox[{"Sin", "[", "x", "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0.2", ",", "0.3"}], "}"}]}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Mathematica", " ", "was", " ", "unable", " ", "to", " ", "evaluate", " ", 
    "the", " ", "integral", " ", "exactly", " ", "and", " ", "therefore", " ",
     "use", " ", "numerical", " ", "techniques", " ", "to", " ", "calculate", 
    " ", "the", " ", "integral"}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.992949438497555*^9, 3.992949446203745*^9}, {
  3.992949503310198*^9, 3.99294951697653*^9}, {3.992949620756092*^9, 
  3.9929497533600674`*^9}, {3.992949804412134*^9, 3.9929498466248455`*^9}, {
  3.992949918717882*^9, 
  3.9929499451587486`*^9}},ExpressionUUID->"ce57d975-ecab-da44-900f-\
017a60a60ecc"],

Cell[TextData[{
 "This is the case for a number of Mathematica\[CloseCurlyQuote]s commands. \
However, if we know that an integral (or calculation) cannot be done exactly, \
we can skip the exact integral calculation attempt by utilizing the ",
 StyleBox["NIntegrate ",
  FontWeight->"Bold"],
 "command. This command also has a lot of options that can change the method \
with which integration is done and change the precision and accuracy of the \
numbers used in calculation. Let\[CloseCurlyQuote]s look at an integral with \
some notable singularities: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox["\[Integral]", "30", "\[Infinity]"], 
         FractionBox[
          SuperscriptBox[
           StyleBox["e", "TI"], 
           RowBox[{"-", 
             StyleBox["x", "TI"]}]], 
          RowBox[{"sin", "(", 
            RowBox[{"\[Pi]", 
              StyleBox["x", "TI"]}], ")"}]], 
         StyleBox["d", "TI"], 
         StyleBox["x", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\int_{30}^{\\infty} \\frac{e^{-x}}{\\sin(\\pi x)}dx", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "294be1d0-2dcd-e74d-88d1-780faf899ebb"],
 "\nIf we try to use the normal ",
 StyleBox["Integrate ",
  FontWeight->"Bold"],
 "we see that it throws an error:"
}], "Text",
 CellChangeTimes->{{3.9929479349014854`*^9, 3.9929481910779495`*^9}, {
  3.9929482492609158`*^9, 3.9929482934192924`*^9}, {3.9929497772048798`*^9, 
  3.9929498130963593`*^9}, {3.9929498665070915`*^9, 3.992949905292427*^9}, {
  3.9929499488048496`*^9, 3.992949969056402*^9}, {3.993029692947195*^9, 
  3.993029735858597*^9}, {3.99302978756312*^9, 3.9930298836913567`*^9}, {
  3.993029943289179*^9, 3.9930299677665195`*^9}, {3.993030028757126*^9, 
  3.993030030858675*^9}, {3.993030209050455*^9, 3.993030211050951*^9}, {
  3.993030278182234*^9, 3.993030315127407*^9}, {3.993030377435587*^9, 
  3.9930303939814873`*^9}, {3.993030440513525*^9, 3.9930304820463467`*^9}, {
  3.993030840182335*^9, 3.9930308569612293`*^9}, {3.993032292401287*^9, 
  3.993032300256838*^9}, {3.993041984128645*^9, 
  3.993041984578415*^9}},ExpressionUUID->"dc4738ad-7ed1-984f-949f-\
c4c233d4396f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Integrate", "[", 
   RowBox[{
    FractionBox[
     RowBox[{"Exp", "[", 
      RowBox[{"-", "x"}], "]"}], 
     RowBox[{"Sin", "[", 
      RowBox[{"\[Pi]", " ", "x"}], "]"}]], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "30", ",", "Infinity"}], "}"}]}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "integration", " ", "of", " ", "a", " ", "singular", " ", "function", " ", 
    "will", " ", "give", " ", "a", " ", "error"}], "*)"}]}]], "Input",
 CellChangeTimes->CompressedData["
1:eJxTTMoPSmViYGAQB2IQ/ePGndkf9791nFD3aDeIzonUOAyib2StPQGiE/rU
mj6BaNHFbSBawiqgF0RPiNacBKJDDs6cDqJ5zinOAtE5/vPaJQ+8dVxQ+bsH
RIuwFk0G0TPky+aD6C8OL5eB6JD2HytBdILVjI0g2qXqNpgOmat4AkSnLEwE
03euHL0AoncIp1wFy3/QvQuiIzLs74PoM3kCT8HiUyLfgugLu35/BNE9Mf/B
tM7KyyxSQHpJuQEriNaJfCYEog2CbEVAtE83+0owndS9HkQH1B05CaIZer+A
6RbVlddAdMK51BtgfSENd0D0FP11YNplxZlnILrje+MLEP2l7425PJCWWJxk
AaJdpv+7In4QKG8QfA1EAwBIjsjz
  "],ExpressionUUID->"76c01c04-189f-0c4f-9ed1-8b33169eadbf"],

Cell[TextData[{
 "If we use the NIntegrate command without any options, we still get errors \
and Mathematica again suggests that the integrand is probably zero. \
Mathematica will even output a number which is on the order of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["10", 
    RowBox[{"-", "12"}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4351c66d-e857-9347-9869-6bcfbaf05fa0"],
 " (which is basically zero)"
}], "Text",
 CellChangeTimes->{{3.993030862884062*^9, 3.993030879332161*^9}, {
  3.9930312405704937`*^9, 3.9930313224695873`*^9}, {3.9930414117537537`*^9, 
  3.9930414551459713`*^9}},ExpressionUUID->"954a431c-d757-264b-91cd-\
87ea5b4c686c"],

Cell[BoxData[
 RowBox[{"NIntegrate", "[", 
  RowBox[{
   FractionBox[
    RowBox[{"Exp", "[", 
     RowBox[{"-", "x"}], "]"}], 
    RowBox[{"Sin", "[", 
     RowBox[{"\[Pi]", " ", "x"}], "]"}]], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "30", ",", "Infinity"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.993030862884062*^9, 3.993030879332161*^9}, {
   3.9930312405704937`*^9, 3.9930312553123207`*^9}, {3.9930318407721043`*^9, 
   3.9930318605884438`*^9}, {3.9930322500760174`*^9, 3.9930322507102222`*^9}, 
   3.9930324103712883`*^9, {3.993032521054323*^9, 3.9930325232560673`*^9}, {
   3.993037563725752*^9, 3.993037564448908*^9}, {3.9930412369130135`*^9, 
   3.9930412397492104`*^9}, {3.993041348858055*^9, 3.9930413493027306`*^9}},
 CellLabel->"In[65]:=",ExpressionUUID->"4943520f-5da9-dd41-bf15-046447336fd9"],

Cell[TextData[{
 "There are a few things we can do to get around these errors. We can tell \
Mathematica to handle the singularities using the ",
 StyleBox["Exclusions ",
  FontWeight->"Bold"],
 "option",
 ". It might also be helpful to increase the ",
 StyleBox["WorkingPrecision",
  FontWeight->"Bold"],
 " which tells Mathematica how many digits of precision to use during the \
numerical evaluation of the integral, and ",
 StyleBox["AccuracyGoal ",
  FontWeight->"Bold"],
 "which tells Mathematica how many digits of accuracy you want before \
Mathematica accepts the answer. In this case, setting the ",
 StyleBox["WorkingPrecision",
  FontWeight->"Bold"],
 " to 2 and ",
 StyleBox["AccuracyGoal ",
  FontWeight->"Bold"],
 "to 4 will make the integral return zero, which may be more useful than a \
small floating point number if we need to use it in later calculations. Feel \
free to mess with these values to see how it changes how Mathematica \
processes the integral."
}], "Text",
 CellChangeTimes->{{3.993031331601795*^9, 3.9930313908679047`*^9}, {
   3.993031421200657*^9, 3.9930314497134647`*^9}, {3.9930315068363304`*^9, 
   3.9930315567247353`*^9}, {3.993041399258724*^9, 3.993041404368431*^9}, {
   3.9930414623812065`*^9, 3.993041478165289*^9}, {3.9930415239768085`*^9, 
   3.9930416135192738`*^9}, {3.993041648390835*^9, 3.993041749982441*^9}, {
   3.993041931449892*^9, 3.9930419475792713`*^9}, 
   3.993042000657505*^9},ExpressionUUID->"09dc16df-1090-7e41-8982-\
84575274b760"],

Cell[BoxData[
 RowBox[{"NIntegrate", "[", 
  RowBox[{
   FractionBox[
    RowBox[{"Exp", "[", 
     RowBox[{"-", "x"}], "]"}], 
    RowBox[{"Sin", "[", 
     RowBox[{"\[Pi]", " ", "x"}], "]"}]], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "30", ",", "Infinity"}], "}"}], ",", " ", 
   RowBox[{"Exclusions", "->", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Sin", "[", 
       RowBox[{"\[Pi]", " ", "x"}], "]"}], " ", "==", " ", "0"}], ")"}]}], ",", 
   RowBox[{"WorkingPrecision", "->", "2"}], ",", " ", 
   RowBox[{"AccuracyGoal", "->", "4"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.993031331601795*^9, 3.9930313908679047`*^9}, {
  3.993031421200657*^9, 3.9930314497134647`*^9}, {3.9930315068363304`*^9, 
  3.9930317068880444`*^9}, {3.9930317609255543`*^9, 3.993031765184309*^9}, {
  3.993031826202017*^9, 3.993031827401808*^9}, {3.9930319937926216`*^9, 
  3.9930319971128006`*^9}, {3.9930323247638874`*^9, 3.9930323327434597`*^9}, {
  3.9930324477705746`*^9, 3.993032455216427*^9}, {3.9930325433473473`*^9, 
  3.9930325454697514`*^9}, {3.993039879114374*^9, 3.9930399198354454`*^9}, {
  3.9930399514610634`*^9, 3.9930399874387684`*^9}, {3.9930412467544136`*^9, 
  3.993041317277302*^9}, {3.9930413635304375`*^9, 3.9930413640580864`*^9}, {
  3.993041485579338*^9, 3.993041516683918*^9}, {3.99304159015172*^9, 
  3.993041597501009*^9}},
 CellLabel->"In[75]:=",ExpressionUUID->"86eebc6a-8759-b746-a051-1fe91876d83e"],

Cell[TextData[{
 "Another thing to point out is how options work for some built-in \
Mathematica commands, the syntax is [OptionName] -> <OptionValue>. The Arrow \
in the middle is made by typing the dash \[OpenCurlyDoubleQuote]-\
\[CloseCurlyDoubleQuote] and than greater-than symbol \
\[OpenCurlyDoubleQuote]>\[CloseCurlyDoubleQuote] like with the replace \
command syntax. A lot of built-in commands have options with their own \
possible values and you will have to read the documentation for a specific \
command to know what appropriate values are for specific options, these will \
come up more in section III on Plotting and Graphics. The NIntegrate command \
also allows you to change what numerical method is used to evaluate the \
integral, though appropriate use of these methods will require some more \
thorough research. Commands similar to ",
 StyleBox["NIntegrate ",
  FontWeight->"Bold"],
 "include ",
 StyleBox["NSolve, NSum, NExpectation, ",
  FontWeight->"Bold"],
 "and more. However, you may find that some commands like ",
 StyleBox["FindRoot ",
  FontWeight->"Bold"],
 "more useful when trying to find solutions to transcendental equations, so \
try different things. There is also a numerical differential equation solver \
which we will look more at in section VI. "
}], "Text",
 CellChangeTimes->{{3.9930417534843063`*^9, 3.9930419293840523`*^9}, {
  3.9930419983943157`*^9, 3.993042083021837*^9}, {3.993042210134762*^9, 
  3.9930423053644543`*^9}, {3.993042336802494*^9, 3.9930424462912464`*^9}, {
  3.9930424788102646`*^9, 3.993042491619747*^9}, {3.9930425263026295`*^9, 
  3.993042606015835*^9}, {3.9930426441514416`*^9, 
  3.993042673596161*^9}},ExpressionUUID->"d8d8c905-c880-2240-8d15-\
66d2359a2c03"],

Cell[BoxData[
 RowBox[{"NSolve", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"Exp", "[", "x", "]"}], "==", 
    RowBox[{"Sin", "[", "x", "]"}]}], ",", "x"}], "]"}]], "Input",
 CellChangeTimes->{{3.993039892469099*^9, 3.993039915860386*^9}, {
  3.9930422201467495`*^9, 3.9930422469946423`*^9}, {3.993042280302477*^9, 
  3.9930423124892693`*^9}, {3.993042613129221*^9, 3.993042618774969*^9}},
 CellLabel->"In[76]:=",ExpressionUUID->"885b8546-4ac7-094a-9aaa-181dbe3e1aae"]
}, Closed]],

Cell[CellGroupData[{

Cell["Units in Mathematica", "Subsection",
 CellChangeTimes->{{3.9930421196751003`*^9, 3.993042131298155*^9}, 
   3.993042675870617*^9},ExpressionUUID->"8931a446-edc1-6940-a74e-\
438190ea0c10"],

Cell[TextData[{
 "To end this section, we are going to go over how you can use units in \
Mathematica. Mathematica has a lot of built-in units. The way you can make \
use of them is using the ",
 StyleBox["Quantity[<Magnitude>,\[CloseCurlyDoubleQuote]<UnitName>\
\[CloseCurlyDoubleQuote]]",
  FontWeight->"Bold"],
 " command:"
}], "Text",
 CellChangeTimes->{{3.9930426814403973`*^9, 3.9930427706030807`*^9}, {
  3.993550239525461*^9, 3.993550350522292*^9}, {3.993550576644125*^9, 
  3.9935506003044853`*^9}},ExpressionUUID->"9ec542e5-6e1e-204c-8a6e-\
c44a40a1bcf7"],

Cell[BoxData[{
 RowBox[{"Clear", "[", "\"\<`*\>\"", "]"}], "\[IndentingNewLine]", 
 RowBox[{"m", " ", "=", " ", 
  RowBox[{"Quantity", "[", 
   RowBox[{"10", ",", "\"\<Kilograms\>\""}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{"define", " ", "a", " ", "mass", " ", "of", " ", "10", " ", "kg"}],
    "*)"}]}]}], "Input",
 CellChangeTimes->{{3.9930421196751003`*^9, 3.993042131298155*^9}, {
   3.99304267641881*^9, 3.9930426764218216`*^9}, {3.993550357226639*^9, 
   3.993550390546649*^9}, 3.993550447865651*^9, {3.993550544812284*^9, 
   3.993550594592575*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"12295900-d459-2b48-a479-84ed23a4ebaf"],

Cell["\<\
Mathematica can use compound units and will correctly handle units when doing \
calculations. It can even handle unit conversions:\
\>", "Text",
 CellChangeTimes->{{3.993550606837721*^9, 3.99355065867667*^9}, {
  3.993550751650008*^9, 3.9935507526175623`*^9}, {3.993550944507321*^9, 
  3.993550982855563*^9}},ExpressionUUID->"0856a809-bac5-4407-bffd-\
454f40d4cdd7"],

Cell[BoxData[
 RowBox[{"g", " ", "=", " ", 
  RowBox[{"Quantity", "[", 
   RowBox[{"32.2", ",", 
    RowBox[{"\"\<Feet\>\"", "/", 
     RowBox[{"\"\<Seconds\>\"", "^", "2"}]}]}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Define", " ", "the", " ", "acceleration", " ", "due", " ", "to", " ", 
    "gravity", " ", "on", " ", "Earth", " ", "to", " ", "be", " ", "32.2", " ", 
    RowBox[{"ft", "/", 
     SuperscriptBox["s", "2"]}]}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.993550606837721*^9, 3.99355065867667*^9}, {
  3.993550751650008*^9, 3.9935507526175623`*^9}, {3.993550944507321*^9, 
  3.993550950369297*^9}, {3.9935509859397984`*^9, 3.993551151902301*^9}, {
  3.9935514164995604`*^9, 
  3.993551418807437*^9}},ExpressionUUID->"b939ea2c-cf3d-4a29-bfc5-\
4323b9907a5b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Convert", " ", "g", " ", "to", " ", 
    RowBox[{"m", "/", 
     SuperscriptBox["s", "2"]}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"UnitConvert", "[", 
   RowBox[{"g", ",", " ", 
    RowBox[{"\"\<Meters\>\"", "/", 
     SuperscriptBox["\"\<Seconds\>\"", "2"]}]}], "]"}], " "}]], "Input",
 CellChangeTimes->{{3.993550606837721*^9, 3.99355065867667*^9}, {
  3.993550751650008*^9, 3.9935507526175623`*^9}, {3.993550944507321*^9, 
  3.993550950369297*^9}, {3.9935509859397984`*^9, 3.993551151902301*^9}},
 CellLabel->"In[8]:=",ExpressionUUID->"bdaee71e-7c31-4b5d-84c9-d8d9ff0b7b15"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Calculate", " ", "the", " ", "weight", " ", "of", " ", "a", " ", "10", " ",
     "kg", " ", "mass", " ", "on", " ", "Earth"}], "*)"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"weight", " ", "=", " ", 
    RowBox[{"m", " ", "g"}]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Convert", " ", "the", " ", "weight", " ", "to", " ", "Newtons", " ", 
     "and", " ", "pounds"}], "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"UnitConvert", "[", 
    RowBox[{"weight", ",", "\"\<Newtons\>\""}], "]"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"UnitConvert", "[", 
    RowBox[{"weight", ",", "\"\<PoundsForce\>\""}], "]"}], 
   "\[IndentingNewLine]"}]}]], "Input",
 CellChangeTimes->{{3.993551157026698*^9, 3.9935512503474483`*^9}, {
  3.993551301450753*^9, 3.993551305350593*^9}, {3.9935514076995783`*^9, 
  3.993551409507388*^9}},ExpressionUUID->"7297a58d-b22f-4a2d-870d-\
93d19a25e51d"],

Cell[TextData[{
 "The unit calculations are not fool-proof however, and sometimes you will \
need will want to just extract the magnitude or the units themselves this can \
be done using the ",
 StyleBox["QuantityMagnitude ",
  FontWeight->"Bold"],
 "and ",
 StyleBox["QuantityUnit ",
  FontWeight->"Bold"],
 "command."
}], "Text",
 CellChangeTimes->{{3.993551340754711*^9, 3.993551342446538*^9}, {
  3.9935513786350317`*^9, 3.993551394430766*^9}, {3.9935514267473927`*^9, 
  3.993551503069446*^9}},ExpressionUUID->"4ec7adff-1600-47af-b8d8-\
5b09c418ccf0"],

Cell[BoxData[
 RowBox[{"  ", 
  RowBox[{
   RowBox[{"QuantityMagnitude", "[", "g", "]"}], " ", 
   RowBox[{"(*", 
    RowBox[{"get", " ", "the", " ", "magnitude", " ", "of", " ", "g", " ", 
     RowBox[{"(", "32.2", ")"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"QuantityUnit", "[", "m", "]"}], " ", 
   RowBox[{"(*", 
    RowBox[{"get", " ", "the", " ", "unit", " ", "of", " ", "m", " ", 
     RowBox[{"(", "Kilograms", ")"}]}], "*)"}]}]}]], "Input",
 CellChangeTimes->{{3.993551340754711*^9, 3.993551342446538*^9}, {
  3.9935513786350317`*^9, 3.993551394430766*^9}, {3.9935514267473927`*^9, 
  3.993551556660634*^9}},ExpressionUUID->"5c10f8ac-de1a-4edc-935c-\
292b58f1809e"],

Cell["\<\
You can also define your own units, but that is outside the scope of this \
notebook. \
\>", "Text",
 CellChangeTimes->{{3.993553440654335*^9, 
  3.993553465709321*^9}},ExpressionUUID->"15a1d102-d9dd-4b2b-ad44-\
b53b34496edb"],

Cell[CellGroupData[{

Cell["Wolfram|Alpha shortcuts", "Subsubsection",
 CellChangeTimes->{{3.9935518065639677`*^9, 3.9935518266682987`*^9}, {
  3.993551985432747*^9, 
  3.993551992424181*^9}},ExpressionUUID->"525d9148-0f9c-4b51-b2ed-\
4db94b2b7a22"],

Cell[TextData[{
 "For this section, you will want to ensure Dynamic Updating is enabled, see \
Section 0 for instructions on how to do this.  You have probably used or seen \
WolframA|lpha to help with homework from time to time. If you have Dynamic \
Updating enabled, you can access the WolframAlpha directly in Mathematica. \
You can open a Wolfram|Alpha prompt by pressing \[OpenCurlyDoubleQuote]Ctrl + \
=\[CloseCurlyDoubleQuote] in an input cell this will cause a dialog box to \
appear with an orange equals sign: ",
 Cell[BoxData[
  GraphicsBox[
   TagBox[RasterBox[CompressedData["
1:eJzt3L1rU1EYgPGgDo6uGR2zR9LknooBl0iWVJIYJEhLbmsz5KtW6SBFFIJO
We3qol1cHPwLHERxEqQ4OZvJVX3NCURRUs1NfXPPCU/hV9ISOC+c+3BzINzz
G+21zVOJRGLn7OjX2vqdfK+3vnf13OiPcmtne6sVNgqtW+FW2FvZOD36ZzDy
YeRMYvwjAAAAAAAAyyadTgOIiL4APfQF6KEvQA99AXroC9BDX4Ae+gL00Beg
x+W+giCQarUqjUZDOp3OQtk17dp2hrj3CP5ytS9jzPgaL5fLks1mx9f5Itk1
7dp2Bvs67n2Cn1zty9477PW96K7+ZOcoFAqx7xP85Gpfk/tG3H3ZGUqlUuz7
