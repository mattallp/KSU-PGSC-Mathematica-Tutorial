Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Clear", "[", "\"\<`*\>\"", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Efield3D", "[", 
     RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], "=", " ", 
    RowBox[{
     FractionBox["1", 
      SuperscriptBox[
       RowBox[{"Sqrt", "[", 
        RowBox[{
         SuperscriptBox["x", "2"], "+", 
         SuperscriptBox["y", "2"]}], "]"}], "3"]], 
     RowBox[{"{", 
      RowBox[{"x", ",", "y", ",", "z"}], "}"}]}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "a", " ", "simple", " ", "3", "D", " ", "Electric", " ", "field", " ", 
    "for", " ", "a", " ", "positive", " ", "charge", " ", "at", " ", "the", " ",
     "origin"}], "*)"}], " "}], "\[IndentingNewLine]", 
 RowBox[{"VectorPlot3D", "[", 
  RowBox[{
   RowBox[{"Efield3D", "[", 
    RowBox[{"x", ",", "y", ",", "z"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"y", ",", 
     RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"z", ",", 
     RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.993731814166113*^9, 3.993731911977868*^9}},
