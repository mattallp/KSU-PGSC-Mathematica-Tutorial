}, Open  ]],

Cell[CellGroupData[{

Cell["I. Basics", "Section",
 CellChangeTimes->{{3.9762760590104065`*^9, 3.9762761319548645`*^9}, {
  3.9762762681290054`*^9, 3.976276370177023*^9}, {3.976276411457575*^9, 
  3.976276441062332*^9}, {3.976277732026493*^9, 3.976277758372057*^9}, {
  3.9763613359361153`*^9, 
  3.9763613492746315`*^9}},ExpressionUUID->"c82d85e9-fe82-174b-9cc0-\
bb014e8077aa"],

Cell["\<\
This section covers basics. This includes things like, how to write and \
evaluate code, how to declare variables, and how to call functions. \
\>", "Text",
 CellChangeTimes->{{3.976359716241705*^9, 
  3.9763597715047073`*^9}},ExpressionUUID->"bb9b0861-3958-f84d-9195-\
ad27d3dd46dd"],

Cell[CellGroupData[{

Cell["Input and Output", "Subsection",
 CellChangeTimes->{{3.9762760590104065`*^9, 3.9762761319548645`*^9}, {
  3.9762762681290054`*^9, 3.976276370177023*^9}, {3.976276411457575*^9, 
  3.976276441062332*^9}, {3.9762777361135635`*^9, 3.9762777440086117`*^9}, {
  3.9762777832840233`*^9, 
  3.9762777861957703`*^9}},ExpressionUUID->"2bd5388c-860c-3045-8e05-\
0a50e5e1e42c"],

Cell[TextData[{
 "Editable Mathematica files are called notebooks, you can create them either \
from the start screen from when you open Mathematica or by going to File and \
selecting New.\nWhen you create a new notebook, it probably won\
\[CloseCurlyQuote]t look like this notebook. This is because I am using the ",
 StyleBox["StandardReport ",
  FontWeight->"Bold"],
 "stylesheet for this notebook, information on stylesheets will be found in \
the PDF (not yet created) ",
 "\n\n In your computer files, notebooks are denoted by the .nb extension. \
Make sure you ",
 StyleBox["SAVE OFTEN",
  FontWeight->"Bold"],
 " as there is no auto-save feature for Mathematica and if your program \
crashes, there is no way to recover the files if they aren\[CloseCurlyQuote]t \
saved. The quickest way to do this is using the Ctrl + S shortcut. \n\nThere \
are two main kinds of code blocks in a Mathematica notebook. First there are \
input cells"
}], "Text",
 CellChangeTimes->{{3.9762760590104065`*^9, 3.9762761319548645`*^9}, {
  3.9762762681290054`*^9, 3.976276370177023*^9}, {3.976276411457575*^9, 
  3.9762764597805367`*^9}, {3.9762765251624355`*^9, 3.9762765533934727`*^9}, {
  3.9762766867977295`*^9, 3.976276688223049*^9}, {3.9762768829224243`*^9, 
  3.976276958024168*^9}, {3.976277274939623*^9, 3.976277427157547*^9}, {
  3.9762777489777184`*^9, 3.976277770412985*^9}, {3.976278179756998*^9, 
  3.9762781970585556`*^9}, {3.97662588495483*^9, 3.976625947540449*^9}, {
  3.9936417763521013`*^9, 
  3.993641879288843*^9}},ExpressionUUID->"7276d7a9-879d-7f46-8327-\
62d9dfa2be30"],

Cell[BoxData[
 RowBox[{"7", " ", 
  RowBox[{"(*", 
   RowBox[{"Input", " ", "cell"}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.9762760590104065`*^9, 3.9762761319548645`*^9}, {
  3.9762762681290054`*^9, 3.976276370177023*^9}, {3.976276411457575*^9, 
  3.9762764597805367`*^9}, {3.9762765251624355`*^9, 3.9762765533934727`*^9}, {
  3.9762766867977295`*^9, 3.976276688223049*^9}, {3.9762768829224243`*^9, 
  3.976276906020628*^9}, {3.976276964740221*^9, 3.976276966184128*^9}},
 CellLabel->"In[13]:=",ExpressionUUID->"1bd9fd47-b5cb-ee45-981b-e478df5c9745"],

Cell[TextData[{
 "These cells allow you to input your code and run them. In order to run a \
cell of code, you need to select the cell you want to run by clicking in the \
cell (your text cursor will appear in the cell)  and press ",
 StyleBox["Shift + Enter",
  FontWeight->"Bold"],
 " on the Keyboard. Try this below:"
}], "Text",
 CellChangeTimes->{{3.976276913094486*^9, 3.976276914464815*^9}, {
   3.97627697033786*^9, 3.9762770943607655`*^9}, 3.976277918975399*^9, {
   3.9763618459869385`*^9, 
   3.9763619492987804`*^9}},ExpressionUUID->"e802f297-169c-c843-b301-\
4bd1e8a9d4d8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"7", "  ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Click", " ", "on", " ", "the", " ", "cell", " ", "and", " ", "press", " ",
      "Shift"}], "+", 
    RowBox[{"Enter", " ", "on", " ", "your", " ", "keyboard"}]}], 
   "*)"}]}]], "Input",
 CellChangeTimes->{{3.976276913094486*^9, 3.976276914464815*^9}, {
  3.97627697033786*^9, 3.9762771153116913`*^9}, {3.9762774356898136`*^9, 
