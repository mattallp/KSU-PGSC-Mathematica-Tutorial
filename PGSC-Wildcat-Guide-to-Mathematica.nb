   PlotRange->{{0, 216.}, {0, 59.}}]], "Input",ExpressionUUID->
  "31ad11d8-14d4-4901-a82f-8f6b443d0da6"],
 ". Using this you can lookup constants and generate code (though I would be \
wary of the code generation).  You can also write a quantity with units to \
shortcut defining quantities. For example, by typing \
\[OpenCurlyDoubleQuote]permittivity of free space\[CloseCurlyDoubleQuote], I \
can get the constant ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Epsilon]", "0"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "af20fa52-01c6-4b92-9940-007f56cfe4a0"],
 ":"
}], "Text",
 CellChangeTimes->{{3.9935518065639677`*^9, 3.993551873295658*^9}, {
  3.993551923631875*^9, 3.9935519272877417`*^9}, {3.993552009368569*^9, 
  3.99355211007694*^9}, {3.9935521462376013`*^9, 3.9935522776546183`*^9}, {
  3.993552401744166*^9, 3.993552428308004*^9}, {3.993552459278028*^9, 
  3.993552514641099*^9}, {3.993552546179408*^9, 3.993552636429842*^9}, {
  3.9935533197201233`*^9, 
  3.993553381962175*^9}},ExpressionUUID->"aaf2cbe1-dd7f-48d1-88f5-\
8fa201091ddf"],

Cell[BoxData[
 RowBox[{"\[Epsilon]0", " ", "=", " ", 
  TemplateBox[<|
   "query" -> "permitivity of free space", "boxes" -> TemplateBox[{
       InterpretationBox["\[InvisibleSpace]", 1], 
       SubscriptBox["\"\[CurlyEpsilon]\"", "0"], "electric constants", 
       "\"ElectricConstant\""}, "Quantity", SyntaxForm -> Mod], 
    "allassumptions" -> {}, "assumptions" -> {}, "open" -> {1, 2}, 
    "querystate" -> {
     "Online" -> True, "Allowed" -> True, "mparse.jsp" -> 
      0.808781`6.359375933690094, "Messages" -> {}}, "contextinfo" -> 
    Automatic, "version" -> 5|>,
   "LinguisticAssistantTemplate"], " ", 
  RowBox[{"(*", 
   RowBox[{"permittivity", " ", "of", " ", "free", " ", "space"}], 
   "*)"}]}]], "Input",
 CellChangeTimes->{{3.9935518065639677`*^9, 3.993551873295658*^9}, {
  3.993551923631875*^9, 3.9935519272877417`*^9}, {3.993552009368569*^9, 
  3.99355211007694*^9}, {3.9935521462376013`*^9, 3.9935522339268217`*^9}, {
  3.993552280687258*^9, 3.993552285707417*^9}, {3.993552372067501*^9, 
  3.993552374223783*^9}, {3.993552938096758*^9, 3.9935529440207577`*^9}},
 CellLabel->"In[21]:=",ExpressionUUID->"03e8e410-beeb-40bd-b1b1-53b8201eb533"],

Cell["\<\
And by writing \[OpenCurlyDoubleQuote]10 V\[CloseCurlyDoubleQuote] I can get \
a quantity representing 10 Volts\
\>", "Text",
 CellChangeTimes->{{3.993553374716606*^9, 
  3.993553408672773*^9}},ExpressionUUID->"c2f6d038-20c2-4b71-86c2-\
3b782fd4548d"],

Cell[BoxData[
 RowBox[{"V", " ", "=", " ", 
  TemplateBox[<|
   "query" -> "10 V", "boxes" -> 
    TemplateBox[{"10", "\"V\"", "volts", "\"Volts\""}, "Quantity", SyntaxForm -> 
      Mod], "allassumptions" -> {{
      "type" -> "Clash", "word" -> "V", "template" -> 
       "Assuming \"V\" is a unit${separator}Use as ${desc} or ${desc} \
instead", "count" -> "3", "pulldown" -> "false", "default" -> 
       "{\"C\", \"V\"} -> {\"Unit\", \"dflt\"}", 
       "Values" -> {{
         "name" -> "Unit", "desc" -> "a unit", "input" -> 
          "{\"C\", \"V\"} -> {\"Unit\"}"}, {
         "name" -> "Variable", "desc" -> "a variable", "input" -> 
          "{\"C\", \"V\"} -> {\"Variable\"}"}, {
         "name" -> "RomanNumeral", "desc" -> "a roman numeral", "input" -> 
          "{\"C\", \"V\"} -> {\"RomanNumeral\"}"}}}, {
      "type" -> "Unit", "word" -> "V", "template" -> 
       "Assuming volts for \"V\"${separator}Use ${desc} instead", "count" -> 
       "2", "pulldown" -> "false", "default" -> 
       "\"UnitClash\" -> {\"V\", {\"Volts\", \"dflt\"}}", 
       "Values" -> {{
         "name" -> "Volts", "desc" -> "volts", "input" -> 
          "\"UnitClash\" -> {\"V\", {\"Volts\"}}"}, {
         "name" -> "LargeVreebles", "desc" -> "large vreebles", "input" -> 
          "\"UnitClash\" -> {\"V\", {\"LargeVreebles\"}}"}}}}, 
    "assumptions" -> {}, "open" -> {1, 2}, 
    "querystate" -> {
     "Online" -> True, "Allowed" -> True, "mparse.jsp" -> 
      0.66893`6.276925667012215, "Messages" -> {}}, "contextinfo" -> 
    Automatic, "version" -> 5|>,
   "LinguisticAssistantTemplate"]}]], "Input",
 CellChangeTimes->{{3.993553411544979*^9, 3.993553417749071*^9}},
 CellLabel->"In[20]:=",ExpressionUUID->"b3b148ce-95be-483a-be57-6b5fdaa263b2"],

Cell["\<\
Another cool feature of this is that even if you have a typo in what you are \
trying to get, Mathematica may still be able to figure it out. Again, \
however, this is not fool-proof. The check-mark next to the box is their for \
you to confirm that Mathematica\[CloseCurlyQuote]s interpretation of what you \
wrote is correct. There is a large amount of information that Wolfram|Alpha \
has access to, so if there is a constant or something you need, just try \
searching for it in Mathematica:\
\>", "Text",
 CellChangeTimes->{{3.993552638915223*^9, 3.9935526551096888`*^9}, {
  3.9935527333347816`*^9, 
  3.993552885104067*^9}},ExpressionUUID->"aafe237d-90f0-4e85-9511-\
fdc8cc9dbb58"],

Cell[BoxData[
 RowBox[{
  TemplateBox[<|"query" -> "Image of a dog", "boxes" -> RowBox[{
       TemplateBox[{"\"dog\"", 
         RowBox[{"Entity", "[", 
           
           RowBox[{"\"TaxonomicSpecies\"", ",", 
             "\"CanisLupusFamiliaris::4t62p\""}], "]"}], 
         "\"Entity[\\\"TaxonomicSpecies\\\", \
\\\"CanisLupusFamiliaris::4t62p\\\"]\"", "\"species specification\""}, 
        "Entity"], "[", 
       TemplateBox[{"\"image\"", 
         RowBox[{"EntityProperty", "[", 
           RowBox[{"\"TaxonomicSpecies\"", ",", "\"Image\""}], "]"}], 
         "\"EntityProperty[\\\"TaxonomicSpecies\\\", \\\"Image\\\"]\""}, 
        "EntityProperty"], "]"}], "allassumptions" -> {}, "assumptions" -> {},
     "open" -> {1, 2}, 
    "querystate" -> {
     "Online" -> True, "Allowed" -> True, "mparse.jsp" -> 
      0.920269`6.415459786210681, "Messages" -> {}}, "contextinfo" -> 
    Automatic, "version" -> 5|>,
   "LinguisticAssistantTemplate"], " ", 
  RowBox[{"(*", 
   RowBox[{
   "This", " ", "is", " ", "what", " ", "happens", " ", "when", " ", "I", " ",
     "ask", " ", "for", " ", "an", " ", "image", " ", "of", " ", "a", " ", 
    "dog"}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.993552638915223*^9, 3.9935526551096888`*^9}, {
  3.9935527333347816`*^9, 3.993552872279923*^9}, {3.9935529472848473`*^9, 
  3.993552957168827*^9}},ExpressionUUID->"bd115a6b-95ee-4b70-9d91-\
48744b200c35"],

Cell[BoxData[
 RowBox[{
  TemplateBox[<|
   "query" -> "generate a plot of sin(x)", "boxes" -> RowBox[{"Plot", "[", 
       RowBox[{
         RowBox[{"Sin", "[", "x", "]"}], ",", " ", 
         RowBox[{"{", 
           RowBox[{"x", ",", " ", 
             RowBox[{
               RowBox[{"-", "2"}], "*", "Pi"}], ",", " ", 
             RowBox[{"2", "*", "Pi"}]}], "}"}]}], "]"}], 
    "allassumptions" -> {}, "assumptions" -> {}, "open" -> {1, 2}, 
    "querystate" -> {
     "Online" -> True, "Allowed" -> True, "mparse.jsp" -> 
      0.779868`6.343566093977617, "Messages" -> {}}, "contextinfo" -> 
    Automatic, "version" -> 5|>,
   "LinguisticAssistantTemplate"], " ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "here", " ", "is", " ", "an", " ", "example", " ", "of", " ", "when", " ",
      "I", " ", "ask", " ", "to", " ", "generate", " ", "code"}], ",", " ", 
    RowBox[{
    "I", " ", "asked", " ", "it", " ", "to", " ", "generate", " ", "a", " ", 
     "plot", " ", "of", " ", "sin", 
     RowBox[{"(", "x", ")"}]}]}], "*)"}]}]], "Input",
 CellChangeTimes->{
  3.99355292742327*^9, {3.993552959324676*^9, 
   3.993552979313081*^9}},ExpressionUUID->"08d0b82a-b3a6-48b3-a301-\
caa1b815d2cc"]
}, Closed]],

Cell[CellGroupData[{

Cell["Exercise", "Subsubsection",
 CellChangeTimes->{{3.9935529877369757`*^9, 
  3.993552991726715*^9}},ExpressionUUID->"1637ca07-7d68-4770-adaf-\
f54f5afa6d2e"],

Cell[TextData[{
 "For this exercise, I am going to ask you to solve a basic conservation of \
energy problem:\nA ball of mass 20 g is dropped from a height of ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["h", "TI"], TraditionalForm], "errors" -> {}, "input" -> "h", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e2b84b20-e50f-46c8-b9a4-fa67db348952"],
 " = 10 ft. After the ball hits the ground, it bounces to a max height of ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox["1", "3"], 
         StyleBox["h", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\frac{1}{3}h", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "27d0254a-30dc-4f76-a989-036b642ca507"],
 " Calculate \n(a) The total energy (in Joules) of the ball before it is \
dropped\n(b) The speed of the ball (in m/s) as it hits the ground\n(c) The \
total energy of the ball after it hits the ground"
}], "Text",
 CellChangeTimes->{{3.9935529877369757`*^9, 3.9935532661775513`*^9}, {
  3.993553842636619*^9, 
  3.993553860256926*^9}},ExpressionUUID->"ebb60f1d-2601-4f44-a89c-\
8923c7b0c4d2"],

Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{"Your", " ", "code", " ", "here"}], "*)"}]], "Input",
 CellChangeTimes->{{3.9935529877369757`*^9, 
  3.993553269911674*^9}},ExpressionUUID->"cff27048-786b-42b6-93cf-\
05698c231d45"]
}, Closed]],

Cell[CellGroupData[{

Cell["Solution", "Subsubsection",
 CellChangeTimes->{{3.993553279552588*^9, 
  3.9935532871537*^9}},ExpressionUUID->"67c1bd86-7c35-4462-93c9-823713058245"],

Cell["\<\
For (a), we need only calculate the initial gravitational potential energy\
\>", "Text",
 CellChangeTimes->{{3.9935532946875877`*^9, 3.993553299563788*^9}, {
  3.993553489545657*^9, 
  3.9935535002241096`*^9}},ExpressionUUID->"4fc3fa07-be37-4c6c-9e60-\
d2b490180aa7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "\"\<`*\>\"", "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Clear", " ", "constants"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"define", " ", "constants"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"g", " ", "=", " ", 
   TemplateBox[<|
    "query" -> "acceleration due to gravity", "boxes" -> TemplateBox[{
        InterpretationBox["\[InvisibleSpace]", 1], "\"g\"", 
        "standard accelerations due to gravity on the surface of the earth", 
        "\"StandardAccelerationOfGravity\""}, "Quantity", SyntaxForm -> Mod], 
     "allassumptions" -> {{
       "type" -> "Clash", "word" -> "acceleration due to gravity", "template" -> 
        "Assuming \"acceleration due to gravity\" is a unit${separator}Use as \
${desc} instead", "count" -> "2", "pulldown" -> "false", "default" -> 
        "{\"C\", \"acceleration due to gravity\"} -> {\"Unit\", \"dflt\"}", 
        "Values" -> {{
          "name" -> "Unit", "desc" -> "a unit", "input" -> 
           "{\"C\", \"acceleration due to gravity\"} -> {\"Unit\"}"}, {
          "name" -> "GeogravityWord", "desc" -> " referring to gravity", 
           "input" -> 
           "{\"C\", \"acceleration due to gravity\"} -> \
{\"GeogravityWord\"}"}}}, {
       "type" -> "Unit", "word" -> "acceleration due to gravity", "template" -> 
        "Assuming standard acceleration due to gravity for \"acceleration due \
to gravity\"${separator}Use ${desc} instead", "count" -> "2", "pulldown" -> 
        "false", "default" -> 
        "\"UnitClash\" -> {\"acceleration due to gravity\", \
{\"StandardAccelerationOfGravity\", \"dflt\"}}", 
        "Values" -> {{
          "name" -> "StandardAccelerationOfGravity", "desc" -> 
           "standard acceleration due to gravity", "input" -> 
           "\"UnitClash\" -> {\"acceleration due to gravity\", \
{\"StandardAccelerationOfGravity\"}}"}, {
          "name" -> "AccelerationOfFreeFall", "desc" -> 
           "acceleration of free fall (including centrifugal acceleration)", 
           "input" -> 
           "\"UnitClash\" -> {\"acceleration due to gravity\", \
{\"AccelerationOfFreeFall\"}}"}}}}, "assumptions" -> {}, "open" -> {1, 2}, 
     "querystate" -> {
      "Online" -> True, "Allowed" -> True, "mparse.jsp" -> 
       0.609257`6.236345521166293, "Messages" -> {}}, "contextinfo" -> 
     Automatic, "version" -> 5|>,
    "LinguisticAssistantTemplate"]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"m", " ", "=", " ", 
   TemplateBox[{"20", "\"g\"", "grams", "\"Grams\""},
    "Quantity"]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"h", " ", "=", " ", 
    TemplateBox[<|
     "query" -> "10 ft", "boxes" -> 
      TemplateBox[{"10", "\"ft\"", "feet", "\"Feet\""}, "Quantity", 
        SyntaxForm -> Mod], "allassumptions" -> {}, "assumptions" -> {}, 
      "open" -> {1, 2}, 
      "querystate" -> {
       "Online" -> True, "Allowed" -> True, "mparse.jsp" -> 
        0.367626`6.016951212361364, "Messages" -> {}}, "contextinfo" -> 
      Automatic, "version" -> 5|>,
     "LinguisticAssistantTemplate"]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"E0", " ", "=", 
  RowBox[{
   RowBox[{"UnitConvert", "[", " ", 
    RowBox[{
     RowBox[{"m", " ", "g", " ", "h"}], " ", ",", "\"\<Joules\>\""}], "]"}], "//",
    " ", "N", 
   RowBox[{"(*", 
    RowBox[{"initial", " ", "energy", " ", "in", " ", "Joules"}], 
    "*)"}]}]}]}], "Input",
 CellChangeTimes->{{3.993553279552588*^9, 3.993553292140222*^9}, {
  3.993553502893694*^9, 3.993553601214748*^9}},
 CellLabel->"In[36]:=",ExpressionUUID->"a797aa07-6f39-49c6-b73c-d7209cb15c9c"],

Cell["\<\
For  (b), we can simply use the formula for kinetic energy to find the speed\
\>", "Text",
 CellChangeTimes->{{3.993553626002872*^9, 3.9935536263946466`*^9}, {
  3.993553686859673*^9, 
  3.993553700255414*^9}},ExpressionUUID->"ffe91a9d-9a03-4a4c-9890-\
455c2ed1a326"],

Cell[BoxData[
 RowBox[{
  RowBox[{"v", "/.", " ", 
   RowBox[{"Solve", "[", 
    RowBox[{
     RowBox[{"E0", " ", "==", " ", 
      RowBox[{
       FractionBox["1", "2"], "m", " ", 
       SuperscriptBox["v", "2"]}]}], ",", "v"}], "]"}]}], "//", "UnitConvert",
   " ", 
  RowBox[{"(*", 
   RowBox[{
   "this", " ", "will", " ", "produce", " ", "both", " ", "the", " ", 
    "positive", " ", "and", " ", "negative", " ", "solution"}], 
   "*)"}]}]], "Input",
 CellChangeTimes->{{3.9935536085558367`*^9, 3.993553609630781*^9}, {
  3.993553706223*^9, 3.993553712875556*^9}, {3.9935538046367273`*^9, 
  3.9935538360247383`*^9}, {3.993553867940823*^9, 
  3.993553896733437*^9}},ExpressionUUID->"1d16a625-1475-42cb-b9ac-\
90cf4bbcc7b4"],

Cell["\<\
For (c), we simply do a similar calculation as we did for a, but with 1/3 the \
height\
\>", "Text",
 CellChangeTimes->{{3.993553899898736*^9, 
  3.9935539290474453`*^9}},ExpressionUUID->"42a90fff-91bf-44ff-b07a-\
1be651f4ebac"],

Cell[BoxData[
 RowBox[{"Ef", " ", "=", " ", 
  RowBox[{
   RowBox[{"UnitConvert", "[", " ", 
    RowBox[{
     RowBox[{"m", " ", "g", " ", 
      FractionBox["h", "4"]}], " ", ",", "\"\<Joules\>\""}], "]"}], "//", " ",
    "N", " ", 
   RowBox[{"(*", 
    RowBox[{"final", " ", "energy", " ", "in", " ", "Joules"}], 
    "*)"}]}]}]], "Input",
 CellChangeTimes->{{3.993553899898736*^9, 3.993553959822122*^9}},
 CellLabel->"In[35]:=",ExpressionUUID->"e9a36512-5b44-427b-8017-7a5b9e332edb"]
}, Closed]]
}, Closed]]
}, Closed]],

Cell[CellGroupData[{

Cell["III. Plotting and Graphics", "Section",
 CellChangeTimes->{{3.9762798208942547`*^9, 3.97627982922587*^9}, 
   3.9766254552397823`*^9, {3.992946176710211*^9, 3.9929461794550304`*^9}, {
   3.993553976999796*^9, 
   3.9935539833280897`*^9}},ExpressionUUID->"42863c33-dea1-3340-b8ff-\
13725f457a85"],

Cell["\<\
In this section we are going to go over some basic graphical features that \
Mathematica, including plots, primitive graphics, and animations. \
\>", "Text",
 CellChangeTimes->{
  3.976279839200224*^9, {3.993553988830265*^9, 3.993553995262281*^9}, {
   3.9935542256644497`*^9, 3.9935542624849033`*^9}, {3.99355572398722*^9, 
   3.993555730052067*^9}},ExpressionUUID->"57c8246b-1b5e-754e-bdfc-\
4680f07626ac"],

Cell[CellGroupData[{

Cell["1D Plots and Plot Options", "Subsection",
 CellChangeTimes->{
  3.976279839200224*^9, {3.993553988830265*^9, 3.993553995262281*^9}, {
   3.9935542256644497`*^9, 3.9935542624849033`*^9}, {3.99355572398722*^9, 
   3.993555748781045*^9}, {3.9935557845915947`*^9, 3.993555788307453*^9}, {
   3.99356257077696*^9, 
   3.9935625730925922`*^9}},ExpressionUUID->"568365a9-dac2-4afe-a5bd-\
5894478dbd3e"],

Cell[TextData[{
 "Perhaps one of the most useful features of Mathematica is its ability to \
produce plots and graphics suitable for presentations and publications. Let\
\[CloseCurlyQuote]s begin with simple 1D plots, these are made using the ",
 StyleBox["Plot ",
  FontWeight->"Bold"],
 "command. The basic syntax is ",
 StyleBox["Plot[",
  FontWeight->"Bold"],
 "<function>, {<variable>,<min>,<max>}",
 StyleBox["]. ",
  FontWeight->"Bold"],
 "The function can also be user-defined, you just need to make sure that the \
variable we are plotting against is the same as the function. Below is a plot \
of the function ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"cos", "(", 
         RowBox[{"\[Pi]", 
           StyleBox["x", "TI"]}], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\cos(\\pi x)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b450f433-f9f6-4839-8806-95013f9e4a4e"],
 " + sin(2 \[Pi] x)"
}], "Text",
 CellChangeTimes->{{3.993555801127294*^9, 3.9935558586240177`*^9}, {
  3.993555992841485*^9, 3.993556009821624*^9}, {3.993556043165888*^9, 
  3.993556217875204*^9}, {3.9935564066496677`*^9, 
  3.993556465846353*^9}},ExpressionUUID->"9ce0a53b-efe7-4f1c-b90a-\
471138db4112"],

Cell[BoxData[{
 RowBox[{"Clear", "[", "\"\<`*\>\"", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", "x_", "]"}], ":=", " ", 
   RowBox[{
    RowBox[{"Cos", "[", 
     RowBox[{"\[Pi]", " ", "x"}], "]"}], " ", "+", " ", 
    RowBox[{"Sin", "[", 
     RowBox[{"2", " ", "\[Pi]", " ", "x"}], "]"}]}]}], " ", 
  RowBox[{"(*", 
   RowBox[{"user", " ", "defined", " ", "function"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"f", "[", "x", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "2"}], ",", "2"}], "}"}]}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{"plot", " ", "of", " ", "function"}], "*)"}]}]}], "Input",
 CellChangeTimes->{
  3.976279839200224*^9, {3.993553988830265*^9, 3.993553995262281*^9}, {
   3.9935542256644497`*^9, 3.9935542624849033`*^9}, {3.99355572398722*^9, 
