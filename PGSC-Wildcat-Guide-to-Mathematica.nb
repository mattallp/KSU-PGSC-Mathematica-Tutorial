 CellChangeTimes->{{3.9762780974851513`*^9, 3.9762781597122707`*^9}},
 CellLabel->"In[17]:=",ExpressionUUID->"fe9e4626-10b5-6142-9908-699070718fdd"],

Cell[TextData[{
 "Be careful, however, as this will give you the last ",
 StyleBox["evaluated ",
  FontWeight->"Bold"],
 "output not the output directly above.\nYou can also separate cells by going \
clicking in the cell and pressing ",
 StyleBox["Ctrl + D",
  FontWeight->"Bold"],
 ". "
}], "Text",
 CellChangeTimes->{{3.9762783722928047`*^9, 3.976278374441839*^9}, {
  3.993822649908943*^9, 
  3.9938226870942383`*^9}},ExpressionUUID->"b02e94c6-1c56-a148-8dae-\
