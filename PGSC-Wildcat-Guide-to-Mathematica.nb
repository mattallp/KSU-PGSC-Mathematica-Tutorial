f4951f662743"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"A", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"3", ",", "4"}], "}"}]}], "}"}]}], "  "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"A", " ", "//", " ", "MatrixForm"}], " ", 
  RowBox[{"(*", 
   RowBox[{"outputs", " ", "matrix", " ", "form"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"A", " ", "//", " ", "Transpose"}], " ", "//", " ", "MatrixForm"}],
   " ", 
  RowBox[{"(*", 
   RowBox[{
   "transposes", " ", "the", " ", "matrix", " ", "and", " ", "then", " ", 
    "outputs", " ", "matrix", " ", "form"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"A", " ", "//", " ", "Inverse"}], " ", "//", " ", "MatrixForm", " ", 
  RowBox[{"(*", 
   RowBox[{
   "inverts", " ", "the", " ", "matrix", " ", "and", " ", "outputs", " ", 
    "the", " ", "matrix", " ", "form"}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.977502248850111*^9, 3.9775022509693184`*^9}, {
  3.977503344121319*^9, 3.977503356291477*^9}, {3.977503496642023*^9, 
