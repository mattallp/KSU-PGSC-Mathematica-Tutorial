Cell[BoxData[
 TemplateBox[{
  "NIntegrate", "ncvb", 
   "\"NIntegrate failed to converge to prescribed accuracy after \
\\!\\(\\*RowBox[{\\\"9\\\"}]\\) recursive bisections in \
\\!\\(\\*RowBox[{\\\"x\\\"}]\\) near \\!\\(\\*RowBox[{\\\"{\\\", \\\"x\\\", \
\\\"}\\\"}]\\) = \\!\\(\\*RowBox[{\\\"{\\\", \
\\\"30.0000000000000000000000000000163072643374912722470619778528907452`65.\
954589770191\\\", \\\"}\\\"}]\\). NIntegrate obtained \
\\!\\(\\*RowBox[{\\\"4.4221683864024034`*^-12\\\"}]\\) and \
\\!\\(\\*RowBox[{\\\"7.604856355772847`*^-13\\\"}]\\) for the integral and \
error estimates.\"", 2, 65, 99, 34900017014425649369, "Local"},
  "MessageTemplate",
  BaseStyle->"MSG"]], "Message",
 CellChangeTimes->{
  3.9930320790718956`*^9, 3.993032251398056*^9, 3.9930322822753944`*^9, {
   3.9930324118990536`*^9, 3.9930324260735474`*^9}, 3.9930325235003166`*^9, 
