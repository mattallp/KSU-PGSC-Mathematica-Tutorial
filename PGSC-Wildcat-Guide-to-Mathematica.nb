Cell[CellGroupData[{

Cell["Vector Fields", "Subsubsection",
 CellChangeTimes->{{3.993727652163608*^9, 3.993727664994814*^9}, {
  3.993727701523086*^9, 3.993727792476852*^9}, {3.993728390192707*^9, 
  3.993728395816805*^9}, {3.993731257165557*^9, 
  3.993731281272141*^9}},ExpressionUUID->"140e90e7-3be7-4908-9caf-\
b18e66855454"],

Cell[TextData[{
 StyleBox["VectorPlot ",
  FontWeight->"Bold"],
 "and ",
 StyleBox["StreamPlot ",
  FontWeight->"Bold"],
 "are useful for displaying vector fields:"
}], "Text",
 CellChangeTimes->{{3.993727652163608*^9, 3.993727664994814*^9}, {
   3.993727701523086*^9, 3.993727792476852*^9}, {3.993728390192707*^9, 
   3.993728395816805*^9}, 
   3.9937314261895638`*^9},ExpressionUUID->"91d5df0a-f838-4819-89a3-\
c435bbb9a2b8"],

Cell[BoxData[{
 RowBox[{"Clear", "[", "\"\<`*\>\"", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Efield", "[", 
     RowBox[{"x_", ",", "y_"}], "]"}], "=", " ", 
    RowBox[{
     FractionBox["1", 
      SuperscriptBox[
       RowBox[{"Sqrt", "[", 
        RowBox[{
         SuperscriptBox["x", "2"], "+", 
         SuperscriptBox["y", "2"]}], "]"}], "3"]], 
     RowBox[{"{", 
      RowBox[{"x", ",", "y"}], "}"}]}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "a", " ", "simple", " ", "2", "D", " ", "Electric", " ", "field", " ", 
    "for", " ", "a", " ", "positive", " ", "charge", " ", "at", " ", "the", " ",
     "origin"}], "*)"}], " "}], "\[IndentingNewLine]", 
 RowBox[{"VectorPlot", "[", 
  RowBox[{
   RowBox[{"Efield", "[", 
    RowBox[{"x", ",", "y"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"y", ",", 
     RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.9937283984965897`*^9, 3.993728447893001*^9}, {
  3.993728478721654*^9, 3.993728492093466*^9}, {3.993728527322275*^9, 
  3.993728646167223*^9}, {3.9937286823633757`*^9, 3.9937287005315723`*^9}, {
  3.9937287310640182`*^9, 3.9937287372478437`*^9}, {3.993728840721058*^9, 
  3.993728873056954*^9}, {3.993728971261861*^9, 3.993728971825761*^9}, {
  3.993729818972867*^9, 3.993729832528307*^9}},
 CellLabel->
  "In[113]:=",ExpressionUUID->"e487d6b8-b471-48d7-bc00-244e59bfadb5"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"V", "[", 
     RowBox[{"x_", ",", "y_"}], "]"}], "=", " ", 
    RowBox[{
     SuperscriptBox["x", "2"], "+", 
     SuperscriptBox["y", "2"]}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"A", " ", "simple", " ", "2", "D", " ", "potential"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"GradV", "[", 
     RowBox[{"x_", ",", "y_"}], "]"}], "=", " ", 
    RowBox[{"Grad", "[", 
     RowBox[{
      RowBox[{"V", "[", 
       RowBox[{"x", ",", "y"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "y"}], "}"}]}], "]"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"get", " ", "the", " ", "gradient", " ", "of", " ", "V"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"StreamPlot", "[", 
   RowBox[{
    RowBox[{"-", 
     RowBox[{"GradV", "[", 
      RowBox[{"x", ",", "y"}], "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "4"}], ",", "4"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"y", ",", 
      RowBox[{"-", "4"}], ",", "4"}], "}"}]}], "]"}], "  ", 
  RowBox[{"(*", 
   RowBox[{"Plot", " ", "of", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{"-", "\[Del]", 
          StyleBox["V", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
      "-\\nabla V", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"]}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.993727652163608*^9, 3.993727664994814*^9}, {
  3.993727701523086*^9, 3.9937278729134197`*^9}, {3.9937279283211823`*^9, 
  3.993727958325507*^9}, {3.9937280462345657`*^9, 3.993728222195719*^9}, {
  3.993728292606051*^9, 3.993728359709262*^9}, {3.993728634875688*^9, 
  3.993728636190793*^9}},
 CellLabel->
  "In[104]:=",ExpressionUUID->"7c9744a5-debd-4049-950d-de85708f97e0"],

Cell["There is also a 3D version of both of these", "Text",
 CellChangeTimes->{{3.993731814166113*^9, 
  3.993731839342368*^9}},ExpressionUUID->"3c998a8e-a363-473c-a2c0-\
6c11f28d0001"],

Cell[BoxData[{
 RowBox[{"Clear", "[", "\"\<`*\>\"", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Efield3D", "[", 
     RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], "=", " ", 
    RowBox[{
     FractionBox["1", 
      SuperscriptBox[
       RowBox[{"Sqrt", "[", 
        RowBox[{
         SuperscriptBox["x", "2"], "+", 
         SuperscriptBox["y", "2"]}], "]"}], "3"]], 
     RowBox[{"{", 
      RowBox[{"x", ",", "y", ",", "z"}], "}"}]}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "a", " ", "simple", " ", "3", "D", " ", "Electric", " ", "field", " ", 
    "for", " ", "a", " ", "positive", " ", "charge", " ", "at", " ", "the", " ",
     "origin"}], "*)"}], " "}], "\[IndentingNewLine]", 
 RowBox[{"VectorPlot3D", "[", 
  RowBox[{
   RowBox[{"Efield3D", "[", 
    RowBox[{"x", ",", "y", ",", "z"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"y", ",", 
     RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"z", ",", 
     RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.993731814166113*^9, 3.993731911977868*^9}},
 CellLabel->
  "In[267]:=",ExpressionUUID->"d46f3b47-4b53-43b9-b48e-b8f7078f2444"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"V", "[", 
     RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], "=", " ", 
    RowBox[{
     SuperscriptBox["x", "2"], "+", 
     SuperscriptBox["y", "2"], "+", 
     SuperscriptBox["z", "2"]}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"A", " ", "simple", " ", "3", "D", " ", "potential"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
