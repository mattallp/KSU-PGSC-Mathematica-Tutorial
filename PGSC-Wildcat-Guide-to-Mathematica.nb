Cell[BoxData[
 RowBox[{
  RowBox[{"24", " ", "r", " ", 
   RowBox[{"Cos", "[", "phi", "]"}]}], "+", 
  RowBox[{"6", " ", 
   SuperscriptBox[
    RowBox[{"Cos", "[", "phi", "]"}], "2"], " ", 
   RowBox[{"Sin", "[", "theta", "]"}]}], "+", 
  FractionBox[
   RowBox[{
    RowBox[{"12", " ", 
     SuperscriptBox["r", "2"], " ", 
     RowBox[{"Cos", "[", "phi", "]"}]}], "+", 
    RowBox[{"3", " ", "r", " ", 
     SuperscriptBox[
      RowBox[{"Cos", "[", "phi", "]"}], "2"], " ", 
     RowBox[{"Sin", "[", "theta", "]"}]}]}], "r"], "+", 
  RowBox[{
   FractionBox["1", "r"], 
   RowBox[{
    RowBox[{"Csc", "[", "theta", "]"}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"3", " ", "r", " ", 
       SuperscriptBox[
        RowBox[{"Cos", "[", "phi", "]"}], "2"], " ", 
       SuperscriptBox[
        RowBox[{"Cos", "[", "theta", "]"}], "2"]}], "+", 
      RowBox[{
       RowBox[{"Sin", "[", "theta", "]"}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"12", " ", 
          SuperscriptBox["r", "2"], " ", 
          RowBox[{"Cos", "[", "phi", "]"}]}], "+", 
         RowBox[{"6", " ", "r", " ", 
          SuperscriptBox[
           RowBox[{"Cos", "[", "phi", "]"}], "2"], " ", 
          RowBox[{"Sin", "[", "theta", "]"}]}]}], ")"}]}], "+", 
      FractionBox[
       RowBox[{
        RowBox[{"Csc", "[", "theta", "]"}], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"-", "4"}], " ", 
           SuperscriptBox["r", "3"], " ", 
           RowBox[{"Cos", "[", "phi", "]"}]}], "-", 
          RowBox[{"6", " ", 
           SuperscriptBox["r", "2"], " ", 
           SuperscriptBox[
            RowBox[{"Cos", "[", "phi", "]"}], "2"], " ", 
           RowBox[{"Sin", "[", "theta", "]"}]}], "+", 
          RowBox[{"6", " ", 
           SuperscriptBox["r", "2"], " ", 
           SuperscriptBox[
            RowBox[{"Sin", "[", "phi", "]"}], "2"], " ", 
           RowBox[{"Sin", "[", "theta", "]"}]}]}], ")"}]}], "r"]}], 
     ")"}]}]}]}]], "Output",
 CellChangeTimes->{
  3.976969985156231*^9, {3.976970196092327*^9, 3.9769702633744698`*^9}, 
