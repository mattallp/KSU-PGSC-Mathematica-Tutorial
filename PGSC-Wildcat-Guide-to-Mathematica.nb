Cell[CellGroupData[{

Cell["Complex Functions", "Subsubsection",
 CellChangeTimes->{{3.9937324680912037`*^9, 
  3.993732478255817*^9}},ExpressionUUID->"abc7029f-d59f-43cc-bbde-\
9f804731c0f5"],

Cell[TextData[{
 "For complex functions, you can use ",
 StyleBox["Re ",
  FontWeight->"Bold"],
 "and ",
 StyleBox["Im ",
  FontWeight->"Bold"],
 "to extract the imaginry and real components of complex numbers to plot \
separately:"
}], "Text",
 CellChangeTimes->{{3.9937324680912037`*^9, 3.9937324885863657`*^9}, {
  3.993732553155079*^9, 
  3.9937326339476357`*^9}},ExpressionUUID->"4d82f9d2-10a8-4baf-ad86-\
a9a87ebf8ed1"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Re", "[", 
       RowBox[{"E", "^", 
        RowBox[{"(", 
         RowBox[{"I", " ", "\[Theta]"}], ")"}]}], "]"}], ",", 
      RowBox[{"Im", "[", 
       RowBox[{"E", "^", 
        RowBox[{"(", 
         RowBox[{"I", " ", "\[Theta]"}], ")"}]}], "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"\[Theta]", ",", 
      RowBox[{"-", "\[Pi]"}], ",", "\[Pi]"}], "}"}], ",", 
    RowBox[{"PlotLegends", "->", "\"\<Expressions\>\""}]}], "]"}], "  ", 
  RowBox[{"(*", 
   RowBox[{"ends", " ", "up", " ", "plotting", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{"cos", "\[Theta]"}], TraditionalForm], "errors" -> {}, 
      "input" -> "\\cos \\theta", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " ", "and", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{"sin", "\[Theta]"}], TraditionalForm], "errors" -> {}, 
      "input" -> "\\sin \\theta", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"]}], 
   "*)"}]}], "\[IndentingNewLine]", "Compl"}], "Input",
 CellChangeTimes->{{3.9937324680912037`*^9, 3.9937324885863657`*^9}, {
