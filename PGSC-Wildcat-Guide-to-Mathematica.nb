e2943a3c3f55"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"change", " ", "the", " ", "values", " ", "of", " ", "a"}], ",", 
    " ", 
    RowBox[{"b", " ", "and", " ", "c"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"a", "=", "2"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"b", "=", "0"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"c", "=", "0"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"h", "[", "x", "]"}], "  ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{
      "still", " ", "prints", " ", "out", " ", "the", " ", "function", " ", 
       "h", 
       RowBox[{"(", "x", ")"}], " ", "with", " ", "a"}], "=", "1"}], ",", " ", 
     RowBox[{"b", "=", "2"}], ",", " ", 
