   RowBox[{"{", 
    RowBox[{
     RowBox[{"0.11469418665021275`", "\[VeryThinSpace]", "-", 
      RowBox[{"0.2935871648960677`", " ", "\[ImaginaryI]"}]}], ",", 
     RowBox[{"0.4257795876577188`", "\[VeryThinSpace]", "+", 
      RowBox[{"0.12207382458537919`", " ", "\[ImaginaryI]"}]}], ",", 
     RowBox[{
      RowBox[{"-", "0.04538247181393319`"}], "-", 
