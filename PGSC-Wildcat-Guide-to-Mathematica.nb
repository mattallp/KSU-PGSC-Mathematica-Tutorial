Cell[CellGroupData[{

Cell["Solution", "Subsubsection",
 CellChangeTimes->{{3.9769710228876305`*^9, 
  3.9769710239671936`*^9}},ExpressionUUID->"d8ea7d50-5472-8047-b946-\
afa5b3fe007c"],

Cell["\<\
I can define the function using the pre-built Mathematica functions for the \
Bessel functions\
\>", "Text",
 CellChangeTimes->{{3.9769710286825657`*^9, 3.9769710496889496`*^9}, {
  3.976971125860815*^9, 
  3.9769711293880024`*^9}},ExpressionUUID->"804b1edf-869f-4246-b0b5-\
caea2047acd8"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "\"\<`*\>\"", "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Clear", " ", "all", " ", "definitions"}], "*)"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", "x_", "]"}], " ", "=", " ", 
   RowBox[{
    RowBox[{"BesselJ", "[", 
     RowBox[{"0", ",", "x"}], "]"}], "-", " ", 
    RowBox[{"BesselY", "[", 
     RowBox[{"0", ",", "x"}], "]"}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9769710228876305`*^9, 3.976971161954649*^9}, {
  3.9769712601524277`*^9, 3.9769712605005474`*^9}},
 CellLabel->"In[22]:=",ExpressionUUID->"156aa3d5-30b5-1048-afaf-6de4402fe6a0"],

Cell[TextData[{
 "There are a couple of ways I can find the first zero, if I use the FindRoot \
command, I need to specify where I want the to look by defining ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        SubscriptBox[
         StyleBox["x", "TI"], "0"], TraditionalForm], "errors" -> {}, "input" -> 
      "x_0", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], "."}], TraditionalForm]],ExpressionUUID->
  "a865c44d-d75c-4f40-9bcb-1216969d8f6f"],
 " Since I know that the function is singular at ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "x=0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c637d44b-7d49-6948-97ab-db8e319f1f32"],
 ", I will chose ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["x", "TI"], "\[LongEqual]", "0.1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "x=0.1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "cd4c5b70-3950-b040-aac7-0aa190560792"],
 " "
}], "Text",
 CellChangeTimes->{{3.9769711666026955`*^9, 3.9769711899008923`*^9}, {
  3.9769712696529274`*^9, 
  3.9769713543242683`*^9}},ExpressionUUID->"7165b2d5-4d99-4940-ac31-\
0f41abb230be"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FindRoot", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"f", "[", "x", "]"}], "==", "0"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0.01"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9769711666026955`*^9, 3.976971201232458*^9}, {
  3.9769712481400967`*^9, 3.9769712551563854`*^9}},
 CellLabel->"In[24]:=",ExpressionUUID->"758a6d89-1f33-6b4b-880e-a84fa2d14890"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"x", "\[Rule]", "1.6385599102938413`"}], "}"}]], "Output",
 CellChangeTimes->{
  3.9769712022031307`*^9, {3.9769712507764397`*^9, 3.976971255720356*^9}, 
   3.9775016934143753`*^9},
 CellLabel->"Out[24]=",ExpressionUUID->"b6b4f4b5-5067-084d-994f-3bfe8e524192"]
}, Open  ]],

