Cell["\<\
You can also define vector functions and perform various differential \
operators on both scalar and vector functions. Mathematica can also handle \
differential operators in different coordinate systems, but you need to \
specify them.\
\>", "Text",
 CellChangeTimes->{{3.9769693594324837`*^9, 3.976969405824705*^9}, {
   3.9769697637984505`*^9, 3.9769697762382603`*^9}, {3.976969837419836*^9, 
   3.9769698455114613`*^9}, {3.976969901678999*^9, 3.9769699594948444`*^9}, 
   3.9769703206257534`*^9},ExpressionUUID->"b8975ce2-b9f0-7546-95e7-\
d7f33124e5e0"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"G", "[", 
     RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       SuperscriptBox["y", "2"], " ", "+", " ", "z"}], ",", " ", 
      SuperscriptBox["x", "3"], ",", " ", 
      RowBox[{"3", "y"}]}], " ", "}"}]}], " ", ";"}], 
  RowBox[{"(*", 
   RowBox[{"define", " ", "a", " ", "vector", " ", "function"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"h", "[", 
     RowBox[{"r_", ",", "theta_", ",", "phi_"}], "]"}], " ", "=", " ", 
    RowBox[{
     RowBox[{"3", 
      SuperscriptBox["r", "2"], 
      SuperscriptBox[
       RowBox[{"Cos", "[", "phi", "]"}], "2"], 
      RowBox[{"Sin", "[", "theta", "]"}]}], " ", "+", " ", 
     RowBox[{"4", 
      SuperscriptBox["r", "3"], 
      RowBox[{"Cos", "[", "phi", "]"}]}]}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "define", " ", "a", " ", "scalar", " ", "function", " ", "in", " ", 
    "spherical", " ", "coordinates"}], "*)"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Grad", "[", 
   RowBox[{
    RowBox[{"h", "[", 
     RowBox[{"r", ",", "theta", ",", "phi"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"r", ",", "theta", ",", "phi"}], "}"}], 
    ",", "\"\<Spherical\>\""}], "]"}], 
  RowBox[{"(*", "Gradient", "*)"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Curl", "[", 
   RowBox[{
    RowBox[{"G", "[", 
     RowBox[{"x", ",", "y", ",", "z"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "y", ",", "z"}], "}"}]}], "]"}], 
  RowBox[{"(*", "Curl", "*)"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Div", "[", 
   RowBox[{
    RowBox[{"G", "[", 
     RowBox[{"x", ",", "y", ",", "z"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "y", ",", "z"}], "}"}]}], "]"}], 
  RowBox[{"(*", "Divergence", "*)"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Laplacian", "[", 
   RowBox[{
    RowBox[{"h", "[", 
     RowBox[{"r", ",", "theta", ",", "phi"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"r", ",", "theta", ",", "phi"}], "}"}], 
    ",", "\"\<Spherical\>\""}], "]"}], " ", 
  RowBox[{"(*", "Laplacian", "*)"}]}]}], "Input",
 CellChangeTimes->{{3.9769693594324837`*^9, 3.976969407300665*^9}, {
  3.976969847118271*^9, 3.9769698972021885`*^9}, {3.976969962842108*^9, 
  3.9769703093069744`*^9}},ExpressionUUID->"059b9c85-213e-b049-ada4-\
f5169da903fd"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"12", " ", 
     SuperscriptBox["r", "2"], " ", 
     RowBox[{"Cos", "[", "phi", "]"}]}], "+", 
    RowBox[{"6", " ", "r", " ", 
     SuperscriptBox[
      RowBox[{"Cos", "[", "phi", "]"}], "2"], " ", 
     RowBox[{"Sin", "[", "theta", "]"}]}]}], ",", 
   RowBox[{"3", " ", "r", " ", 
    SuperscriptBox[
     RowBox[{"Cos", "[", "phi", "]"}], "2"], " ", 
    RowBox[{"Cos", "[", "theta", "]"}]}], ",", 
   FractionBox[
    RowBox[{
     RowBox[{"Csc", "[", "theta", "]"}], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "4"}], " ", 
        SuperscriptBox["r", "3"], " ", 
        RowBox[{"Sin", "[", "phi", "]"}]}], "-", 
       RowBox[{"6", " ", 
        SuperscriptBox["r", "2"], " ", 
        RowBox[{"Cos", "[", "phi", "]"}], " ", 
        RowBox[{"Sin", "[", "phi", "]"}], " ", 
        RowBox[{"Sin", "[", "theta", "]"}]}]}], ")"}]}], "r"]}], 
  "}"}]], "Output",
 CellChangeTimes->{
  3.976969985156231*^9, {3.976970196092327*^9, 3.9769702633744698`*^9}, 
   3.9769702990995827`*^9},
 CellLabel->
  "Out[163]=",ExpressionUUID->"006f9e93-95e7-1f4e-b81f-d4971138eb06"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"3", ",", "1", ",", 
   RowBox[{
    RowBox[{"3", " ", 
     SuperscriptBox["x", "2"]}], "-", 
    RowBox[{"2", " ", "y"}]}]}], "}"}]], "Output",
 CellChangeTimes->{
  3.976969985156231*^9, {3.976970196092327*^9, 3.9769702633744698`*^9}, 
   3.976970299103592*^9},
 CellLabel->
  "Out[164]=",ExpressionUUID->"d4e7b1a5-ed45-8c48-b104-384ae2510e6c"],

Cell[BoxData["0"], "Output",
 CellChangeTimes->{
  3.976969985156231*^9, {3.976970196092327*^9, 3.9769702633744698`*^9}, 
   3.9769702991055927`*^9},
 CellLabel->
  "Out[165]=",ExpressionUUID->"a0ab4f90-2058-f643-82a6-761455f0b882"],

Cell[BoxData[
 RowBox[{
  RowBox[{"24", " ", "r", " ", 
   RowBox[{"Cos", "[", "phi", "]"}]}], "+", 
  RowBox[{"6", " ", 
   SuperscriptBox[
    RowBox[{"Cos", "[", "phi", "]"}], "2"], " ", 
   RowBox[{"Sin", "[", "theta", "]"}]}], "+", 
  FractionBox[
   RowBox[{
    RowBox[{"12", " ", 
     SuperscriptBox["r", "2"], " ", 
     RowBox[{"Cos", "[", "phi", "]"}]}], "+", 
    RowBox[{"3", " ", "r", " ", 
     SuperscriptBox[
      RowBox[{"Cos", "[", "phi", "]"}], "2"], " ", 
     RowBox[{"Sin", "[", "theta", "]"}]}]}], "r"], "+", 
  RowBox[{
   FractionBox["1", "r"], 
   RowBox[{
    RowBox[{"Csc", "[", "theta", "]"}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"3", " ", "r", " ", 
       SuperscriptBox[
        RowBox[{"Cos", "[", "phi", "]"}], "2"], " ", 
       SuperscriptBox[
        RowBox[{"Cos", "[", "theta", "]"}], "2"]}], "+", 
      RowBox[{
       RowBox[{"Sin", "[", "theta", "]"}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"12", " ", 
          SuperscriptBox["r", "2"], " ", 
          RowBox[{"Cos", "[", "phi", "]"}]}], "+", 
         RowBox[{"6", " ", "r", " ", 
          SuperscriptBox[
           RowBox[{"Cos", "[", "phi", "]"}], "2"], " ", 
          RowBox[{"Sin", "[", "theta", "]"}]}]}], ")"}]}], "+", 
      FractionBox[
       RowBox[{
        RowBox[{"Csc", "[", "theta", "]"}], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"-", "4"}], " ", 
           SuperscriptBox["r", "3"], " ", 
           RowBox[{"Cos", "[", "phi", "]"}]}], "-", 
          RowBox[{"6", " ", 
           SuperscriptBox["r", "2"], " ", 
           SuperscriptBox[
            RowBox[{"Cos", "[", "phi", "]"}], "2"], " ", 
           RowBox[{"Sin", "[", "theta", "]"}]}], "+", 
          RowBox[{"6", " ", 
           SuperscriptBox["r", "2"], " ", 
           SuperscriptBox[
            RowBox[{"Sin", "[", "phi", "]"}], "2"], " ", 
           RowBox[{"Sin", "[", "theta", "]"}]}]}], ")"}]}], "r"]}], 
     ")"}]}]}]}]], "Output",
 CellChangeTimes->{
  3.976969985156231*^9, {3.976970196092327*^9, 3.9769702633744698`*^9}, 
   3.976970299161148*^9},
 CellLabel->
  "Out[166]=",ExpressionUUID->"74dd77f4-16d7-5b48-9e0b-15e7cec8d5e6"]
}, Open  ]],

Cell[TextData[{
 "Being able to define functions in this way can be very helpful. Especially \
when it comes to creating nice plots, we will get to more of plotting in \
section III. \n\nAt this point, I also want to introduce you to a slightly \
different way to declare functions and variables using ",
 StyleBox["SetDelayed , ",
  FontWeight->"Bold"],
 "or the colon-equals (:=)  command.  With a normal equals sign, you cannot \
edit your function in any way once you have defined it. For example, suppose \
I have some quadratic polynomial ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["h", "TI"], 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}], "\[LongEqual]", 
         StyleBox["a", "TI"], 
         SuperscriptBox[
          StyleBox["x", "TI"], "2"], "+", 
         StyleBox["b", "TI"], 
         StyleBox["x", "TI"], "+", 
         StyleBox["c", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "h(x) = ax^2 + bx + c", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c928e2ef-e52e-3f46-aa87-0b7ebba8b164"],
 ". Where a, b, and c, are some constants. If I define the function first \
using equals (=), and then make changes to the constants, I the function will \
not change unitl I re-define it:"
}], "Text",
 CellChangeTimes->{{3.9769703275681095`*^9, 3.9769705158493385`*^9}, {
   3.976970645160671*^9, 3.976970742818342*^9}, {3.9769709209860477`*^9, 
   3.9769710108886166`*^9}, {3.976971416332304*^9, 3.976971419872059*^9}, 
   3.976971487787777*^9, {3.9772463042085876`*^9, 3.9772463056383553`*^9}, {
   3.977247239015276*^9, 3.977247343866049*^9}, {3.9772474233519287`*^9, 
   3.977247503522436*^9}, {3.977247536900219*^9, 3.9772476890582485`*^9}, {
   3.9772477217548714`*^9, 3.977247726900057*^9}, {3.977247770072487*^9, 
   3.977247770638674*^9}, {3.977247910907074*^9, 3.977248043123289*^9}, {
   3.9772480813347607`*^9, 3.9772482902495937`*^9}, {3.9772483698047256`*^9, 
   3.97724837634095*^9}, {3.9772484517469463`*^9, 
   3.97724848013591*^9}},ExpressionUUID->"e2c3cabc-6ce5-4044-b0bf-\
a5a7feed209c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"a", ",", "b", ",", "c", ",", "h"}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Clear", " ", "variable", " ", "names"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"give", " ", "a"}], ",", " ", "b", " ", ",", " ", 
    RowBox[{"and", " ", "c", " ", "values"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"a", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"b", "=", "2"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"c", "=", "3"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"h", "[", "x_", "]"}], "=", " ", 
   RowBox[{
    RowBox[{"a", " ", 
     SuperscriptBox["x", "2"]}], " ", "+", " ", 
    RowBox[{"b", " ", "x"}], " ", "+", " ", "c"}]}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"define", " ", "a", " ", "function", " ", "h", 
     RowBox[{"(", "x", ")"}], " ", "using"}], " ", "="}], 
   "*)"}]}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.9769703275681095`*^9, 3.9769705158493385`*^9}, {
   3.976970645160671*^9, 3.976970742818342*^9}, {3.9769709209860477`*^9, 
   3.9769710108886166`*^9}, {3.976971416332304*^9, 3.976971419872059*^9}, 
   3.976971487787777*^9, {3.9772463042085876`*^9, 3.9772463056383553`*^9}, {
   3.977247239015276*^9, 3.977247343866049*^9}, {3.9772474233519287`*^9, 
   3.977247473277939*^9}, {3.9772476906771297`*^9, 3.97724770105245*^9}, {
   3.9772477768814793`*^9, 3.97724778093503*^9}, 3.9772478168907585`*^9, {
   3.9772479051503563`*^9, 3.9772479055279064`*^9}, {3.9772481894924145`*^9, 
   3.9772482128869457`*^9}, {3.9772482496772614`*^9, 3.977248252417925*^9}, {
   3.977248292280636*^9, 3.9772484307885857`*^9}, {3.9772484844161625`*^9, 
   3.9772485168590527`*^9}, {3.9772489108033085`*^9, 3.977248915242872*^9}, {
   3.977248982501713*^9, 
   3.9772490204500847`*^9}},ExpressionUUID->"8065fc15-71f1-8144-82c4-\
e2943a3c3f55"],

