Cell["You can also use % to for the last evaluated output: ", "Text",
 CellChangeTimes->{{3.9762780974851513`*^9, 3.9762781580402584`*^9}, {
  3.9762783660041714`*^9, 
  3.9762783798192825`*^9}},ExpressionUUID->"30026d73-d81c-464e-916d-\
f9788c083f4c"],

