Cell["\<\
You can also define vector functions and perform various differential \
operators on both scalar and vector functions. Mathematica can also handle \
differential operators in different coordinate systems, but you need to \
specify them.\
\>", "Text",
 CellChangeTimes->{{3.9769693594324837`*^9, 3.976969405824705*^9}, {
   3.9769697637984505`*^9, 3.9769697762382603`*^9}, {3.976969837419836*^9, 
   3.9769698455114613`*^9}, {3.976969901678999*^9, 3.9769699594948444`*^9}, 
   3.9769703206257534`*^9},ExpressionUUID->"b8975ce2-b9f0-7546-95e7-\
d7f33124e5e0"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"G", "[", 
     RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       SuperscriptBox["y", "2"], " ", "+", " ", "z"}], ",", " ", 
      SuperscriptBox["x", "3"], ",", " ", 
      RowBox[{"3", "y"}]}], " ", "}"}]}], " ", ";"}], 
  RowBox[{"(*", 
   RowBox[{"define", " ", "a", " ", "vector", " ", "function"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"h", "[", 
     RowBox[{"r_", ",", "theta_", ",", "phi_"}], "]"}], " ", "=", " ", 
    RowBox[{
     RowBox[{"3", 
      SuperscriptBox["r", "2"], 
      SuperscriptBox[
       RowBox[{"Cos", "[", "phi", "]"}], "2"], 
      RowBox[{"Sin", "[", "theta", "]"}]}], " ", "+", " ", 
     RowBox[{"4", 
      SuperscriptBox["r", "3"], 
      RowBox[{"Cos", "[", "phi", "]"}]}]}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "define", " ", "a", " ", "scalar", " ", "function", " ", "in", " ", 
    "spherical", " ", "coordinates"}], "*)"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Grad", "[", 
   RowBox[{
    RowBox[{"h", "[", 
     RowBox[{"r", ",", "theta", ",", "phi"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"r", ",", "theta", ",", "phi"}], "}"}], 
    ",", "\"\<Spherical\>\""}], "]"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Gradient", " ", "in", " ", "Spherical", " ", "coordinates"}], ",",
     " ", 
    RowBox[{
    "note", " ", "that", " ", "the", " ", "second", " ", "coordinate", " ", 
     "is", " ", "the", " ", "polar", " ", "angle"}], ",", " ", 
    RowBox[{
    "and", " ", "the", " ", "third", " ", "coordinate", " ", "is", " ", "the",
      " ", "azimuthal", " ", "angle"}]}], "*)"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Curl", "[", 
   RowBox[{
    RowBox[{"G", "[", 
     RowBox[{"x", ",", "y", ",", "z"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "y", ",", "z"}], "}"}]}], "]"}], 
  RowBox[{"(*", "Curl", "*)"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Div", "[", 
   RowBox[{
    RowBox[{"G", "[", 
     RowBox[{"x", ",", "y", ",", "z"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "y", ",", "z"}], "}"}]}], "]"}], 
  RowBox[{"(*", "Divergence", "*)"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Laplacian", "[", 
   RowBox[{
    RowBox[{"h", "[", 
     RowBox[{"r", ",", "theta", ",", "phi"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"r", ",", "theta", ",", "phi"}], "}"}], 
    ",", "\"\<Spherical\>\""}], "]"}], " ", 
  RowBox[{"(*", "Laplacian", "*)"}]}]}], "Input",
 CellChangeTimes->{{3.9769693594324837`*^9, 3.976969407300665*^9}, {
  3.976969847118271*^9, 3.9769698972021885`*^9}, {3.976969962842108*^9, 
  3.9769703093069744`*^9}, {3.993726375160446*^9, 3.993726390240438*^9}, {
  3.9937264569132032`*^9, 
  3.993726466793331*^9}},ExpressionUUID->"059b9c85-213e-b049-ada4-\
f5169da903fd"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"12", " ", 
     SuperscriptBox["r", "2"], " ", 
     RowBox[{"Cos", "[", "phi", "]"}]}], "+", 
    RowBox[{"6", " ", "r", " ", 
     SuperscriptBox[
      RowBox[{"Cos", "[", "phi", "]"}], "2"], " ", 
     RowBox[{"Sin", "[", "theta", "]"}]}]}], ",", 
   RowBox[{"3", " ", "r", " ", 
    SuperscriptBox[
     RowBox[{"Cos", "[", "phi", "]"}], "2"], " ", 
    RowBox[{"Cos", "[", "theta", "]"}]}], ",", 
   FractionBox[
    RowBox[{
     RowBox[{"Csc", "[", "theta", "]"}], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "4"}], " ", 
        SuperscriptBox["r", "3"], " ", 
        RowBox[{"Sin", "[", "phi", "]"}]}], "-", 
       RowBox[{"6", " ", 
        SuperscriptBox["r", "2"], " ", 
        RowBox[{"Cos", "[", "phi", "]"}], " ", 
        RowBox[{"Sin", "[", "phi", "]"}], " ", 
        RowBox[{"Sin", "[", "theta", "]"}]}]}], ")"}]}], "r"]}], 
  "}"}]], "Output",
 CellChangeTimes->{
  3.976969985156231*^9, {3.976970196092327*^9, 3.9769702633744698`*^9}, 
   3.9769702990995827`*^9},
 CellLabel->
  "Out[163]=",ExpressionUUID->"006f9e93-95e7-1f4e-b81f-d4971138eb06"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"3", ",", "1", ",", 
   RowBox[{
    RowBox[{"3", " ", 
     SuperscriptBox["x", "2"]}], "-", 
    RowBox[{"2", " ", "y"}]}]}], "}"}]], "Output",
 CellChangeTimes->{
  3.976969985156231*^9, {3.976970196092327*^9, 3.9769702633744698`*^9}, 
