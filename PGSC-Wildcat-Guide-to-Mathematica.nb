  3.9935596265365467`*^9}},ExpressionUUID->"5ef4d05b-9636-4974-b7c7-\
db3f59be9337"],

Cell[CellGroupData[{

Cell["Plot Options for Formatting", "Subsubsection",
 CellChangeTimes->{{3.9935563172115993`*^9, 3.9935563208605137`*^9}, {
  3.993556355006337*^9, 3.993556390729535*^9}, {3.99355648461032*^9, 
  3.993556519554565*^9}, {3.9935565648952007`*^9, 3.993556805221444*^9}, {
  3.9935569908153*^9, 3.993556995691362*^9}, {3.9935570700554237`*^9, 
  3.9935571032403812`*^9}, {3.993557148613353*^9, 3.993557176313101*^9}, {
  3.993557207273381*^9, 3.99355723406155*^9}, {3.9935572648942127`*^9, 
  3.993557346366622*^9}, {3.99355769774207*^9, 3.993557827639187*^9}, {
  3.993557922876432*^9, 3.993558025205161*^9}, {3.99355811790648*^9, 
  3.9935584250831833`*^9}, {3.993558496269965*^9, 3.9935585502784233`*^9}, {
  3.993559211765052*^9, 3.993559260109558*^9}, {3.9935595277959843`*^9, 
  3.993559557572011*^9}},ExpressionUUID->"2a4fe017-0dd1-4a16-bbde-\
333db13bd47a"],

Cell[TextData[{
 "Here are a list of plot options that may be useful to tidy up plots, you \
will have to check the documentation to see what values are appropriate for \
each option.\n\t",
 StyleBox["PlotRange: ",
  FontWeight->"Bold"],
 "Allows you to change how much of the plot you can see within the plot \
window",
 "\n\t",
 StyleBox["PlotLabel: ",
  FontWeight->"Bold"],
 "Gives the plot an overall label\n\t",
 StyleBox["LabelStyle: ",
  FontWeight->"Bold"],
 "Allows you to edit the font of the label\n\t",
 StyleBox["PlotLabels: ",
  FontWeight->"Bold"],
 "Individually labels each function plotted\n\t",
 StyleBox["ColorFunction: ",
  FontWeight->"Bold"],
 "Changes the plot color based on the values of the function\n\t",
 StyleBox["AxesLabel: ",
  FontWeight->"Bold"],
 "Labels the axes\n\t",
 StyleBox["AxesStyle: ",
  FontWeight->"Bold"],
 "Allows you change the style of the axes\n\t",
 StyleBox["PlotStyle: ",
  FontWeight->"Bold"],
 "Allows you to edit the color, thickness, plot points, and style with which \
Mathematica plots the function\n\t",
 StyleBox["PlotLegends: ",
  FontWeight->"Bold"],
 "Creates a Legend for the plot\n\t",
 StyleBox["Background: ",
  FontWeight->"Bold"],
 "Allows you to change the color of the background\n\t",
 StyleBox["Ticks: ",
  FontWeight->"Bold"],
 "Allows you to change the plot ticks and scale along the axes\n\t",
 StyleBox["Frame: ",
  FontWeight->"Bold"],
 "Puts a frame around the plot\n\t",
 StyleBox["FrameLabel: ",
  FontWeight->"Bold"],
 "Allows you to label the frame\n\t",
 StyleBox["FrameTicks: ",
  FontWeight->"Bold"],
 "Allows you to change the Frame ticks\n\t",
 StyleBox["FrameStyle: ",
  FontWeight->"Bold"],
 "Allows you change the style of the frame\n\t",
 StyleBox["GridLines: ",
  FontWeight->"Bold"],
 "Allows you to put gridlines on your plots"
}], "Text",
 CellChangeTimes->{{3.9935563172115993`*^9, 3.9935563208605137`*^9}, {
  3.993556355006337*^9, 3.993556390729535*^9}, {3.99355648461032*^9, 
  3.993556519554565*^9}, {3.9935565648952007`*^9, 3.993556805221444*^9}, {
  3.9935569908153*^9, 3.993556995691362*^9}, {3.9935570700554237`*^9, 
  3.9935571032403812`*^9}, {3.993557148613353*^9, 3.993557176313101*^9}, {
  3.993557207273381*^9, 3.99355723406155*^9}, {3.9935572648942127`*^9, 
  3.993557346366622*^9}, {3.99355769774207*^9, 3.993557827639187*^9}, {
  3.993557922876432*^9, 3.993558025205161*^9}, {3.99355811790648*^9, 
  3.9935584250831833`*^9}, {3.993558496269965*^9, 3.9935585502784233`*^9}, {
  3.993559211765052*^9, 3.993559260109558*^9}, {3.9935595277959843`*^9, 
  3.993559528540181*^9}},ExpressionUUID->"2eeae750-3e9b-4682-a5b4-\
e6424cd39091"],

Cell["\<\
Below are some examples of what can be done with some of these plot options, \
feel free to mess around with the values or add your own to see how it works\
\>", "Text",
 CellChangeTimes->{{3.9935563172115993`*^9, 3.9935563208605137`*^9}, {
  3.993556355006337*^9, 3.993556390729535*^9}, {3.99355648461032*^9, 
  3.993556519554565*^9}, {3.9935565648952007`*^9, 3.993556805221444*^9}, {
  3.9935569908153*^9, 3.993556995691362*^9}, {3.9935570700554237`*^9, 
  3.9935571032403812`*^9}, {3.993557148613353*^9, 3.993557176313101*^9}, {
  3.993557207273381*^9, 3.99355723406155*^9}, {3.9935572648942127`*^9, 
  3.993557346366622*^9}, {3.99355769774207*^9, 3.993557827639187*^9}, {
  3.993557922876432*^9, 3.993558025205161*^9}, {3.99355811790648*^9, 
  3.993558445835081*^9}, {3.993558703507763*^9, 
  3.9935587193039427`*^9}},ExpressionUUID->"500f2590-9db3-4af3-9241-\
68ffd8cce53b"],

Cell[BoxData[{
 RowBox[{
  StyleBox[
   RowBox[{"Clear", "[", "\"\<`*\>\"", "]"}],
   FontWeight->"Bold"], 
  StyleBox[" ",
   FontWeight->"Bold"], 
  StyleBox[
   RowBox[{
    StyleBox[
     RowBox[{"(", "*"}]], 
    RowBox[{"clear", " ", "all", " ", "variables"}], 
    StyleBox[
     RowBox[{"*", ")"}]]}],
   FontWeight->"Bold"], "\n", " ", 
  RowBox[{"(*", 
   RowBox[{"Some", " ", "user", " ", "defined", " ", "functions"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", "x_", "]"}], ":=", " ", 
   RowBox[{
    RowBox[{"Exp", "[", "x", "]"}], 
    RowBox[{"Sin", "[", "x", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"g", "[", "x_", "]"}], ":=", " ", 
   RowBox[{
    RowBox[{"Exp", "[", 
     RowBox[{"-", "x"}], "]"}], 
    RowBox[{"Cos", "[", "x", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"h", "[", "x_", "]"}], ":=", " ", 
   RowBox[{
    RowBox[{"Sin", "[", "x", "]"}], 
    RowBox[{"Cos", "[", "x", "]"}]}]}], 
  ";"}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.9935563172115993`*^9, 3.9935563208605137`*^9}, {
  3.993556355006337*^9, 3.993556390729535*^9}, {3.99355648461032*^9, 
  3.993556519554565*^9}, {3.9935565648952007`*^9, 3.993556805221444*^9}, {
  3.9935569908153*^9, 3.993556995691362*^9}, {3.9935570700554237`*^9, 
  3.9935571032403812`*^9}, {3.993557148613353*^9, 3.993557176313101*^9}, {
  3.993557207273381*^9, 3.99355723406155*^9}, {3.9935572648942127`*^9, 
  3.993557346366622*^9}, {3.99355769774207*^9, 3.993557827639187*^9}, {
  3.993557922876432*^9, 3.993558025205161*^9}, {3.99355811790648*^9, 
  3.993558493529809*^9}, {3.993558553754777*^9, 3.993558591371956*^9}, {
  3.99355864938378*^9, 3.993558664143907*^9}},
 CellLabel->"In[54]:=",ExpressionUUID->"86982b36-f9c0-40d0-b861-a02c3b4c232d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"f", "[", "x", "]"}], ",", 
     RowBox[{"g", "[", "x", "]"}], ",", 
     RowBox[{"h", "[", "x", "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "\[Pi]"}], ",", "\[Pi]"}], "}"}], ",", 
   RowBox[{"PlotRange", "->", "Automatic"}], ",", 
   RowBox[{"Background", "->", "White"}], ",", 
   RowBox[{"PlotLegends", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<f(x)\>\"", ",", "\"\<g(x)\>\"", ",", "\"\<h(x)\>\""}], 
     "}"}]}], ",", 
   RowBox[{"PlotStyle", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"Red", ",", "Dashed"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"Blue", ",", "Dotted"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"Green", ",", "Thick"}], "}"}]}], "}"}]}], ",", " ", 
   RowBox[{"AxesLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<x\>\"", ",", "\"\<y\>\""}], "}"}]}], ",", 
   RowBox[{"AxesStyle", "->", 
    RowBox[{"Directive", "[", 
     RowBox[{"Black", ",", " ", "Bold"}], "]"}]}], ",", " ", 
   RowBox[{"PlotLabel", "->", "\"\<Plot of some Functions\>\""}], ",", " ", 
   RowBox[{"LabelStyle", "->", 
    RowBox[{"Directive", "[", 
     RowBox[{"Bold", ",", " ", "Black"}], "]"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.993558667915593*^9, 
  3.9935589299705067`*^9}},ExpressionUUID->"4a4ce593-112e-49df-a900-\
774f52ab053f"],

