Cell[TextData[{
 "While it is nice that Mathematica changes the color of each function, in \
this particular case it is kind of difficult to tell which function is which \
without some careful thought. Fortunately, we can make use of plot options to \
label the different functions. To implement plot options, we have to include \
them after the domain specification, separate each option by a comma, and and \
use the arrow syntax as follows: \n",
 StyleBox["Plot[",
  FontWeight->"Bold"],
 "<function and domain info>, PlotOption1 -> <value1>, PlotOption2 -> \
<value2>, ...",
 StyleBox["]",
  FontWeight->"Bold"],
 ". \nAs an example, we will use the PlotLegends option on the previous plot."
}], "Text",
 CellChangeTimes->{{3.9935563172115993`*^9, 3.9935563208605137`*^9}, {
  3.993556355006337*^9, 3.993556390729535*^9}, {3.99355648461032*^9, 
  3.993556519554565*^9}, {3.9935565648952007`*^9, 3.993556805221444*^9}, {
  3.9935569908153*^9, 3.993556995691362*^9}, {3.9935570700554237`*^9, 
  3.9935571032403812`*^9}, {3.993557148613353*^9, 3.993557176313101*^9}, {
  3.993557207273381*^9, 3.99355723406155*^9}, {3.9935572648942127`*^9, 
  3.993557347172842*^9}, {3.99355740469923*^9, 3.99355740680333*^9}, {
  3.993557467752137*^9, 3.993557469847991*^9}, {3.993557549048712*^9, 
  3.993557576893153*^9}, {3.993557621289606*^9, 
  3.993557629393517*^9}},ExpressionUUID->"f887ab90-4aff-422d-b830-\
90588974af5f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"f", "[", "x", "]"}], ",", 
      RowBox[{"g", "[", "x", "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
    RowBox[{"PlotLegends", "->", 
     RowBox[{"{", 
      RowBox[{"\"\<f(x)\>\"", ",", "\"\<g(x)\>\""}], "}"}]}]}], "]"}], 
  " "}]], "Input",
 CellChangeTimes->{{3.9935563172115993`*^9, 3.9935563208605137`*^9}, {
  3.993556355006337*^9, 3.993556390729535*^9}, {3.99355648461032*^9, 
