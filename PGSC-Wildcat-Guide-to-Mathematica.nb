Cell["\<\
Note that Mathematica will still evaluate the expression even if your rule \
contains parameters which don\[CloseCurlyQuote]t appear in the expression. \
\>", "Text",
 CellChangeTimes->{{3.977501181897558*^9, 
  3.9775012120599365`*^9}},ExpressionUUID->"cba7e896-f8fd-974b-87df-\
5ac0dc5a0190"],

Cell[TextData[{
 "For a more applicable example, suppose I am working with the magnitude of \
some electric field . I can store the constants I might use in a rule and use \
",
 StyleBox["Replace",
  FontWeight->"Bold"],
 " to numerically evaluate the field :"
}], "Text",
 CellChangeTimes->{{3.976971517887455*^9, 3.9769715485208187`*^9}, {
   3.977246450772932*^9, 3.9772464720028763`*^9}, {3.977246506341463*^9, 
   3.9772465256877575`*^9}, {3.9772465826819305`*^9, 
   3.9772465923542633`*^9}, {3.9772467009793205`*^9, 
   3.9772467306122875`*^9}, {3.9772469127315025`*^9, 3.977246913995699*^9}, {
   3.977248711276884*^9, 3.977248712647888*^9}, {3.977499002884161*^9, 
   3.9774990612660713`*^9}, {3.977499157212118*^9, 3.9774992336241016`*^9}, {
   3.977499282336191*^9, 3.9774993933641186`*^9}, {3.977499579120455*^9, 
   3.977499669025341*^9}, {3.977499733389925*^9, 3.977499762194748*^9}, {
   3.9774998636875153`*^9, 3.9774998780355167`*^9}, 3.9774999284575176`*^9, {
   3.977499978770628*^9, 3.977500198657345*^9}, {3.977500241249569*^9, 
   3.9775003362474537`*^9}, {3.9775007740549164`*^9, 
   3.9775007933427944`*^9}, {3.9775009255265503`*^9, 
   3.9775009418910103`*^9}},ExpressionUUID->"61356ab5-f3c7-184c-afff-\
9b6eb20ae328"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"MagEField", "[", "r_", "]"}], " ", "=", "  ", 
   RowBox[{"k", " ", 
    FractionBox["q", 
     SuperscriptBox["r", "2"]]}]}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Define", " ", "the", " ", "magnitude", " ", "of", " ", "the", " ", 
    "electric", " ", "field"}], "*)"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"EMrule", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"k", " ", "->", " ", 
       RowBox[{"8.99", " ", "*", 
        SuperscriptBox["10", "9"]}]}], " ", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"Coulomb", "'"}], "s", " ", "constant", " ", "in", " ", "N", " ", 
        RowBox[{
         RowBox[{"m", "^", "2"}], "/", 
         RowBox[{"C", "^", "2"}]}]}], "*)"}], ",", " ", 
      RowBox[{"q", " ", "->", " ", 
       RowBox[{"1.60218", "*", " ", 
        SuperscriptBox["10", 
         RowBox[{"-", "19"}]]}]}]}], " ", 
     RowBox[{"(*", 
      RowBox[{"elementary", " ", "charge", " ", "in", " ", "Coulombs"}], 
      "*)"}], "}"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "create", " ", "a", " ", "list", " ", "of", " ", "replacement", " ", 
    "rules", " ", "for", " ", "the", " ", "constants"}], "*)"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"MagEField", "[", "0.1", "]"}], "/.", " ", "EMrule", " ", 
  RowBox[{"(*", 
   RowBox[{
   "calculate", " ", "the", " ", "magnitude", " ", "of", " ", "the", " ", 
    "magnetic", " ", "field", " ", "at", " ", "0.1", "m", " ", "with", " ", 
    "above", " ", "constants"}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.976971517887455*^9, 3.9769715485208187`*^9}, {
   3.977246450772932*^9, 3.9772464720028763`*^9}, {3.977246506341463*^9, 
   3.9772465256877575`*^9}, {3.9772465826819305`*^9, 
   3.9772465923542633`*^9}, {3.9772467009793205`*^9, 
   3.9772467306122875`*^9}, {3.9772469127315025`*^9, 3.977246913995699*^9}, {
   3.977248711276884*^9, 3.977248712647888*^9}, {3.977499002884161*^9, 
   3.9774990612660713`*^9}, {3.977499157212118*^9, 3.9774992336241016`*^9}, {
   3.977499282336191*^9, 3.9774993933641186`*^9}, {3.977499579120455*^9, 
   3.977499669025341*^9}, {3.977499733389925*^9, 3.977499762194748*^9}, {
   3.9774998636875153`*^9, 3.9774998780355167`*^9}, 3.9774999284575176`*^9, {
   3.977499978770628*^9, 3.9775001745150604`*^9}, {3.9775002361394005`*^9, 
   3.9775002364979343`*^9}, {3.977500289484129*^9, 3.9775003032953663`*^9}, {
   3.9775003402407913`*^9, 3.9775004124782066`*^9}, {3.977500444837631*^9, 
   3.977500497114916*^9}, {3.977500576656889*^9, 3.9775006452013626`*^9}, {
   3.9775006975095367`*^9, 3.9775007666322517`*^9}},
 CellLabel->"In[8]:=",ExpressionUUID->"60b2fac5-2ff4-9440-b62d-04b0f6c9d0de"],

Cell[BoxData[
 FractionBox[
  RowBox[{"k", " ", "q"}], 
  SuperscriptBox["r", "2"]]], "Output",
 CellChangeTimes->{{3.9775007140457*^9, 3.9775007191841526`*^9}, {
  3.9775007617655144`*^9, 3.9775007677755203`*^9}},
 CellLabel->"Out[8]=",ExpressionUUID->"583f10f6-8ff7-a741-a7f7-aa3a4cdadfbe"],

Cell[BoxData["1.4403598199999997`*^-7"], "Output",
 CellChangeTimes->{{3.9775007140457*^9, 3.9775007191841526`*^9}, {
  3.9775007617655144`*^9, 3.9775007677775383`*^9}},
