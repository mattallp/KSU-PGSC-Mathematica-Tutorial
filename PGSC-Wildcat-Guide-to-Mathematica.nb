Cell[CellGroupData[{

Cell["Units in Mathematica", "Subsection",
 CellChangeTimes->{{3.9930421196751003`*^9, 3.993042131298155*^9}, 
   3.993042675870617*^9},ExpressionUUID->"8931a446-edc1-6940-a74e-\
438190ea0c10"],

Cell[TextData[{
 "To end this section, we are going to go over how you can use units in \
Mathematica. Mathematica has a lot of built-in units. The way you can make \
use of them is using the ",
 StyleBox["Quantity[<Magnitude>,\[CloseCurlyDoubleQuote]<UnitName>\
\[CloseCurlyDoubleQuote]]",
  FontWeight->"Bold"],
 " command:"
}], "Text",
 CellChangeTimes->{{3.9930426814403973`*^9, 3.9930427706030807`*^9}, {
  3.993550239525461*^9, 3.993550350522292*^9}, {3.993550576644125*^9, 
  3.9935506003044853`*^9}},ExpressionUUID->"9ec542e5-6e1e-204c-8a6e-\
c44a40a1bcf7"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Clear", "[", "\"\<`*\>\"", "]"}], "\[IndentingNewLine]", 
 RowBox[{"m", " ", "=", " ", 
  RowBox[{"Quantity", "[", 
   RowBox[{"10", ",", "\"\<Kilograms\>\""}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{"define", " ", "a", " ", "mass", " ", "of", " ", "10", " ", "kg"}],
    "*)"}]}]}], "Input",
 CellChangeTimes->{{3.9930421196751003`*^9, 3.993042131298155*^9}, {
   3.99304267641881*^9, 3.9930426764218216`*^9}, {3.993550357226639*^9, 
   3.993550390546649*^9}, 3.993550447865651*^9, {3.993550544812284*^9, 
   3.993550594592575*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"12295900-d459-2b48-a479-84ed23a4ebaf"],

Cell[BoxData[
 TemplateBox[{"10", "\"kg\"", "kilograms", "\"Kilograms\""},
  "Quantity"]], "Output",
 CellChangeTimes->{3.99355060235504*^9},
 CellLabel->"Out[3]=",ExpressionUUID->"84cc99eb-8e63-48a5-b736-63f2b3dfd45d"]
}, Open  ]],

Cell["\<\
Mathematica can use compound units and will correctly handle units when doing \
calculations. It can even handle unit conversions:\
\>", "Text",
 CellChangeTimes->{{3.993550606837721*^9, 3.99355065867667*^9}, {
  3.993550751650008*^9, 3.9935507526175623`*^9}, {3.993550944507321*^9, 
  3.993550982855563*^9}},ExpressionUUID->"0856a809-bac5-4407-bffd-\
454f40d4cdd7"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"g", " ", "=", " ", 
  RowBox[{"Quantity", "[", 
   RowBox[{"32.2", ",", 
    RowBox[{"\"\<Feet\>\"", "/", 
     RowBox[{"\"\<Seconds\>\"", "^", "2"}]}]}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Define", " ", "the", " ", "acceleration", " ", "due", " ", "to", " ", 
    "gravity", " ", "on", " ", "Earth", " ", "to", " ", "be", " ", "32.2", " ", 
    RowBox[{"ft", "/", 
     SuperscriptBox["s", "2"]}]}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.993550606837721*^9, 3.99355065867667*^9}, {
  3.993550751650008*^9, 3.9935507526175623`*^9}, {3.993550944507321*^9, 
  3.993550950369297*^9}, {3.9935509859397984`*^9, 3.993551151902301*^9}, {
  3.9935514164995604`*^9, 
  3.993551418807437*^9}},ExpressionUUID->"b939ea2c-cf3d-4a29-bfc5-\
4323b9907a5b"],

Cell[BoxData[
 TemplateBox[{"32.2`", 
   RowBox[{"\"ft\"", "\[InvisibleSpace]", "\"/\"", "\[InvisibleSpace]", 
     SuperscriptBox["\"s\"", "2"]}], "feet per second squared", 
   FractionBox["\"Feet\"", 
    SuperscriptBox["\"Seconds\"", "2"]]},
  "Quantity"]], "Output",
 CellChangeTimes->{3.993551256881415*^9},
 CellLabel->"Out[7]=",ExpressionUUID->"0729424e-deb1-4093-a5ba-fcd40040131a"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Convert", " ", "g", " ", "to", " ", 
    RowBox[{"m", "/", 
     SuperscriptBox["s", "2"]}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"UnitConvert", "[", 
   RowBox[{"g", ",", " ", 
    RowBox[{"\"\<Meters\>\"", "/", 
     SuperscriptBox["\"\<Seconds\>\"", "2"]}]}], "]"}], " "}]], "Input",
 CellChangeTimes->{{3.993550606837721*^9, 3.99355065867667*^9}, {
  3.993550751650008*^9, 3.9935507526175623`*^9}, {3.993550944507321*^9, 
  3.993550950369297*^9}, {3.9935509859397984`*^9, 3.993551151902301*^9}},
 CellLabel->"In[8]:=",ExpressionUUID->"bdaee71e-7c31-4b5d-84c9-d8d9ff0b7b15"],

Cell[BoxData[
 TemplateBox[{"9.814560000000002`", 
   RowBox[{"\"m\"", "\[InvisibleSpace]", "\"/\"", "\[InvisibleSpace]", 
     SuperscriptBox["\"s\"", "2"]}], "meters per second squared", 
   FractionBox["\"Meters\"", 
    SuperscriptBox["\"Seconds\"", "2"]]},
  "Quantity"]], "Output",
 CellChangeTimes->{3.99355125842913*^9},
 CellLabel->"Out[8]=",ExpressionUUID->"867badaf-9299-4ef5-9bbf-3477ea0a6e9b"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Calculate", " ", "the", " ", "weight", " ", "of", " ", "a", " ", "10", " ",
     "kg", " ", "mass", " ", "on", " ", "Earth"}], "*)"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"weight", " ", "=", " ", 
    RowBox[{"m", " ", "g"}]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Convert", " ", "the", " ", "weight", " ", "to", " ", "Newtons", " ", 
     "and", " ", "pounds"}], "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"UnitConvert", "[", 
    RowBox[{"weight", ",", "\"\<Newtons\>\""}], "]"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"UnitConvert", "[", 
    RowBox[{"weight", ",", "\"\<PoundsForce\>\""}], "]"}], 
   "\[IndentingNewLine]"}]}]], "Input",
 CellChangeTimes->{{3.993551157026698*^9, 3.9935512503474483`*^9}, {
  3.993551301450753*^9, 3.993551305350593*^9}, {3.9935514076995783`*^9, 
