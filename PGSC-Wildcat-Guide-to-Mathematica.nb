Cell[BoxData["4.4221683864024034`*^-12"], "Output",
 CellChangeTimes->{
  3.993032079105564*^9, 3.9930322514103336`*^9, 3.9930322822884617`*^9, {
   3.9930324119065742`*^9, 3.9930324260806694`*^9}, 3.993032523514778*^9, 
