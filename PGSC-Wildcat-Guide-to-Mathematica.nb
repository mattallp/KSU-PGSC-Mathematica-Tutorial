}, Open  ]],

Cell["\<\
The replace command is also useful because a lot of pre-built Mathematica \
functions return rules as output. A previous exercise asked you to find the \
zero of a function, below I have copied the solution \
\>", "Text",
 CellChangeTimes->{{3.97750144813628*^9, 
  3.9775015938621674`*^9}},ExpressionUUID->"9d140e11-123b-b54a-ab92-\
e33db59bb950"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "\"\<`*\>\"", "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Clear", " ", "variables"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"f", "[", "x_", "]"}], " ", "=", " ", 
    RowBox[{
     RowBox[{"BesselJ", "[", 
      RowBox[{"0", ",", "x"}], "]"}], "-", " ", 
     RowBox[{"BesselY", "[", 
      RowBox[{"0", ",", "x"}], "]"}]}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Define", " ", "function"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"FindRoot", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"f", "[", "x", "]"}], "==", "0"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0.01"}], "}"}]}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Find", " ", "the", " ", "first", " ", "order", " ", "zero"}], 
   "*)"}]}]}], "Input",
 CellChangeTimes->{{3.97750144813628*^9, 3.977501643576782*^9}},
 CellLabel->"In[19]:=",ExpressionUUID->"a970316b-d87f-054c-a29b-88d01ff82e9c"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"x", "\[Rule]", "1.6385599102938413`"}], "}"}]], "Output",
 CellChangeTimes->{3.9775016495896835`*^9, 3.977501683244793*^9},
 CellLabel->"Out[21]=",ExpressionUUID->"312ddca6-478a-9943-a55a-6c7030103bcc"]
}, Open  ]],

Cell["\<\
Notice Mathematica returned a rule as the output. We can use the replace \
command to access this value for a function. We can check to make sure this \
is actually a zero of the function, or evaluate the derivative:\
\>", "Text",
 CellChangeTimes->{{3.9775016530513077`*^9, 3.9775016658254547`*^9}, {
  3.977501705144327*^9, 3.977501724112566*^9}, {3.9775019195970936`*^9, 
  3.9775019806330376`*^9}},ExpressionUUID->"4c47e023-63c4-3e41-818e-\
02eaced00058"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", "x", "]"}], "/.", " ", 
   RowBox[{"FindRoot", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"f", "[", "x", "]"}], "==", "0"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0.01"}], "}"}]}], "]"}]}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Check", " ", "to", " ", "make", " ", "sure", " ", "this", " ", "is", " ", 
    "actually", " ", "a", " ", "zero"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"f", "'"}], "[", "x", "]"}], "/.", " ", 
  RowBox[{"FindRoot", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"f", "[", "x", "]"}], "==", "0"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0.01"}], "}"}]}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Calculate", " ", "the", " ", "derivative", " ", "at", " ", "the", " ", 
    "zero"}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.9775016530513077`*^9, 3.9775016658254547`*^9}, {
  3.977501705144327*^9, 3.977501724112566*^9}, {3.9775019195970936`*^9, 
  3.9775020134278374`*^9}, {3.977502115951721*^9, 3.977502122019497*^9}},
 CellLabel->"In[25]:=",ExpressionUUID->"64b096aa-23b2-0044-8e78-e05aaa86d7d9"],

Cell[BoxData["0.`"], "Output",
 CellChangeTimes->{3.977502123781809*^9},
 CellLabel->"Out[25]=",ExpressionUUID->"83e56916-3f9a-144d-926f-b788d9c8d8eb"],

Cell[BoxData[
 RowBox[{"-", "0.8965443882007487`"}]], "Output",
 CellChangeTimes->{3.977502123783329*^9},
 CellLabel->"Out[26]=",ExpressionUUID->"33c4db56-99b6-e542-b953-2ba67e3b1eed"]
}, Open  ]]
}, Closed]],

Cell[CellGroupData[{

Cell["Prefix and Postfix", "Subsection",
 CellChangeTimes->{{3.977501463759281*^9, 
  3.977501467544937*^9}},ExpressionUUID->"ccee3404-fda7-8e4c-b34d-\
7ab758fd8048"],

Cell["We can also evaluate functions using prefix notation (@). ", "Text",
 CellChangeTimes->{{3.977501253556959*^9, 3.9775013849455357`*^9}, {
  3.977502191117384*^9, 3.9775022021061134`*^9}, {3.977502267057829*^9, 
  3.977502276237734*^9}, {3.9775024008281307`*^9, 
  3.9775024094834213`*^9}},ExpressionUUID->"8d67cf4e-4bbb-2b41-bbbd-\
ab2f48ebb479"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "f", "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Clear", " ", "the", " ", "function", " ", "f"}], "*)"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", "x_", "]"}], "=", " ", 
   RowBox[{"x", "^", "3"}]}], " ", 
  RowBox[{"(*", 
   RowBox[{"Define", " ", "the", " ", "function"}], " ", "*)"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"f", "@", "3", " ", 
  RowBox[{"(*", 
   RowBox[{"Evaluate", " ", "the", " ", "function", " ", "at", " ", "3"}], 
   "*)"}]}]}], "Input",
 CellChangeTimes->{{3.977501253556959*^9, 3.9775013849455357`*^9}, {
  3.977502191117384*^9, 
  3.977502282241827*^9}},ExpressionUUID->"76c2a718-5a38-924b-bc8a-\
e1dfef6be9e6"],

Cell[BoxData[
 SuperscriptBox["x", "3"]], "Output",
 CellChangeTimes->{3.977502242583023*^9, 3.9929447857088547`*^9},
 CellLabel->"Out[28]=",ExpressionUUID->"7f95bc88-3f32-624c-aa58-850f39cbc4a4"],

Cell[BoxData["27"], "Output",
 CellChangeTimes->{3.9775022425860443`*^9, 3.992944785709854*^9},
 CellLabel->"Out[29]=",ExpressionUUID->"33fdb713-173f-d840-80e2-8cb880bcc332"]
}, Open  ]],

Cell["\<\
The line \[OpenCurlyDoubleQuote]f@3\[CloseCurlyDoubleQuote] can be read as \
\[OpenCurlyDoubleQuote]the function, f ,evaluated at \
3\[CloseCurlyDoubleQuote].  This, of course, isn\[CloseCurlyQuote]t much \
different than just doing f[3]. However, when used in conjunction with \
\[OpenCurlyDoubleQuote]nameless\[CloseCurlyDoubleQuote], or pure, functions \
they can become much more useful. A nameless function is exactly what it \
sounds like, it is a function which was not previously defined and therefore \
doesn\[CloseCurlyQuote]t have a name. These functions use # to denote \
variables and & to denote where they end:\
\>", "Text",
 CellChangeTimes->{{3.977502285008751*^9, 3.9775023174789276`*^9}, {
  3.9775023747886333`*^9, 3.9775023819248543`*^9}, {3.977502414614393*^9, 
  3.9775025370820084`*^9}, {3.9775027435809727`*^9, 3.9775027479375095`*^9}, {
  3.977502788881592*^9, 3.9775027944553585`*^9}, {3.977502842440834*^9, 
  3.9775028897712536`*^9}},ExpressionUUID->"f7fb092c-165f-9044-8450-\
cde9f3fee91e"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"(", 
   RowBox[{
    SuperscriptBox["2", "#1"], "&"}], ")"}], "[", "x", "]"}], "\n", 
 RowBox[{
  RowBox[{"(", 
   RowBox[{
    RowBox[{
     RowBox[{
      SuperscriptBox["#1", "2"], " ", 
      SuperscriptBox["#2", "2"]}], "+", "#3"}], "&"}], ")"}], "[", 
  RowBox[{"x", ",", "y", ",", "z"}], "]"}]}], "Input",
 CellChangeTimes->{{3.977502285008751*^9, 3.9775023174789276`*^9}, {
   3.9775023747886333`*^9, 3.9775023819248543`*^9}, {3.977502414614393*^9, 
