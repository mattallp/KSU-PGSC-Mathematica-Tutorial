Cell[BoxData[
 StyleBox[
  RowBox[{
   RowBox[{"Using", " ", "a", " ", "function", " ", "definition"}], ",", " ", 
   RowBox[{
   "try", " ", "to", " ", "find", " ", "the", " ", "first", " ", "order", " ",
     "zero", " ", "of", " ", "the", " ", "function", " ", 
    FormBox[
     TemplateBox[<|"boxes" -> FormBox[
         RowBox[{
           StyleBox["f", "TI"], 
           RowBox[{"(", 
             StyleBox["x", "TI"], ")"}], "\[LongEqual]", 
           SubscriptBox[
            StyleBox["J", "TI"], "0"], 
           RowBox[{"(", 
             StyleBox["x", "TI"], ")"}], "+", 
           SubscriptBox[
            StyleBox["Y", "TI"], "0"], 
           RowBox[{"(", 
             StyleBox["x", "TI"], ")"}]}], TraditionalForm], "errors" -> {}, 
       "input" -> "f(x) &= J_0(x) + Y_0(x)", "state" -> "Boxes"|>,
      "TeXAssistantTemplate"],
     TraditionalForm], " ", "where", " ", 
    FormBox[
     RowBox[{
      TemplateBox[<|"boxes" -> FormBox[
          SubscriptBox[
           StyleBox["J", "TI"], "0"], TraditionalForm], "errors" -> {}, 
        "input" -> "J_0", "state" -> "Boxes"|>,
       "TeXAssistantTemplate"], " ", "and", " ", 
      TemplateBox[<|"boxes" -> FormBox[
          SubscriptBox[
           StyleBox["Y", "TI"], "0"], TraditionalForm], "errors" -> {}, 
        "input" -> "Y_0", "state" -> "Boxes"|>,
       "TeXAssistantTemplate"]}],
     TraditionalForm], " ", "are", " ", "the", " ", "zeroth", " ", "order", " ",
     "Bessel", " ", "functions", " ", "of", " ", "the", " ", "first", " ", 
    "and", " ", "second", " ", "kind"}], ",", " ", 
   RowBox[{
    RowBox[{"respectively", ".", " ", "You"}], " ", "may", " ", "need", " ", 
    "to", " ", "look", " ", "up", " ", "the", " ", "documentation", " ", "on",
     " ", "the", " ", "commands", " ", 
    StyleBox[
     RowBox[{"BesselJ", "[", "]"}],
     FontWeight->"Bold"]}], 
   StyleBox[",",
    FontWeight->"Bold"], " ", 
   StyleBox[
    RowBox[{"BesselY", "[", "]"}],
    FontWeight->"Bold"], 
   StyleBox[",",
    FontWeight->"Bold"], 
   StyleBox[" ",
    FontWeight->"Bold"], 
   RowBox[{"and", 
    StyleBox[" ",
     FontWeight->"Bold"], 
    RowBox[{
     StyleBox[
      RowBox[{"FindRoot", "[", "]"}],
      FontWeight->"Bold"], ".", " ", "Also"}], " ", "note", " ", "that", " ", 
    "when", " ", "you", " ", "want", " ", "to", " ", "define", " ", "a", " ", 
    "condition"}], ",", " ", 
   RowBox[{
   "you", " ", "need", " ", "to", " ", "use", " ", "a", " ", "double", " ", 
    "equals", " ", "sign", " ", 
    RowBox[{"(", "==", ")"}], " ", "as", " ", "you", " ", "are", " ", "not", " ",
     "trying", " ", "to", " ", "define", " ", "a", " ", "variable"}]}], 
  "Text"]], "Text",
 CellChangeTimes->{{3.9769703275681095`*^9, 3.9769705158493385`*^9}, {
   3.976970645160671*^9, 3.976970742818342*^9}, {3.9769709209860477`*^9, 
