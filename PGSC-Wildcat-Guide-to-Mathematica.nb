   PlotRange->{{0, 216.}, {0, 59.}}]], "Input",ExpressionUUID->
  "31ad11d8-14d4-4901-a82f-8f6b443d0da6"],
 ". Using this you can lookup constants and generate code (though I would be \
wary of the code generation).  You can also write a quantity with units to \
shortcut defining quantities. For example, by typing \
\[OpenCurlyDoubleQuote]permittivity of free space\[CloseCurlyDoubleQuote], I \
can get the constant ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Epsilon]", "0"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "af20fa52-01c6-4b92-9940-007f56cfe4a0"],
 ":"
}], "Text",
 CellChangeTimes->{{3.9935518065639677`*^9, 3.993551873295658*^9}, {
  3.993551923631875*^9, 3.9935519272877417`*^9}, {3.993552009368569*^9, 
  3.99355211007694*^9}, {3.9935521462376013`*^9, 3.9935522776546183`*^9}, {
  3.993552401744166*^9, 3.993552428308004*^9}, {3.993552459278028*^9, 
  3.993552514641099*^9}, {3.993552546179408*^9, 3.993552636429842*^9}, {
  3.9935533197201233`*^9, 
  3.993553381962175*^9}},ExpressionUUID->"aaf2cbe1-dd7f-48d1-88f5-\
8fa201091ddf"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[Epsilon]0", " ", "=", " ", 
  TemplateBox[<|
   "query" -> "permitivity of free space", "boxes" -> TemplateBox[{
       InterpretationBox["\[InvisibleSpace]", 1], 
       SubscriptBox["\"\[CurlyEpsilon]\"", "0"], "electric constants", 
       "\"ElectricConstant\""}, "Quantity", SyntaxForm -> Mod], 
    "allassumptions" -> {}, "assumptions" -> {}, "open" -> {1, 2}, 
    "querystate" -> {
     "Online" -> True, "Allowed" -> True, "mparse.jsp" -> 
      0.808781`6.359375933690094, "Messages" -> {}}, "contextinfo" -> 
    Automatic, "version" -> 5|>,
   "LinguisticAssistantTemplate"], " ", 
  RowBox[{"(*", 
   RowBox[{"permittivity", " ", "of", " ", "free", " ", "space"}], 
   "*)"}]}]], "Input",
 CellChangeTimes->{{3.9935518065639677`*^9, 3.993551873295658*^9}, {
  3.993551923631875*^9, 3.9935519272877417`*^9}, {3.993552009368569*^9, 
  3.99355211007694*^9}, {3.9935521462376013`*^9, 3.9935522339268217`*^9}, {
  3.993552280687258*^9, 3.993552285707417*^9}, {3.993552372067501*^9, 
  3.993552374223783*^9}, {3.993552938096758*^9, 3.9935529440207577`*^9}},
 CellLabel->"In[21]:=",ExpressionUUID->"03e8e410-beeb-40bd-b1b1-53b8201eb533"],

Cell[BoxData[
 TemplateBox[{
   InterpretationBox["\[InvisibleSpace]", 1], 
   SubscriptBox["\"\[CurlyEpsilon]\"", "0"], "electric constant", 
   "\"ElectricConstant\""},
  "Quantity"]], "Output",
 CellChangeTimes->{3.993553420740941*^9},
 CellLabel->"Out[21]=",ExpressionUUID->"884d47ca-ff44-4798-925c-ca5de306d5b2"]
}, Open  ]],

Cell["\<\
And by writing \[OpenCurlyDoubleQuote]10 V\[CloseCurlyDoubleQuote] I can get \
a quantity representing 10 Volts\
\>", "Text",
 CellChangeTimes->{{3.993553374716606*^9, 
  3.993553408672773*^9}},ExpressionUUID->"c2f6d038-20c2-4b71-86c2-\
3b782fd4548d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"V", " ", "=", " ", 
  TemplateBox[<|
   "query" -> "10 V", "boxes" -> 
    TemplateBox[{"10", "\"V\"", "volts", "\"Volts\""}, "Quantity", SyntaxForm -> 
      Mod], "allassumptions" -> {{
      "type" -> "Clash", "word" -> "V", "template" -> 
       "Assuming \"V\" is a unit${separator}Use as ${desc} or ${desc} \
instead", "count" -> "3", "pulldown" -> "false", "default" -> 
       "{\"C\", \"V\"} -> {\"Unit\", \"dflt\"}", 
       "Values" -> {{
         "name" -> "Unit", "desc" -> "a unit", "input" -> 
          "{\"C\", \"V\"} -> {\"Unit\"}"}, {
         "name" -> "Variable", "desc" -> "a variable", "input" -> 
          "{\"C\", \"V\"} -> {\"Variable\"}"}, {
         "name" -> "RomanNumeral", "desc" -> "a roman numeral", "input" -> 
          "{\"C\", \"V\"} -> {\"RomanNumeral\"}"}}}, {
      "type" -> "Unit", "word" -> "V", "template" -> 
       "Assuming volts for \"V\"${separator}Use ${desc} instead", "count" -> 
       "2", "pulldown" -> "false", "default" -> 
       "\"UnitClash\" -> {\"V\", {\"Volts\", \"dflt\"}}", 
       "Values" -> {{
         "name" -> "Volts", "desc" -> "volts", "input" -> 
          "\"UnitClash\" -> {\"V\", {\"Volts\"}}"}, {
         "name" -> "LargeVreebles", "desc" -> "large vreebles", "input" -> 
          "\"UnitClash\" -> {\"V\", {\"LargeVreebles\"}}"}}}}, 
    "assumptions" -> {}, "open" -> {1, 2}, 
    "querystate" -> {
     "Online" -> True, "Allowed" -> True, "mparse.jsp" -> 
      0.66893`6.276925667012215, "Messages" -> {}}, "contextinfo" -> 
    Automatic, "version" -> 5|>,
   "LinguisticAssistantTemplate"]}]], "Input",
 CellChangeTimes->{{3.993553411544979*^9, 3.993553417749071*^9}},
 CellLabel->"In[20]:=",ExpressionUUID->"b3b148ce-95be-483a-be57-6b5fdaa263b2"],

Cell[BoxData[
 TemplateBox[{"10", "\"V\"", "volts", "\"Volts\""},
  "Quantity"]], "Output",
 CellChangeTimes->{3.9935534187177*^9},
 CellLabel->"Out[20]=",ExpressionUUID->"90f875c6-0e26-4b25-8f14-a2885397c275"]
}, Open  ]],

Cell["\<\
Another cool feature of this is that even if you have a typo in what you are \
trying to get, Mathematica may still be able to figure it out. Again, \
however, this is not fool-proof. The check-mark next to the box is their for \
you to confirm that Mathematica\[CloseCurlyQuote]s interpretation of what you \
wrote is correct. There is a large amount of information that Wolfram|Alpha \
has access to, so if there is a constant or something you need, just try \
searching for it in Mathematica:\
\>", "Text",
 CellChangeTimes->{{3.993552638915223*^9, 3.9935526551096888`*^9}, {
  3.9935527333347816`*^9, 
  3.993552885104067*^9}},ExpressionUUID->"aafe237d-90f0-4e85-9511-\
fdc8cc9dbb58"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  TemplateBox[<|"query" -> "Image of a dog", "boxes" -> RowBox[{
       TemplateBox[{"\"dog\"", 
         RowBox[{"Entity", "[", 
           
           RowBox[{"\"TaxonomicSpecies\"", ",", 
             "\"CanisLupusFamiliaris::4t62p\""}], "]"}], 
         "\"Entity[\\\"TaxonomicSpecies\\\", \
\\\"CanisLupusFamiliaris::4t62p\\\"]\"", "\"species specification\""}, 
        "Entity"], "[", 
       TemplateBox[{"\"image\"", 
         RowBox[{"EntityProperty", "[", 
           RowBox[{"\"TaxonomicSpecies\"", ",", "\"Image\""}], "]"}], 
         "\"EntityProperty[\\\"TaxonomicSpecies\\\", \\\"Image\\\"]\""}, 
        "EntityProperty"], "]"}], "allassumptions" -> {}, "assumptions" -> {},
     "open" -> {1, 2}, 
    "querystate" -> {
     "Online" -> True, "Allowed" -> True, "mparse.jsp" -> 
      0.920269`6.415459786210681, "Messages" -> {}}, "contextinfo" -> 
    Automatic, "version" -> 5|>,
   "LinguisticAssistantTemplate"], " ", 
  RowBox[{"(*", 
   RowBox[{
   "This", " ", "is", " ", "what", " ", "happens", " ", "when", " ", "I", " ",
     "ask", " ", "for", " ", "an", " ", "image", " ", "of", " ", "a", " ", 
    "dog"}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.993552638915223*^9, 3.9935526551096888`*^9}, {
  3.9935527333347816`*^9, 3.993552872279923*^9}, {3.9935529472848473`*^9, 
