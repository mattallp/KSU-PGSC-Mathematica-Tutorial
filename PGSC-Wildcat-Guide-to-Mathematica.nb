 CellLabel->"Out[14]=",ExpressionUUID->"569b1c5b-9350-4a77-b2ae-8a35511e251c"]
}, Open  ]],

Cell[TextData[{
 "The unit calculations are not fool-proof however, and sometimes you will \
need will want to just extract the magnitude or the units themselves this can \
be done using the ",
 StyleBox["QuantityMagnitude ",
  FontWeight->"Bold"],
 "and ",
 StyleBox["QuantityUnit ",
  FontWeight->"Bold"],
 "command."
}], "Text",
 CellChangeTimes->{{3.993551340754711*^9, 3.993551342446538*^9}, {
  3.9935513786350317`*^9, 3.993551394430766*^9}, {3.9935514267473927`*^9, 
  3.993551503069446*^9}},ExpressionUUID->"4ec7adff-1600-47af-b8d8-\
5b09c418ccf0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"  ", 
  RowBox[{
   RowBox[{"QuantityMagnitude", "[", "g", "]"}], " ", 
   RowBox[{"(*", 
    RowBox[{"get", " ", "the", " ", "magnitude", " ", "of", " ", "g", " ", 
     RowBox[{"(", "32.2", ")"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"QuantityUnit", "[", "m", "]"}], " ", 
   RowBox[{"(*", 
    RowBox[{"get", " ", "the", " ", "unit", " ", "of", " ", "m", " ", 
     RowBox[{"(", "Kilograms", ")"}]}], "*)"}]}]}]], "Input",
 CellChangeTimes->{{3.993551340754711*^9, 3.993551342446538*^9}, {
  3.9935513786350317`*^9, 3.993551394430766*^9}, {3.9935514267473927`*^9, 
  3.993551556660634*^9}},ExpressionUUID->"5c10f8ac-de1a-4edc-935c-\
292b58f1809e"],

Cell[BoxData["32.2`"], "Output",
 CellChangeTimes->{3.9935515498344603`*^9},
 CellLabel->"Out[15]=",ExpressionUUID->"26dfd23d-f5db-4fbe-8e5a-fbb3e5c41268"],

Cell[BoxData["\<\"Kilograms\"\>"], "Output",
 CellChangeTimes->{3.993551549835539*^9},
 CellLabel->"Out[16]=",ExpressionUUID->"d2390a38-f1fc-4b79-bc61-03b38ce5c345"]
}, Open  ]],

Cell["\<\
You can also define your own units, but that is outside the scope of this \
notebook. \
\>", "Text",
 CellChangeTimes->{{3.993553440654335*^9, 
  3.993553465709321*^9}},ExpressionUUID->"15a1d102-d9dd-4b2b-ad44-\
b53b34496edb"],

