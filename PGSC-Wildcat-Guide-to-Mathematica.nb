   3.9935570535163116`*^9, 3.993557059000352*^9}},
 CellLabel->"In[46]:=",ExpressionUUID->"1e565ed4-8e93-45f2-9901-c65275d29e85"],

Cell[TextData[{
 "You can even plot multiple functions in the same ",
 StyleBox["Plot",
  FontWeight->"Bold"],
 " command:"
}], "Text",
 CellChangeTimes->{{3.993556840203178*^9, 3.993556854005563*^9}, {
  3.993556946807193*^9, 
  3.9935569545404663`*^9}},ExpressionUUID->"5e22706c-07af-4155-86b3-\
dd2ea8115261"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"g", "[", "x_", "]"}], ":=", " ", 
   RowBox[{
    RowBox[{"Cos", "[", 
     RowBox[{"2", "\[Pi]", " ", "x"}], "]"}], " ", "+", " ", 
    RowBox[{"Sin", "[", 
     RowBox[{"\[Pi]", " ", "x"}], "]"}]}]}], " ", 
  RowBox[{"(*", 
   RowBox[{"another", " ", "user", " ", "defined", " ", "function"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"f", "[", "x", "]"}], ",", 
      RowBox[{"g", "[", "x", "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "2"}], ",", "2"}], "}"}]}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"plot", " ", "both", " ", "of", " ", "the", " ", "user"}], "-", 
    RowBox[{"defined", " ", "functions", " ", "together"}]}], 
   "*)"}]}]}], "Input",
 CellChangeTimes->{{3.993556840203178*^9, 3.993556854005563*^9}, {
  3.993556946807193*^9, 3.993557040779697*^9}},
 CellLabel->"In[49]:=",ExpressionUUID->"9261627e-582e-477c-bba8-c6f724907494"],

Cell[TextData[{
 "While it is nice that Mathematica changes the color of each function, in \
this particular case it is kind of difficult to tell which function is which \
without some careful thought. Fortunately, we can make use of plot options to \
label the different functions. To implement plot options, we have to include \
them after the domain specification, separate each option by a comma, and and \
use the arrow syntax as follows: \n",
 StyleBox["Plot[",
  FontWeight->"Bold"],
 "<function and domain info>, PlotOption1 -> <value1>, PlotOption2 -> \
<value2>, ...",
 StyleBox["]",
  FontWeight->"Bold"],
 ". \nAs an example, we will use the PlotLegends option on the previous plot."
}], "Text",
 CellChangeTimes->{{3.9935563172115993`*^9, 3.9935563208605137`*^9}, {
  3.993556355006337*^9, 3.993556390729535*^9}, {3.99355648461032*^9, 
  3.993556519554565*^9}, {3.9935565648952007`*^9, 3.993556805221444*^9}, {
  3.9935569908153*^9, 3.993556995691362*^9}, {3.9935570700554237`*^9, 
  3.9935571032403812`*^9}, {3.993557148613353*^9, 3.993557176313101*^9}, {
  3.993557207273381*^9, 3.99355723406155*^9}, {3.9935572648942127`*^9, 
  3.993557347172842*^9}, {3.99355740469923*^9, 3.99355740680333*^9}, {
  3.993557467752137*^9, 3.993557469847991*^9}, {3.993557549048712*^9, 
  3.993557576893153*^9}, {3.993557621289606*^9, 
  3.993557629393517*^9}},ExpressionUUID->"f887ab90-4aff-422d-b830-\
90588974af5f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"f", "[", "x", "]"}], ",", 
      RowBox[{"g", "[", "x", "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
    RowBox[{"PlotLegends", "->", 
     RowBox[{"{", 
      RowBox[{"\"\<f(x)\>\"", ",", "\"\<g(x)\>\""}], "}"}]}]}], "]"}], 
  " "}]], "Input",
 CellChangeTimes->{{3.9935563172115993`*^9, 3.9935563208605137`*^9}, {
  3.993556355006337*^9, 3.993556390729535*^9}, {3.99355648461032*^9, 
  3.993556519554565*^9}, {3.9935565648952007`*^9, 3.993556805221444*^9}, {
  3.9935569908153*^9, 3.993556995691362*^9}, {3.9935570700554237`*^9, 
  3.9935571032403812`*^9}, {3.993557148613353*^9, 3.993557176313101*^9}, {
  3.993557207273381*^9, 3.99355723406155*^9}, {3.9935572648942127`*^9, 
  3.993557355772551*^9}, {3.9935574221241493`*^9, 3.993557512028625*^9}, {
  3.9935581954998283`*^9, 3.993558198387398*^9}, {3.993558257855788*^9, 
  3.993558271826297*^9}, {3.993558344684746*^9, 
  3.993558354620949*^9}},ExpressionUUID->"96b69643-5513-43fb-a34f-\
42c00dd172c3"],

Cell["\<\
Notice, if you are plotting multiple functions, you can adjust the plot \
option for each function by using a bracketed list { <function1 option val>, \
<function2 function val>, ...}. 
While this is great for trying to visualize plots for personal use, the above \
plot is hardly appropriate to put in a reports, publications, or \
presentations. \
\>", "Text",
 CellChangeTimes->{{3.9935563172115993`*^9, 3.9935563208605137`*^9}, {
  3.993556355006337*^9, 3.993556390729535*^9}, {3.99355648461032*^9, 
  3.993556519554565*^9}, {3.9935565648952007`*^9, 3.993556805221444*^9}, {
  3.9935569908153*^9, 3.993556995691362*^9}, {3.9935570700554237`*^9, 
  3.9935571032403812`*^9}, {3.993557148613353*^9, 3.993557176313101*^9}, {
  3.993557207273381*^9, 3.99355723406155*^9}, {3.9935572648942127`*^9, 
  3.993557346366622*^9}, {3.99355769774207*^9, 3.993557827639187*^9}, {
  3.993557922876432*^9, 3.993558025205161*^9}, {3.99355811790648*^9, 
  3.9935584250831833`*^9}, {3.993558496269965*^9, 3.9935585502784233`*^9}, {
  3.993559211765052*^9, 3.993559260109558*^9}, {3.9935595277959843`*^9, 
  3.993559539706023*^9}, {3.9935595901643467`*^9, 
  3.9935596265365467`*^9}},ExpressionUUID->"5ef4d05b-9636-4974-b7c7-\
db3f59be9337"],

Cell[CellGroupData[{

Cell["Plot Options for Formatting", "Subsubsection",
 CellChangeTimes->{{3.9935563172115993`*^9, 3.9935563208605137`*^9}, {
  3.993556355006337*^9, 3.993556390729535*^9}, {3.99355648461032*^9, 
  3.993556519554565*^9}, {3.9935565648952007`*^9, 3.993556805221444*^9}, {
  3.9935569908153*^9, 3.993556995691362*^9}, {3.9935570700554237`*^9, 
  3.9935571032403812`*^9}, {3.993557148613353*^9, 3.993557176313101*^9}, {
  3.993557207273381*^9, 3.99355723406155*^9}, {3.9935572648942127`*^9, 
  3.993557346366622*^9}, {3.99355769774207*^9, 3.993557827639187*^9}, {
  3.993557922876432*^9, 3.993558025205161*^9}, {3.99355811790648*^9, 
  3.9935584250831833`*^9}, {3.993558496269965*^9, 3.9935585502784233`*^9}, {
  3.993559211765052*^9, 3.993559260109558*^9}, {3.9935595277959843`*^9, 
  3.993559557572011*^9}},ExpressionUUID->"2a4fe017-0dd1-4a16-bbde-\
333db13bd47a"],

Cell[TextData[{
 "Here are a list of plot options that may be useful to tidy up plots, you \
will have to check the documentation to see what values are appropriate for \
each option.\n\t",
 StyleBox["PlotRange: ",
  FontWeight->"Bold"],
 "Allows you to change how much of the plot you can see within the plot \
window",
 "\n\t",
 StyleBox["PlotLabel: ",
  FontWeight->"Bold"],
 "Gives the plot an overall label\n\t",
 StyleBox["LabelStyle: ",
  FontWeight->"Bold"],
 "Allows you to edit the font of the label\n\t",
 StyleBox["PlotLabels: ",
  FontWeight->"Bold"],
 "Individually labels each function plotted\n\t",
 StyleBox["ColorFunction: ",
  FontWeight->"Bold"],
 "Changes the plot color based on the values of the function\n\t",
 StyleBox["AxesLabel: ",
  FontWeight->"Bold"],
 "Labels the axes\n\t",
 StyleBox["AxesStyle: ",
  FontWeight->"Bold"],
 "Allows you change the style of the axes\n\t",
 StyleBox["PlotStyle: ",
  FontWeight->"Bold"],
 "Allows you to edit the color, thickness, plot points, and style with which \
Mathematica plots the function\n\t",
 StyleBox["PlotLegends: ",
  FontWeight->"Bold"],
 "Creates a Legend for the plot\n\t",
 StyleBox["Background: ",
  FontWeight->"Bold"],
 "Allows you to change the color of the background\n\t",
 StyleBox["Ticks: ",
  FontWeight->"Bold"],
 "Allows you to change the plot ticks and scale along the axes\n\t",
 StyleBox["Frame: ",
  FontWeight->"Bold"],
 "Puts a frame around the plot\n\t",
 StyleBox["FrameLabel: ",
  FontWeight->"Bold"],
 "Allows you to label the frame\n\t",
 StyleBox["FrameTicks: ",
  FontWeight->"Bold"],
 "Allows you to change the Frame ticks\n\t",
 StyleBox["FrameStyle: ",
  FontWeight->"Bold"],
 "Allows you change the style of the frame\n\t",
 StyleBox["GridLines: ",
  FontWeight->"Bold"],
 "Allows you to put gridlines on your plots"
}], "Text",
 CellChangeTimes->{{3.9935563172115993`*^9, 3.9935563208605137`*^9}, {
  3.993556355006337*^9, 3.993556390729535*^9}, {3.99355648461032*^9, 
  3.993556519554565*^9}, {3.9935565648952007`*^9, 3.993556805221444*^9}, {
  3.9935569908153*^9, 3.993556995691362*^9}, {3.9935570700554237`*^9, 
  3.9935571032403812`*^9}, {3.993557148613353*^9, 3.993557176313101*^9}, {
  3.993557207273381*^9, 3.99355723406155*^9}, {3.9935572648942127`*^9, 
  3.993557346366622*^9}, {3.99355769774207*^9, 3.993557827639187*^9}, {
  3.993557922876432*^9, 3.993558025205161*^9}, {3.99355811790648*^9, 
  3.9935584250831833`*^9}, {3.993558496269965*^9, 3.9935585502784233`*^9}, {
  3.993559211765052*^9, 3.993559260109558*^9}, {3.9935595277959843`*^9, 
  3.993559528540181*^9}},ExpressionUUID->"2eeae750-3e9b-4682-a5b4-\
e6424cd39091"],

Cell["\<\
Below are some examples of what can be done with some of these plot options, \
feel free to mess around with the values or add your own to see how it works\
\>", "Text",
 CellChangeTimes->{{3.9935563172115993`*^9, 3.9935563208605137`*^9}, {
  3.993556355006337*^9, 3.993556390729535*^9}, {3.99355648461032*^9, 
  3.993556519554565*^9}, {3.9935565648952007`*^9, 3.993556805221444*^9}, {
  3.9935569908153*^9, 3.993556995691362*^9}, {3.9935570700554237`*^9, 
  3.9935571032403812`*^9}, {3.993557148613353*^9, 3.993557176313101*^9}, {
  3.993557207273381*^9, 3.99355723406155*^9}, {3.9935572648942127`*^9, 
  3.993557346366622*^9}, {3.99355769774207*^9, 3.993557827639187*^9}, {
  3.993557922876432*^9, 3.993558025205161*^9}, {3.99355811790648*^9, 
  3.993558445835081*^9}, {3.993558703507763*^9, 
  3.9935587193039427`*^9}},ExpressionUUID->"500f2590-9db3-4af3-9241-\
68ffd8cce53b"],

Cell[BoxData[{
 RowBox[{
  StyleBox[
   RowBox[{"Clear", "[", "\"\<`*\>\"", "]"}],
   FontWeight->"Bold"], 
  StyleBox[" ",
   FontWeight->"Bold"], 
  StyleBox[
   RowBox[{
    StyleBox[
     RowBox[{"(", "*"}]], 
    RowBox[{"clear", " ", "all", " ", "variables"}], 
    StyleBox[
     RowBox[{"*", ")"}]]}],
   FontWeight->"Bold"], "\n", " ", 
  RowBox[{"(*", 
   RowBox[{"Some", " ", "user", " ", "defined", " ", "functions"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", "x_", "]"}], ":=", " ", 
   RowBox[{
    RowBox[{"Exp", "[", "x", "]"}], 
    RowBox[{"Sin", "[", "x", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"g", "[", "x_", "]"}], ":=", " ", 
   RowBox[{
    RowBox[{"Exp", "[", 
     RowBox[{"-", "x"}], "]"}], 
    RowBox[{"Cos", "[", "x", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"h", "[", "x_", "]"}], ":=", " ", 
   RowBox[{
    RowBox[{"Sin", "[", "x", "]"}], 
    RowBox[{"Cos", "[", "x", "]"}]}]}], 
  ";"}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.9935563172115993`*^9, 3.9935563208605137`*^9}, {
  3.993556355006337*^9, 3.993556390729535*^9}, {3.99355648461032*^9, 
  3.993556519554565*^9}, {3.9935565648952007`*^9, 3.993556805221444*^9}, {
  3.9935569908153*^9, 3.993556995691362*^9}, {3.9935570700554237`*^9, 
  3.9935571032403812`*^9}, {3.993557148613353*^9, 3.993557176313101*^9}, {
  3.993557207273381*^9, 3.99355723406155*^9}, {3.9935572648942127`*^9, 
  3.993557346366622*^9}, {3.99355769774207*^9, 3.993557827639187*^9}, {
  3.993557922876432*^9, 3.993558025205161*^9}, {3.99355811790648*^9, 
  3.993558493529809*^9}, {3.993558553754777*^9, 3.993558591371956*^9}, {
  3.99355864938378*^9, 3.993558664143907*^9}},
 CellLabel->"In[54]:=",ExpressionUUID->"86982b36-f9c0-40d0-b861-a02c3b4c232d"],

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"f", "[", "x", "]"}], ",", 
     RowBox[{"g", "[", "x", "]"}], ",", 
     RowBox[{"h", "[", "x", "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "\[Pi]"}], ",", "\[Pi]"}], "}"}], ",", 
   RowBox[{"PlotRange", "->", "Automatic"}], ",", 
   RowBox[{"Background", "->", "White"}], ",", 
   RowBox[{"PlotLegends", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<f(x)\>\"", ",", "\"\<g(x)\>\"", ",", "\"\<h(x)\>\""}], 
     "}"}]}], ",", 
   RowBox[{"PlotStyle", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"Red", ",", "Dashed"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"Blue", ",", "Dotted"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"Green", ",", "Thick"}], "}"}]}], "}"}]}], ",", " ", 
   RowBox[{"AxesLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<x\>\"", ",", "\"\<y\>\""}], "}"}]}], ",", 
   RowBox[{"AxesStyle", "->", 
    RowBox[{"Directive", "[", 
     RowBox[{"Black", ",", " ", "Bold"}], "]"}]}], ",", " ", 
   RowBox[{"PlotLabel", "->", "\"\<Plot of some Functions\>\""}], ",", " ", 
   RowBox[{"LabelStyle", "->", 
    RowBox[{"Directive", "[", 
     RowBox[{"Bold", ",", " ", "Black"}], "]"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.993558667915593*^9, 
  3.9935589299705067`*^9}},ExpressionUUID->"4a4ce593-112e-49df-a900-\
774f52ab053f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"g", "[", "x", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "\[Pi]"}], ",", "\[Pi]"}], "}"}], ",", 
    RowBox[{"PlotRange", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "8"}], ",", "5"}], "}"}]}], ",", 
    RowBox[{"Background", "->", "White"}], ",", 
    RowBox[{"AxesStyle", "->", 
     RowBox[{"Directive", "[", 
      RowBox[{"Black", ",", " ", "Bold"}], "]"}]}], ",", " ", 
    RowBox[{"PlotLabel", "->", "\"\<Plot of a Function\>\""}], ",", " ", 
    RowBox[{"LabelStyle", "->", 
     RowBox[{"Directive", "[", 
      RowBox[{"Bold", ",", " ", "Black"}], "]"}]}], ",", 
    RowBox[{"Frame", "->", "True"}], ",", 
    RowBox[{"FrameStyle", "->", 
     RowBox[{"Directive", "[", 
      RowBox[{"Black", ",", "Bold"}], "]"}]}], ",", 
    RowBox[{"FrameLabel", "->", 
     RowBox[{"{", 
      RowBox[{"\"\<Independent Variable\>\"", ",", 
       " ", "\"\<Dependent Variable\>\""}], "}"}]}], ",", 
    RowBox[{"GridLines", "->", "Automatic"}], ",", 
    RowBox[{"ColorFunction", "->", " ", "\"\<TemperatureMap\>\""}]}], "]"}], 
  "\[IndentingNewLine]"}]], "Input",
 CellChangeTimes->{{3.99355898123486*^9, 3.9935590621519547`*^9}, {
  3.9935591440731077`*^9, 3.9935593407822933`*^9}, {3.993724648762589*^9, 
  3.993724653986656*^9}},ExpressionUUID->"0bf6f2e9-5b39-458d-ab6e-\
9c0cf47cea7c"],

Cell[TextData[{
 "Another thing to keep in mind is the scale of your plots, the command ",
 StyleBox["LogPlot, LogLinearPlot, ",
  FontWeight->"Bold"],
 "and",
 StyleBox[" LogLogPlot, ",
  FontWeight->"Bold"],
 "allow you to use a Logarithmic scale on one or both of the axes: "
}], "Text",
 CellChangeTimes->{{3.9937246028613987`*^9, 
  3.993724708185493*^9}},ExpressionUUID->"57950b82-06bd-42a1-b59a-\
2e2cbd275674"],

Cell[BoxData[
 RowBox[{
  RowBox[{"LogPlot", "[", 
   RowBox[{
    RowBox[{"Exp", "[", "x", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0", ",", "10"}], "}"}]}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"Log", " ", "plot", " ", "scales", " ", "the", " ", "y"}], "-", 
     "axis"}], ",", " ", "logarithmically"}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.9937246028613987`*^9, 3.993724713639654*^9}, {
  3.9937250047812033`*^9, 
  3.99372503377341*^9}},ExpressionUUID->"9a86e84f-87e9-4324-b835-\
baa3ea464f2d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"LogLinearPlot", "[", 
   RowBox[{
    RowBox[{"Log", "[", "x", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0", ",", 
      SuperscriptBox["10", "4"]}], "}"}]}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"LogLinearPlot", " ", "scales", " ", "the", " ", "x"}], "-", 
     "axis"}], ",", " ", "logarithmically"}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.993725045317227*^9, 
  3.993725089849585*^9}},ExpressionUUID->"948c54eb-d75e-46df-bc0c-\
715d818bef52"],

Cell[BoxData[
 RowBox[{
  RowBox[{"LogLogPlot", "[", 
   RowBox[{
    RowBox[{"x", "^", "x"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0.1", ",", "10"}], "}"}]}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"LogLogPlot", " ", "scales", " ", "both", " ", "axes"}], ",", " ",
     "logarithmically"}], "*)"}]}]], "Input",
