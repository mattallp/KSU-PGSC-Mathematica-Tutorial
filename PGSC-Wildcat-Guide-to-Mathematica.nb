   3.993551314867392*^9},
 CellLabel->"Out[13]=",ExpressionUUID->"cc3f4101-79c7-406e-8d5f-af387138c67b"],

Cell[BoxData[
 TemplateBox[{
  "22.064008605886947`", "\"lbf\"", "pounds\[Hyphen]force", "\"PoundsForce\""},
