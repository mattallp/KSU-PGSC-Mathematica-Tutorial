Cell[CellGroupData[{

Cell["Clearing and Suppressing Output", "Subsubsection",
 CellChangeTimes->{{3.9762782124740696`*^9, 3.9762782187110214`*^9}, 
   3.976278405517706*^9, {3.9762784716147175`*^9, 
   3.9762784844114227`*^9}},ExpressionUUID->"dffd3f4a-735a-f24d-9b2e-\
e203f0a28368"],

Cell["\<\
Mathematica will output each and every line of evaluated code. For large data \
sets and complicated numerical calculations, this can be cumbersome. However, \
we can suppress output by using a semi-colon ;

Try evaluating the code below and notice that Mathematica will not generate \
an output cell\
\>", "Text",
 CellChangeTimes->{{3.9762782124740696`*^9, 3.9762782187110214`*^9}, {
  3.9762784346727505`*^9, 3.976278535750786*^9}, {3.9762786409492188`*^9, 
  3.9762786659331207`*^9}, {3.9762787033577366`*^9, 
  3.976278738675272*^9}},ExpressionUUID->"16ce0dfd-e949-7d48-8efc-\
927bb35342ef"],

