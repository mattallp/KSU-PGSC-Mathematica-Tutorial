JgFThYaGBkkG4jIWmIabmpr8/PzIMA2rsStWrCgqKrKzs6PEQGRjgQbGxsbK
yclRbiAEREdHu7u7U8u0UTAKRjIAALoi/bY=
     "], {{0, 21.599999999999998`}, {17.4, 0}}, {0, 255},
     ColorFunction->RGBColor,
     ImageResolution->{120., 120.},
