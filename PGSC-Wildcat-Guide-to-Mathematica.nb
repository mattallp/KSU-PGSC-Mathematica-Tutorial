Cell[TextData[{
 "There are a few things we can do to get around these errors. We can tell \
Mathematica to handle the singularities using the ",
 StyleBox["Exclusions ",
  FontWeight->"Bold"],
 "option",
 ". It might also be helpful to increase the ",
 StyleBox["WorkingPrecision",
  FontWeight->"Bold"],
 " which tells Mathematica how many digits of precision to use during the \
numerical evaluation of the integral, and ",
 StyleBox["AccuracyGoal ",
  FontWeight->"Bold"],
 "which tells Mathematica how many digits of accuracy you want before \
Mathematica accepts the answer. In this case, setting the ",
 StyleBox["WorkingPrecision",
  FontWeight->"Bold"],
 " to 2 and ",
 StyleBox["AccuracyGoal ",
  FontWeight->"Bold"],
 "to 4 will make the integral return zero, which may be more useful than a \
small floating point number if we need to use it in later calculations. Feel \
free to mess with these values to see how it changes how Mathematica \
processes the integral."
}], "Text",
 CellChangeTimes->{{3.993031331601795*^9, 3.9930313908679047`*^9}, {
   3.993031421200657*^9, 3.9930314497134647`*^9}, {3.9930315068363304`*^9, 
   3.9930315567247353`*^9}, {3.993041399258724*^9, 3.993041404368431*^9}, {
   3.9930414623812065`*^9, 3.993041478165289*^9}, {3.9930415239768085`*^9, 
   3.9930416135192738`*^9}, {3.993041648390835*^9, 3.993041749982441*^9}, {
   3.993041931449892*^9, 3.9930419475792713`*^9}, 
   3.993042000657505*^9},ExpressionUUID->"09dc16df-1090-7e41-8982-\
84575274b760"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"NIntegrate", "[", 
  RowBox[{
   FractionBox[
    RowBox[{"Exp", "[", 
     RowBox[{"-", "x"}], "]"}], 
    RowBox[{"Sin", "[", 
     RowBox[{"\[Pi]", " ", "x"}], "]"}]], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "30", ",", "Infinity"}], "}"}], ",", " ", 
   RowBox[{"Exclusions", "->", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Sin", "[", 
       RowBox[{"\[Pi]", " ", "x"}], "]"}], " ", "==", " ", "0"}], ")"}]}], ",", 
   RowBox[{"WorkingPrecision", "->", "2"}], ",", " ", 
   RowBox[{"AccuracyGoal", "->", "4"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.993031331601795*^9, 3.9930313908679047`*^9}, {
  3.993031421200657*^9, 3.9930314497134647`*^9}, {3.9930315068363304`*^9, 
  3.9930317068880444`*^9}, {3.9930317609255543`*^9, 3.993031765184309*^9}, {
  3.993031826202017*^9, 3.993031827401808*^9}, {3.9930319937926216`*^9, 
  3.9930319971128006`*^9}, {3.9930323247638874`*^9, 3.9930323327434597`*^9}, {
  3.9930324477705746`*^9, 3.993032455216427*^9}, {3.9930325433473473`*^9, 
  3.9930325454697514`*^9}, {3.993039879114374*^9, 3.9930399198354454`*^9}, {
  3.9930399514610634`*^9, 3.9930399874387684`*^9}, {3.9930412467544136`*^9, 
  3.993041317277302*^9}, {3.9930413635304375`*^9, 3.9930413640580864`*^9}, {
  3.993041485579338*^9, 3.993041516683918*^9}, {3.99304159015172*^9, 
  3.993041597501009*^9}},
 CellLabel->"In[75]:=",ExpressionUUID->"86eebc6a-8759-b746-a051-1fe91876d83e"],

