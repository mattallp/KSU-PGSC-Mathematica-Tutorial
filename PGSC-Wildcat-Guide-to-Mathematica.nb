  "],ExpressionUUID->"76c01c04-189f-0c4f-9ed1-8b33169eadbf"],

Cell[BoxData[
 TemplateBox[{
  "Integrate", "idiv", 
   "\"Integral of \\!\\(\\*RowBox[{SuperscriptBox[\\\"\[ExponentialE]\\\", \
RowBox[{\\\"-\\\", \\\"x\\\"}]], \\\" \\\", RowBox[{\\\"Csc\\\", \\\"[\\\", \
RowBox[{\\\"\[Pi]\\\", \\\" \\\", \\\"x\\\"}], \\\"]\\\"}]}]\\) does not \
converge on \\!\\(\\*RowBox[{\\\"{\\\", RowBox[{\\\"30\\\", \\\",\\\", \\\"\
\[Infinity]\\\"}], \\\"}\\\"}]\\).\"", 2, 64, 97, 34900017014425649369, 
   "Local"},
  "MessageTemplate",
  BaseStyle->"MSG"]], "Message",
 CellChangeTimes->{
  3.9930322737741337`*^9, 3.993032388857233*^9, 3.9930324240963497`*^9, {
   3.993032511702284*^9, 3.993032517170229*^9}, 3.993041352481247*^9},
