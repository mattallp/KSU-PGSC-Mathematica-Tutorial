   3.976971487787777*^9, {3.9772463042085876`*^9, 3.9772463056383553`*^9}, {
   3.977247239015276*^9, 3.977247343866049*^9}, {3.9772474233519287`*^9, 
   3.977247461797262*^9}, {3.9772477847178707`*^9, 3.9772477994530964`*^9}, {
   3.9772478963172474`*^9, 3.9772478997908688`*^9}, {3.9772485880586033`*^9, 
   3.977248659757139*^9}, {3.9772488305432224`*^9, 
   3.9772488783086967`*^9}},ExpressionUUID->"e9978367-24b3-3348-9a03-\
e6d6f4bab4c8"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"a", ",", "b", ",", "c", ",", "h"}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Clear", " ", "variable", " ", "names"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"h", "[", "x_", "]"}], ":=", " ", 
   RowBox[{
    RowBox[{"a", " ", 
     SuperscriptBox["x", "2"]}], " ", "+", " ", 
    RowBox[{"b", " ", "x"}], " ", "+", " ", "c"}]}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"define", " ", "a", " ", "function", " ", "h", 
     RowBox[{"(", "x", ")"}], " ", "using"}], " ", "="}], "*)"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]"}], "Input",
